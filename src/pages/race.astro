---
// src/pages/race.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
---

<BaseLayout title="Informasi Lomba - Waru Turi Fun Run 2026">
  <Navbar />

  <!-- Hero Section -->
  <section class="relative py-16 sm:py-20 lg:py-28 xl:py-36 bg-gradient-to-br from-[#001a4d] via-[#002266] to-[#0033A0] text-white overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-[-50%] right-[-20%] w-[400px] sm:w-[600px] lg:w-[800px] h-[400px] sm:h-[600px] lg:h-[800px] bg-blue-500/10 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-[-40%] left-[-10%] w-[300px] sm:w-[500px] lg:w-[600px] h-[300px] sm:h-[500px] lg:h-[600px] bg-indigo-500/10 rounded-full blur-3xl animate-float-delay"></div>
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="0.03"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
    </div>
    
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 sm:px-5 py-2 sm:py-2.5 rounded-full text-xs sm:text-sm font-semibold mb-4 sm:mb-6 border border-white/20 animate-fade-down">
          <i class="bi bi-flag text-[#FFD700] text-sm sm:text-base"></i>
          Informasi Lomba
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-extrabold mb-4 sm:mb-6 animate-fade-down animation-delay-200 leading-tight">
          Informasi <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#FFD700] to-[#FFA500]">Lomba</span>
        </h1>
        <p class="text-base sm:text-lg lg:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed px-4 animate-fade-down animation-delay-400">
          Informasi lengkap seputar kategori lomba, rute lari, jadwal, dan ketentuan Fun Run Waru Turi Kediri.
        </p>
        <div class="flex flex-wrap justify-center gap-2 mt-4 sm:mt-6 animate-fade-down animation-delay-600">
          <a href="/" class="text-white/70 hover:text-white text-xs sm:text-sm transition">Home</a>
          <span class="text-white/40 text-xs sm:text-sm">›</span>
          <span class="text-[#FFD700] text-xs sm:text-sm">Informasi Lomba</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== QUICK STATS ===== -->
  <section class="py-8 sm:py-12 bg-gradient-to-b from-white to-[#F7F8FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 max-w-4xl mx-auto">
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-5 text-center shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-[#0045FF]/10 rounded-full flex items-center justify-center mx-auto mb-2 sm:mb-3">
            <i class="bi bi-trophy text-[#0045FF] text-base sm:text-xl"></i>
          </div>
          <p class="text-xl sm:text-2xl font-bold text-gray-900">3</p>
          <p class="text-[10px] sm:text-xs text-gray-500">Kategori Lomba</p>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-5 text-center shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-[#FF6B00]/10 rounded-full flex items-center justify-center mx-auto mb-2 sm:mb-3">
            <i class="bi bi-people text-[#FF6B00] text-base sm:text-xl"></i>
          </div>
          <p class="text-xl sm:text-2xl font-bold text-gray-900">1000+</p>
          <p class="text-[10px] sm:text-xs text-gray-500">Total Peserta</p>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-5 text-center shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-[#20B082]/10 rounded-full flex items-center justify-center mx-auto mb-2 sm:mb-3">
            <i class="bi bi-flag text-[#20B082] text-base sm:text-xl"></i>
          </div>
          <p class="text-xl sm:text-2xl font-bold text-gray-900">5K &amp; 10K</p>
          <p class="text-[10px] sm:text-xs text-gray-500">Jarak Tempuh</p>
        </div>
        <div class="bg-white rounded-xl sm:rounded-2xl p-3 sm:p-5 text-center shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-[#FFD700]/10 rounded-full flex items-center justify-center mx-auto mb-2 sm:mb-3">
            <i class="bi bi-calendar text-[#FFD700] text-base sm:text-xl"></i>
          </div>
          <p class="text-xl sm:text-2xl font-bold text-gray-900">2026</p>
          <p class="text-[10px] sm:text-xs text-gray-500">Tahun Event</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Rundown Kategori -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-12">
        <span class="text-[#0045FF] font-semibold text-[10px] sm:text-sm uppercase tracking-wider">Jadwal Acara</span>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mt-2 mb-2 sm:mb-3">Rundown Kategori</h2>
        <p class="text-sm sm:text-base text-gray-500">Jadwal lengkap untuk peserta Fun Run 5K &amp; 10K</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 max-w-5xl mx-auto">
        <!-- Kategori 10K -->
        <div class="bg-[#F7F8FF] rounded-xl sm:rounded-2xl p-5 sm:p-8 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-[#0045FF] rounded-xl flex items-center justify-center text-white text-lg sm:text-xl font-bold flex-shrink-0">10</div>
            <div>
              <span class="inline-block bg-[#0045FF]/10 text-[#0045FF] text-[10px] sm:text-xs font-bold px-2 sm:px-3 py-1 rounded-full">Kategori 10K</span>
              <h3 class="text-lg sm:text-xl font-bold text-gray-900">Rundown 10K</h3>
            </div>
          </div>
          <ul class="space-y-2">
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 pb-2 border-b border-dashed border-gray-100 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#0045FF] text-xs sm:text-sm min-w-[95px]">04.45 - 05.15</span>
              <span class="text-gray-600 text-xs sm:text-sm">Persiapan &amp; Senam Aerobik</span>
            </li>
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 pb-2 border-b border-dashed border-gray-100 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#0045FF] text-xs sm:text-sm min-w-[95px]">05.15 - 05.20</span>
              <span class="text-gray-600 text-xs sm:text-sm">Persiapan Pemberangkatan</span>
            </li>
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 pb-2 border-b border-dashed border-gray-100 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#0045FF] text-xs sm:text-sm min-w-[95px]">05.20 - 05.30</span>
              <span class="text-gray-600 text-xs sm:text-sm">Start Pemberangkatan 10K</span>
            </li>
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 pb-2 border-b border-dashed border-gray-100 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#0045FF] text-xs sm:text-sm min-w-[95px]">05.40 - 07.30</span>
              <span class="text-gray-600 text-xs sm:text-sm">Fun Run</span>
            </li>
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 pb-2 border-b border-dashed border-gray-100 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#0045FF] text-xs sm:text-sm min-w-[95px]">07.30 - 08.00</span>
              <span class="text-gray-600 text-xs sm:text-sm">Penghijauan Peserta</span>
            </li>
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#0045FF] text-xs sm:text-sm min-w-[95px]">08.00 - 10.00</span>
              <span class="text-gray-600 text-xs sm:text-sm">Hiburan &amp; Doorprize</span>
            </li>
          </ul>
          <p class="text-xs sm:text-sm text-[#0045FF] italic mt-4 flex items-center gap-2">
            <i class="bi bi-info-circle"></i>
            <span>Harap berada di garis start pukul 05.15.</span>
          </p>
        </div>

        <!-- Kategori 5K -->
        <div class="bg-[#F7F8FF] rounded-xl sm:rounded-2xl p-5 sm:p-8 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-[#FF6B00] rounded-xl flex items-center justify-center text-white text-lg sm:text-xl font-bold flex-shrink-0">5</div>
            <div>
              <span class="inline-block bg-[#FF6B00]/10 text-[#FF6B00] text-[10px] sm:text-xs font-bold px-2 sm:px-3 py-1 rounded-full">Kategori 5K</span>
              <h3 class="text-lg sm:text-xl font-bold text-gray-900">Rundown 5K</h3>
            </div>
          </div>
          <ul class="space-y-2">
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 pb-2 border-b border-dashed border-gray-100 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#FF6B00] text-xs sm:text-sm min-w-[95px]">04.45 - 05.15</span>
              <span class="text-gray-600 text-xs sm:text-sm">Persiapan &amp; Senam Aerobik</span>
            </li>
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 pb-2 border-b border-dashed border-gray-100 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#FF6B00] text-xs sm:text-sm min-w-[95px]">05.15 - 05.30</span>
              <span class="text-gray-600 text-xs sm:text-sm">Menunggu Start 10K</span>
            </li>
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 pb-2 border-b border-dashed border-gray-100 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#FF6B00] text-xs sm:text-sm min-w-[95px]">05.30 - 05.40</span>
              <span class="text-gray-600 text-xs sm:text-sm">Start Pemberangkatan 5K</span>
            </li>
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 pb-2 border-b border-dashed border-gray-100 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#FF6B00] text-xs sm:text-sm min-w-[95px]">05.40 - 07.30</span>
              <span class="text-gray-600 text-xs sm:text-sm">Fun Run</span>
            </li>
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 pb-2 border-b border-dashed border-gray-100 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#FF6B00] text-xs sm:text-sm min-w-[95px]">07.30 - 08.00</span>
              <span class="text-gray-600 text-xs sm:text-sm">Penghijauan Peserta</span>
            </li>
            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-3 hover:bg-[#F7F8FF] px-2 sm:px-3 py-2 rounded-lg transition">
              <span class="font-bold text-[#FF6B00] text-xs sm:text-sm min-w-[95px]">08.00 - 10.00</span>
              <span class="text-gray-600 text-xs sm:text-sm">Hiburan &amp; Doorprize</span>
            </li>
          </ul>
          <p class="text-xs sm:text-sm text-[#FF6B00] italic mt-4 flex items-center gap-2">
            <i class="bi bi-info-circle"></i>
            <span>Start dimulai setelah kategori 10K berangkat.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tabs Informasi -->
  <section class="py-12 sm:py-16 bg-[#F7F8FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-12">
        <span class="text-[#0045FF] font-semibold text-[10px] sm:text-sm uppercase tracking-wider">Informasi Lengkap</span>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mt-2 mb-2 sm:mb-3">Waru Turi Fun Run 2026</h2>
        <p class="text-sm sm:text-base text-gray-500 max-w-2xl mx-auto px-4">
          Temukan berbagai informasi penting seputar acara Fun Run mulai dari inovasi acara, keamanan peserta, performa pelaksanaan, hingga dukungan tim panitia.
        </p>
      </div>

      <!-- Tab Buttons - Responsive with scroll -->
      <div class="flex flex-wrap justify-center gap-2 sm:gap-3 mb-6 sm:mb-10 px-2">
        <button class="tab-btn px-4 sm:px-6 py-2.5 sm:py-3 rounded-full text-xs sm:text-sm font-semibold transition-all duration-300 bg-[#0045FF] text-white shadow-lg shadow-[#0045FF]/20 flex items-center gap-1.5 sm:gap-2 flex-shrink-0" data-tab="tab1" onclick="switchTab('tab1')">
          <i class="bi bi-rocket-takeoff text-sm sm:text-base"></i> 
          <span class="hidden xs:inline">Inovasi</span>
        </button>
        <button class="tab-btn px-4 sm:px-6 py-2.5 sm:py-3 rounded-full text-xs sm:text-sm font-semibold transition-all duration-300 bg-gray-200 text-gray-600 hover:bg-gray-300 flex items-center gap-1.5 sm:gap-2 flex-shrink-0" data-tab="tab2" onclick="switchTab('tab2')">
          <i class="bi bi-shield-shaded text-sm sm:text-base"></i> 
          <span class="hidden xs:inline">Keamanan</span>
        </button>
        <button class="tab-btn px-4 sm:px-6 py-2.5 sm:py-3 rounded-full text-xs sm:text-sm font-semibold transition-all duration-300 bg-gray-200 text-gray-600 hover:bg-gray-300 flex items-center gap-1.5 sm:gap-2 flex-shrink-0" data-tab="tab3" onclick="switchTab('tab3')">
          <i class="bi bi-lightning-charge text-sm sm:text-base"></i> 
          <span class="hidden xs:inline">Performa</span>
        </button>
        <button class="tab-btn px-4 sm:px-6 py-2.5 sm:py-3 rounded-full text-xs sm:text-sm font-semibold transition-all duration-300 bg-gray-200 text-gray-600 hover:bg-gray-300 flex items-center gap-1.5 sm:gap-2 flex-shrink-0" data-tab="tab4" onclick="switchTab('tab4')">
          <i class="bi bi-heart-pulse text-sm sm:text-base"></i> 
          <span class="hidden xs:inline">Dukungan</span>
        </button>
      </div>

      <!-- Tab Content -->
      <div class="max-w-5xl mx-auto">
        <!-- Tab 1: Inovasi -->
        <div id="tab1" class="tab-content bg-white rounded-xl sm:rounded-2xl p-5 sm:p-8 shadow-lg">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8 items-center">
            <div>
              <div class="w-12 h-12 sm:w-14 sm:h-14 bg-[#0045FF] rounded-full flex items-center justify-center text-white text-xl sm:text-2xl mb-3 sm:mb-4">
                <i class="bi bi-rocket-takeoff"></i>
              </div>
              <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2 sm:mb-3">Inovasi Dalam Pelaksanaan Fun Run</h3>
              <p class="text-sm sm:text-base text-gray-600 mb-4 sm:mb-5">Kami menghadirkan konsep acara yang modern dan interaktif untuk memberikan pengalaman berlari yang lebih seru, mulai dari rute tematik hingga fitur interaktif pada acara.</p>
              <div class="grid grid-cols-1 xs:grid-cols-2 gap-2 sm:gap-3">
                <div class="flex items-center gap-2 text-xs sm:text-sm text-gray-700 bg-[#F7F8FC] px-2 sm:px-3 py-1.5 sm:py-2 rounded-lg"><i class="bi bi-check-circle-fill text-[#0045FF] text-xs sm:text-sm"></i> Rute tematik menarik</div>
                <div class="flex items-center gap-2 text-xs sm:text-sm text-gray-700 bg-[#F7F8FC] px-2 sm:px-3 py-1.5 sm:py-2 rounded-lg"><i class="bi bi-check-circle-fill text-[#0045FF] text-xs sm:text-sm"></i> Spot foto interaktif</div>
                <div class="flex items-center gap-2 text-xs sm:text-sm text-gray-700 bg-[#F7F8FC] px-2 sm:px-3 py-1.5 sm:py-2 rounded-lg"><i class="bi bi-check-circle-fill text-[#0045FF] text-xs sm:text-sm"></i> Pendataan digital</div>
                <div class="flex items-center gap-2 text-xs sm:text-sm text-gray-700 bg-[#F7F8FC] px-2 sm:px-3 py-1.5 sm:py-2 rounded-lg"><i class="bi bi-check-circle-fill text-[#0045FF] text-xs sm:text-sm"></i> Update real-time</div>
              </div>
            </div>
            <div class="order-first lg:order-last">
              <img src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgdH3wyXVm55V4ybo7Vzkhx20WX5osQDwvKtDVAjCVN7GL-xcIDGsh9s3XjMLGZbjXLeeVM9Bswk9zk8-UgiAs8NcByj2ed5_VEboE7PYmES_VPsGt2sEc9-EKag3eAbRoMPRAKPEr9ldJn94bBGhQZ4EBp3vpBpyaP1pk1YqjdkL802EiL0KVl5PYmyhq_/s710-rw/Isi%20web%20600x600.webp" alt="Inovasi Fun Run" class="w-full rounded-xl shadow-md" loading="lazy">
            </div>
          </div>
        </div>

        <!-- Tab 2: Keamanan -->
        <div id="tab2" class="tab-content bg-white rounded-xl sm:rounded-2xl p-5 sm:p-8 shadow-lg hidden">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8 items-center">
            <div>
              <div class="w-12 h-12 sm:w-14 sm:h-14 bg-[#0045FF] rounded-full flex items-center justify-center text-white text-xl sm:text-2xl mb-3 sm:mb-4">
                <i class="bi bi-shield-shaded"></i>
              </div>
              <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2 sm:mb-3">Keamanan Peserta Fun Run</h3>
              <p class="text-sm sm:text-base text-gray-600 mb-4 sm:mb-5">Kami memastikan keamanan dan kenyamanan seluruh peserta melalui prosedur pengawasan rute, tenaga medis, serta standar keselamatan selama acara berlangsung.</p>
              <div class="grid grid-cols-1 xs:grid-cols-2 gap-2 sm:gap-3">
                <div class="flex items-center gap-2 text-xs sm:text-sm text-gray-700 bg-[#F7F8FC] px-2 sm:px-3 py-1.5 sm:py-2 rounded-lg"><i class="bi bi-check-circle-fill text-[#0045FF] text-xs sm:text-sm"></i> Pengawasan rute</div>
                <div class="flex items-center gap-2 text-xs sm:text-sm text-gray-700 bg-[#F7F8FC] px-2 sm:px-3 py-1.5 sm:py-2 rounded-lg"><i class="bi bi-check-circle-fill text-[#0045FF] text-xs sm:text-sm"></i> Tim medis siaga</div>
                <div class="flex items-center gap-2 text-xs sm:text-sm text-gray-700 bg-[#F7F8FC] px-2 sm:px-3 py-1.5 sm:py-2 rounded-lg"><i class="bi bi-check-circle-fill text-[#0045FF] text-xs sm:text-sm"></i> Penanganan darurat</div>
                <div class="flex items-center gap-2 text-xs sm:text-sm text-gray-700 bg-[#F7F8FC] px-2 sm:px-3 py-1.5 sm:py-2 rounded-lg"><i class="bi bi-check-circle-fill text-[#0045FF] text-xs sm:text-sm"></i> Briefing keamanan</div>
              </div>
            </div>
            <div class="order-first lg:order-last">
              <img src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEiGLXPwjDGAoiJwD8mFMlBULp1ozljorJz-9puxEBQ-XHHlwX71p_vLIWwwfje6u1ilKokDPaWWkWx1XxhKnoNnNXW8NxU7zqNzyKqGyrW9bVzCaSbouHxSZLPTogr_GmanfH_43Z6LEuLtFuXYYgbOx3_ksIlKEj4Klw6UCLCdmsEFo4GdnAuXE-UDNqnr/s1224-rw/keaman.jpg" alt="Keamanan Fun Run" class="w-full rounded-xl shadow-md" loading="lazy">
            </div>
          </div>
        </div>

        <!-- Tab 3: Performa -->
        <div id="tab3" class="tab-content bg-white rounded-xl sm:rounded-2xl p-5 sm:p-8 shadow-lg hidden">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8 items-center">
            <div>
              <div class="w-12 h-12 sm:w-14 sm:h-14 bg-[#0045FF] rounded-full flex items-center justify-center text-white text-xl sm:text-2xl mb-3 sm:mb-4">
                <i class="bi bi-lightning-charge"></i>
              </div>
              <h3 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2 sm:mb-3">Performa &amp; Kelancaran Acara</h3>
