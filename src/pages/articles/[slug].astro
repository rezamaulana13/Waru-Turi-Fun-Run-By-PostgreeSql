---
// src/pages/articles/[slug].astro
// ============================================================
// HALAMAN PREVIEW ADMIN — bukan halaman publik.
// Diakses dari tombol "Lihat" di /admin/articles (dibuka tab baru).
// Bedanya dengan /artikel/[slug] (halaman publik):
//   - Bisa menampilkan artikel status APAPUN: draft, published, archived
//   - TIDAK menambah view count (preview bukan kunjungan sungguhan)
//   - Ada banner "PREVIEW MODE" di atas supaya jelas ini bukan halaman publik
//
// CATATAN: halaman ini belum diberi proteksi login/session karena di
// /admin/articles/index.astro belum ada mekanisme auth yang bisa saya
// ikuti polanya. Kalau nanti auth admin sudah ada, tambahkan pengecekan
// session di awal file ini (redirect ke /admin/login kalau belum login).
// ============================================================
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/common/Navbar.astro';
import Footer from '../../components/common/Footer.astro';
import { db, articles } from '../../db';
import { eq, and, ne, desc } from 'drizzle-orm';

const { slug } = Astro.params;

let artikel: any = null;
let relatedArticles: any[] = [];
let error = '';

try {
  // Tanpa filter status — preview admin harus bisa lihat draft & archived juga
  const result = await db.select()
    .from(articles)
    .where(eq(articles.slug, slug || ''));

  if (result.length > 0) {
    artikel = result[0];

    // Artikel terkait: kategori sama, exclude artikel ini sendiri, published saja
    // (biar related articles yang tampil tetap relevan buat pembaca beneran)
    if (artikel.category) {
      const related = await db.select()
        .from(articles)
        .where(and(
          eq(articles.category, artikel.category),
          eq(articles.status, 'published'),
          ne(articles.id, artikel.id)
        ))
        .orderBy(desc(articles.createdAt));
      relatedArticles = related.slice(0, 3);
    }
  }
} catch (e: any) {
  error = e.message;
  console.error('Error fetching article preview:', e);
}

// ===== 404 kalau artikel benar-benar tidak ada =====
if (!artikel) {
  Astro.response.status = 404;
}

// ===== HELPER FUNCTIONS =====
function formatDate(dateStr: string | Date): string {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function getReadTime(content: string): number {
  if (!content) return 1;
  const words = content.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

function getCategoryColor(category: string): string {
  const colorMap: Record<string, string> = {
    'Tips & Trik': 'bg-blue-100 text-blue-700',
    'Peralatan': 'bg-purple-100 text-purple-700',
    'Nutrisi': 'bg-green-100 text-green-700',
    'Latihan': 'bg-orange-100 text-orange-700',
    'Kesehatan': 'bg-emerald-100 text-emerald-700',
    'Event': 'bg-red-100 text-red-700',
  };
  return colorMap[category] || 'bg-gray-100 text-gray-700';
}

function getStatusBadge(status: string): { label: string; color: string } {
  const map: Record<string, { label: string; color: string }> = {
    published: { label: 'Published', color: 'bg-green-500' },
    draft: { label: 'Draft', color: 'bg-yellow-500' },
    archived: { label: 'Archived', color: 'bg-gray-500' },
  };
  return map[status] || { label: status || 'Unknown', color: 'bg-gray-500' };
}

// Konverter markdown ringan — sama persis dengan halaman publik,
// supaya preview yang admin lihat = hasil akhir yang pembaca lihat.
function renderContent(raw: string): string {
  if (!raw) return '';

  const escapeHtml = (str: string) =>
    str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');

  const inlineFormat = (text: string) =>
    text
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>');

  const lines = escapeHtml(raw).split(/\r?\n/);
  let html = '';
  let inList = false;

  for (const rawLine of lines) {
    const line = rawLine.trim();

    if (line === '') {
      if (inList) { html += '</ul>'; inList = false; }
      continue;
    }

    const headingMatch = line.match(/^(#{1,3})\s+(.*)$/);
    if (headingMatch) {
      if (inList) { html += '</ul>'; inList = false; }
      const level = headingMatch[1].length + 2;
      html += `<h${level}>${inlineFormat(headingMatch[2])}</h${level}>`;
      continue;
    }

    if (line.startsWith('- ')) {
      if (!inList) { html += '<ul>'; inList = true; }
      html += `<li>${inlineFormat(line.slice(2))}</li>`;
      continue;
    }

    if (inList) { html += '</ul>'; inList = false; }
    html += `<p>${inlineFormat(line)}</p>`;
  }

  if (inList) html += '</ul>';
  return html;
}

const contentHtml = artikel ? renderContent(artikel.content) : '';
const tags: string[] = (artikel?.tags || []) as string[];
const statusBadge = artikel ? getStatusBadge(artikel.status) : { label: '', color: '' };
const pageTitle = artikel ? `[Preview] ${artikel.title}` : 'Artikel Tidak Ditemukan';
const pageDescription = artikel
  ? (artikel.metaDescription || artikel.excerpt || '')
  : 'Artikel yang kamu cari tidak ditemukan.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="artikel-page">
    <Navbar />

    {artikel && (
      <!-- ===== ADMIN PREVIEW BANNER ===== -->
      <div class="preview-banner">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-wrap items-center justify-between gap-3 py-2.5">
            <div class="flex items-center gap-2.5 text-sm text-white">
              <i class="bi bi-eye-fill"></i>
              <span class="font-semibold">Mode Preview Admin</span>
              <span class={`px-2 py-0.5 rounded-full text-xs font-bold text-white ${statusBadge.color}`}>
                {statusBadge.label}
              </span>
            </div>
            <a href="/admin/articles" class="text-xs text-white/80 hover:text-white flex items-center gap-1.5 transition">
              <i class="bi bi-arrow-left"></i>
              Kembali ke Admin
            </a>
          </div>
        </div>
      </div>
    )}

    {error && (
      <section class="py-4 bg-red-50 border-b border-red-200">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <p class="text-red-700 text-sm">
            <i class="bi bi-exclamation-circle-fill mr-1"></i>
            Gagal memuat artikel: {error}
          </p>
        </div>
      </section>
    )}

    {artikel ? (
      <>
        <!-- ===== BREADCRUMB + TITLE (berdiri sendiri di awal) ===== -->
        <section class="bg-white pt-8 md:pt-12 pb-6 md:pb-8 border-b border-gray-100">
          <div class="container mx-auto px-4 sm:px-6 lg:px-8">
            <div class="max-w-3xl mx-auto">
              <nav class="text-xs text-gray-400 mb-4 flex items-center gap-2">
                <a href="/admin/articles" class="hover:text-[#2679ec] transition">Admin</a>
                <span>›</span>
                <span class="text-gray-500 line-clamp-1">{artikel.title}</span>
              </nav>

              {artikel.category && (
                <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold mb-4 ${getCategoryColor(artikel.category)}`}>
                  {artikel.category}
                </span>
              )}

              <h1 class="text-3xl md:text-[2.75rem] font-extrabold text-gray-900 leading-tight tracking-tight">
                {artikel.title}
              </h1>

              {artikel.subtitle && (
                <p class="text-gray-500 text-base md:text-lg mt-4 leading-relaxed">
                  {artikel.subtitle}
                </p>
              )}

              <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-gray-500 mt-6 pt-6 border-t border-gray-100">
                <span class="flex items-center gap-1.5">
                  <i class="bi bi-person-circle text-gray-400"></i>
                  {artikel.authorName || 'Admin'}
                </span>
                <span class="flex items-center gap-1.5">
                  <i class="bi bi-calendar3 text-gray-400"></i>
                  {formatDate(artikel.createdAt)}
                </span>
                <span class="flex items-center gap-1.5">
                  <i class="bi bi-clock text-gray-400"></i>
                  {getReadTime(artikel.content)} min read
                </span>
                <span class="flex items-center gap-1.5">
                  <i class="bi bi-eye text-gray-400"></i>
                  {artikel.viewCount || 0} views
                </span>
              </div>
            </div>
          </div>
        </section>

        <!-- ===== FEATURED IMAGE (ukuran asli) ===== -->
        {artikel.featuredImage && (
          <section class="bg-white pt-8 md:pt-10">
            <div class="container mx-auto px-4 sm:px-6 lg:px-8">
              <div class="max-w-4xl mx-auto">
                <img
                  src={artikel.featuredImage}
                  alt={artikel.title}
                  class="w-full h-auto rounded-2xl"
                />
              </div>
            </div>
          </section>
        )}

        <!-- ===== CONTENT ===== -->
        <section class="py-10 bg-white">
          <div class="container mx-auto px-4 sm:px-6 lg:px-8">
            <div class="max-w-3xl mx-auto">
              <article class="artikel-content" set:html={contentHtml} />

              {tags.length > 0 && (
                <div class="flex flex-wrap items-center gap-2 mt-10 pt-6 border-t border-gray-100">
                  <i class="bi bi-tags text-gray-400 mr-1"></i>
                  {tags.map((tag) => (
                    <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              <div class="mt-8 flex items-center gap-4">
                <a href="/admin/articles" class="inline-flex items-center gap-2 text-[#2679ec] font-semibold text-sm hover:gap-3 transition-all">
                  <i class="bi bi-arrow-left"></i>
                  Kembali ke Admin
                </a>
                <a href={`/admin/articles?edit=${artikel.id}`} class="inline-flex items-center gap-2 text-gray-500 font-semibold text-sm hover:text-[#2679ec] transition">
                  <i class="bi bi-pencil"></i>
                  Edit Artikel Ini
                </a>
              </div>
            </div>
          </div>
        </section>

        <!-- ===== RELATED ARTICLES ===== -->
        {relatedArticles.length > 0 && (
          <section class="py-12 bg-[#F7F8FC]">
            <div class="container mx-auto px-4 sm:px-6 lg:px-8">
              <div class="max-w-5xl mx-auto">
                <div class="flex items-center gap-3 mb-6">
                  <span class="w-1 h-7 bg-[#2679ec] rounded-full"></span>
                  <h2 class="text-xl font-bold text-gray-900">Artikel Terkait (Published)</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                  {relatedArticles.map((rel) => (
                    <a
                      href={`/articles/${rel.slug}`}
                      class="group block bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-gray-100 hover:-translate-y-1"
                    >
                      <div class="relative h-36 overflow-hidden">
                        {rel.featuredImage ? (
                          <img
                            src={rel.featuredImage}
                            alt={rel.title}
                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                            loading="lazy"
                          />
                        ) : (
                          <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                            <i class="bi bi-image text-3xl text-gray-400"></i>
                          </div>
                        )}
                      </div>
                      <div class="p-4">
                        <h3 class="text-sm font-bold text-gray-900 group-hover:text-[#2679ec] transition-colors line-clamp-2">
                          {rel.title}
                        </h3>
                        <p class="text-xs text-gray-400 mt-2">{formatDate(rel.createdAt)}</p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </section>
        )}
      </>
    ) : (
      <!-- ===== NOT FOUND ===== -->
      <section class="py-24 bg-white">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-lg mx-auto text-center">
            <div class="w-28 h-28 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
              <i class="bi bi-file-earmark-x text-5xl text-gray-400"></i>
            </div>
            <h1 class="text-2xl font-bold text-gray-900 mb-3">Artikel Tidak Ditemukan</h1>
            <p class="text-gray-500 mb-6">
              Artikel dengan slug ini tidak ada di database, atau mungkin sudah dihapus.
            </p>
            <a href="/admin/articles" class="inline-flex items-center gap-2 px-6 py-3 bg-[#2679ec] text-white rounded-xl hover:bg-[#1a5fc7] transition">
              <i class="bi bi-arrow-left"></i>
              Kembali ke Admin
            </a>
          </div>
        </div>
      </section>
    )}

    <Footer />
  </div>
</BaseLayout>

<style>
  /* Font Open Sans, konsisten dengan halaman publik */
  @import url('https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap');

  .artikel-page {
    font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .preview-banner {
    background: repeating-linear-gradient(
      45deg,
      #1a1a1a,
      #1a1a1a 10px,
      #2d2d2d 10px,
      #2d2d2d 20px
    );
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .artikel-content {
    color: #374151;
    font-size: 17px;
    line-height: 1.85;
  }
  .artikel-content :global(h3) {
    font-size: 22px;
    font-weight: 800;
    color: #111827;
    margin-top: 32px;
    margin-bottom: 12px;
  }
  .artikel-content :global(h4) {
    font-size: 19px;
    font-weight: 700;
    color: #111827;
    margin-top: 24px;
    margin-bottom: 10px;
  }
  .artikel-content :global(h5) {
    font-size: 16px;
    font-weight: 700;
    color: #111827;
    margin-top: 20px;
    margin-bottom: 8px;
  }
  .artikel-content :global(p) {
    margin-bottom: 16px;
  }
  .artikel-content :global(ul) {
    list-style: disc;
    padding-left: 22px;
    margin-bottom: 16px;
  }
  .artikel-content :global(li) {
    margin-bottom: 6px;
  }
  .artikel-content :global(strong) {
    font-weight: 700;
    color: #111827;
  }
</style>