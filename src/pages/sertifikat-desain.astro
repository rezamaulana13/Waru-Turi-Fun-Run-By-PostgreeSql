---
// src/pages/sertifikat-desain.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
import { db, participants, certificates } from '../db/index.js';
import { eq, desc } from 'drizzle-orm';

let participantsData: any[] = [];
let certificatesData: any = {};

try {
  const result = await db.select().from(participants).orderBy(desc(participants.createdAt));
  participantsData = result;

  const certResult = await db.select({
    participantId: certificates.participantId,
    certificateNumber: certificates.certificateNumber,
    fileUrl: certificates.fileUrl,
    status: certificates.status,
  })
  .from(certificates)
  .where(eq(certificates.status, 'issued'));

  certificatesData = certResult.reduce((acc: any, cert: any) => {
    acc[cert.participantId] = {
      number: cert.certificateNumber,
      url: cert.fileUrl,
    };
    return acc;
  }, {});

} catch (error) {
  console.error('Error fetching data:', error);
}

const certificateTypes = [
  {
    id: 'finisher',
    title: 'Sertifikat Finisher',
    subtitle: 'Penghargaan untuk Peserta yang Menyelesaikan Lomba',
    icon: 'bi-award',
    borderColor: 'from-[#FFD700] via-[#F4A460] to-[#FFD700]',
    accentColor: '#FFD700',
    textColor: '#8B6914',
    badge: '🏅 Finisher',
    watermark: 'bi-award',
    watermarkColor: '#FFD700',
    defaultName: 'BUDI SANTOSO',
    defaultCategory: '5K Fun Run',
    defaultTime: '00:25:30',
    defaultBib: '001',
  },
  {
    id: 'participant',
    title: 'Sertifikat Peserta',
    subtitle: 'Penghargaan untuk Semua Peserta',
    icon: 'bi-person-check',
    borderColor: 'from-[#0033A0] via-[#4169E1] to-[#0033A0]',
    accentColor: '#0033A0',
    textColor: '#1a3a7a',
    badge: '🎽 Peserta',
    watermark: 'bi-person-check',
    watermarkColor: '#0033A0',
    defaultName: 'SITI RAHAYU',
    defaultCategory: '10K Fun Run',
    defaultTime: '',
    defaultBib: '002',
  },
  {
    id: 'winner',
    title: 'Sertifikat Pemenang',
    subtitle: 'Penghargaan untuk Juara Lomba',
    icon: 'bi-trophy',
    borderColor: 'from-[#FF4500] via-[#FF6B00] to-[#FF4500]',
    accentColor: '#FF4500',
    textColor: '#CC3300',
    badge: '🏆 Juara',
    watermark: 'bi-trophy',
    watermarkColor: '#FF4500',
    defaultName: 'ANDI WIJAYA',
    defaultCategory: '5K Fun Run',
    defaultTime: '00:27:45',
    defaultBib: '003',
  },
  {
    id: 'volunteer',
    title: 'Sertifikat Relawan',
    subtitle: 'Penghargaan untuk Tim Relawan',
    icon: 'bi-heart',
    borderColor: 'from-[#E91E63] via-[#F06292] to-[#E91E63]',
    accentColor: '#E91E63',
    textColor: '#880E4F',
    badge: '🤝 Relawan',
    watermark: 'bi-heart-fill',
    watermarkColor: '#E91E63',
    defaultName: 'TIM RELAWAN',
    defaultCategory: 'Volunteer',
    defaultTime: '',
    defaultBib: 'V-001',
  },
  {
    id: 'sponsor',
    title: 'Sertifikat Sponsor',
    subtitle: 'Penghargaan untuk Mitra Sponsor',
    icon: 'bi-building',
    borderColor: 'from-[#2E7D32] via-[#4CAF50] to-[#2E7D32]',
    accentColor: '#2E7D32',
    textColor: '#1B5E20',
    badge: '💎 Sponsor',
    watermark: 'bi-building',
    watermarkColor: '#2E7D32',
    defaultName: 'PT. MAJU JAYA',
    defaultCategory: 'Sponsor Utama',
    defaultTime: '',
    defaultBib: 'S-001',
  },
  {
    id: 'media',
    title: 'Sertifikat Media Partner',
    subtitle: 'Penghargaan untuk Mitra Media',
    icon: 'bi-newspaper',
    borderColor: 'from-[#6A1B9A] via-[#9C27B0] to-[#6A1B9A]',
    accentColor: '#6A1B9A',
    textColor: '#4A148C',
    badge: '📰 Media',
    watermark: 'bi-newspaper',
    watermarkColor: '#6A1B9A',
    defaultName: 'RADAR KEDIRI',
    defaultCategory: 'Media Partner',
    defaultTime: '',
    defaultBib: 'M-001',
  },
];

let latestParticipant = participantsData.length > 0 ? participantsData[0] : null;
let defaultName = latestParticipant?.fullName || 'BUDI SANTOSO';
let defaultCategory = latestParticipant?.category || '5K Fun Run';
let defaultBib = String(latestParticipant?.bibNumber || '001').padStart(3, '0');

const updatedCertificateTypes = certificateTypes.map(cert => ({
  ...cert,
  defaultName: defaultName,
  defaultCategory: defaultCategory,
  defaultBib: defaultBib,
}));
---

<BaseLayout title="Desain Sertifikat - Waru Turi Fun Run 2026">
  <Navbar />

  <section class="sertifikat-hero">
    <div class="sertifikat-overlay"></div>
    <div class="sertifikat-hero-content">
      <h2 class="sertifikat-title">Desain Sertifikat</h2>
      <p class="sertifikat-subtitle">Edit nama dan data peserta secara real-time, lalu download sebagai PNG.</p>
      <div class="sertifikat-breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <span>Desain Sertifikat</span>
      </div>
    </div>
  </section>

  <section class="py-4 bg-white border-b border-gray-100 sticky top-[72px] z-40 shadow-sm">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto flex flex-wrap gap-2 justify-center">
        {updatedCertificateTypes.map((cert) => (
          <button 
            key={cert.id}
            class="cert-nav-btn px-4 py-2 rounded-full text-sm font-medium transition-all"
            data-target={cert.id}
            data-color={cert.accentColor}
          >
            <i class={`${cert.icon} mr-1.5`}></i>
            {cert.badge}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="py-8 bg-[#F4F7FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-5 gap-8">
        
        <div class="lg:col-span-3">
          <div id="certificate-container" class="relative">
            {updatedCertificateTypes.map((cert, index) => (
              <div 
                key={cert.id}
                class={`certificate-wrapper ${index === 0 ? 'active' : 'hidden'}`}
                data-type={cert.id}
              >
                <div class="certificate-card bg-white rounded-3xl shadow-2xl overflow-hidden transform transition-all duration-500 hover:shadow-3xl">
                  <div class={`certificate-border p-4 bg-gradient-to-br ${cert.borderColor}`}>
                    <div class="certificate-inner bg-white p-8 md:p-10 relative">
                      
                      <div class="absolute top-4 left-4 w-10 h-10 border-t-4 border-l-4 border-[#FFD700]/30 rounded-tl-2xl"></div>
                      <div class="absolute top-4 right-4 w-10 h-10 border-t-4 border-r-4 border-[#FFD700]/30 rounded-tr-2xl"></div>
                      <div class="absolute bottom-4 left-4 w-10 h-10 border-b-4 border-l-4 border-[#FFD700]/30 rounded-bl-2xl"></div>
                      <div class="absolute bottom-4 right-4 w-10 h-10 border-b-4 border-r-4 border-[#FFD700]/30 rounded-br-2xl"></div>

                      <div class="absolute inset-0 flex items-center justify-center opacity-[0.04] pointer-events-none">
                        <i class={`${cert.watermark} text-[400px]`} style={{ color: cert.accentColor }}></i>
                      </div>

                      <div class="text-center relative z-10">
                        <div class="flex items-center justify-center gap-2 mb-2">
                          <div class={`w-12 h-1 bg-gradient-to-r ${cert.borderColor} rounded-full`}></div>
                        </div>
                        
                        <img 
                          src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEj_7yqZkol2_oh-DOsILVsPCd4wV11OjAalFSlWtVwgX-ryCIq6eL8swt_xsLkmxpEC4FQYEUFr38libsnOhSPimz7DcWGHpA09petmLf_YWdDVKDHSrZlHV2j3aoYNsmQwmLMJCd2-Qfk2IdjRUlk6beTlQbJVb362F3FjKjs2L2nqBke4V_NTeCDBc816/s704/logo%20fun%20run%202026.webp" 
                          alt="Waru Turi Fun Run" 
                          class="h-14 mx-auto mb-2 object-contain"
                        />

                        <div class="inline-flex items-center gap-2 px-4 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-2" style={{ background: `${cert.accentColor}15`, color: cert.accentColor, border: `1px solid ${cert.accentColor}30` }}>
                          <i class={`${cert.icon} text-sm`}></i>
                          {cert.badge}
                        </div>

                        <h2 class={`text-2xl md:text-3xl font-extrabold tracking-wider mb-1`} style={{ color: cert.textColor }}>
                          {cert.title}
                        </h2>
                        <div class={`w-20 h-1 bg-gradient-to-r ${cert.borderColor} mx-auto rounded-full`}></div>
                        <p class="text-gray-500 text-xs mt-2 font-medium">{cert.subtitle}</p>
                      </div>

                      <div class="text-center py-6 relative z-10">
                        <p class="text-gray-400 text-xs uppercase tracking-widest font-semibold">Diberikan Kepada</p>
                        
                        <div class="relative inline-block my-3 px-6">
                          <div class="absolute -inset-1 bg-gradient-to-r from-transparent via-[#FFD700]/20 to-transparent blur-xl"></div>
                          <h3 
                            id={`name-${cert.id}`}
                            class="editable-name text-3xl md:text-4xl font-extrabold text-gray-900 relative cursor-text hover:bg-gray-50 rounded-lg px-4 py-1 transition-colors"
                            style={{ color: cert.textColor }}
                            contenteditable="true"
                            spellcheck="false"
                          >
                            {cert.defaultName}
                          </h3>
                          <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 text-[10px] text-gray-400 opacity-0 group-hover:opacity-100 transition-opacity">
                            <i class="bi bi-pencil"></i> Klik untuk edit
                          </div>
                        </div>
                        
                        <div class={`w-24 h-0.5 mx-auto ${cert.id === 'winner' ? 'bg-[#FFD700]' : 'bg-gray-300'}`}></div>
                        
                        <div class="mt-3 space-y-1">
                          <p class="text-gray-600 text-sm">
                            Telah berhasil menyelesaikan <span class="font-bold" style={{ color: cert.textColor }}>
                              <span id={`category-${cert.id}`} class="editable-text" contenteditable="true" spellcheck="false">{cert.defaultCategory}</span>
                            </span>
                          </p>
                          {cert.id === 'winner' && (
                            <p class="text-gray-600 text-sm">
                              Sebagai <span class="font-bold text-[#FFD700]">
                                <span id={`position-${cert.id}`} class="editable-text" contenteditable="true" spellcheck="false">Juara 1</span>
                              </span>
                            </p>
                          )}
                          {cert.id === 'finisher' && (
                            <p class="text-gray-500 text-sm">
                              Dengan waktu <span class="font-semibold text-gray-700">
                                <span id={`time-${cert.id}`} class="editable-text" contenteditable="true" spellcheck="false">{cert.defaultTime}</span>
                              </span>
                            </p>
                          )}
                          <p class="text-gray-500 text-sm">
                            Nomor BIB: <span class="font-semibold text-gray-700">
                              <span id={`bib-${cert.id}`} class="editable-text" contenteditable="true" spellcheck="false">{cert.defaultBib}</span>
                            </span>
                          </p>
                        </div>
                      </div>

                      <div class="relative z-10">
                        <div class="flex flex-col md:flex-row justify-between items-center gap-3 pt-3 border-t-2" style={{ borderColor: `${cert.accentColor}30` }}>
                          <div class="text-center">
                            <div class="w-28 h-10 border-b-2 border-gray-400 mx-auto"></div>
                            <p class="text-gray-500 text-[10px] mt-1 font-medium">Ketua Panitia</p>
                          </div>
                          <div class="text-center">
                            <div class="w-28 h-10 border-b-2 border-gray-400 mx-auto"></div>
                            <p class="text-gray-500 text-[10px] mt-1 font-medium">Koordinator Lomba</p>
                          </div>
                          <div class="text-center">
                            <p class="font-bold text-base" style={{ color: cert.textColor }}>WARU TURI</p>
                            <p class="text-gray-400 text-[10px]">15 Februari 2026</p>
                            <div class="flex items-center justify-center gap-1 mt-0.5">
                              <span class="w-4 h-0.5 bg-gray-300"></span>
                              <span class="text-[8px] text-gray-400">Official</span>
                              <span class="w-4 h-0.5 bg-gray-300"></span>
                            </div>
                          </div>
                        </div>

                        <div class="text-center mt-3 pt-2 border-t border-gray-100">
                          <p class="text-[8px] text-gray-400 font-mono tracking-wider">
                            Cert. No: WTF-2026-{cert.id.toUpperCase()}-<span id={`certno-${cert.id}`} class="editable-text" contenteditable="true" spellcheck="false">001</span>
                          </p>
                        </div>
                      </div>

                      <div class="absolute bottom-16 right-6 opacity-15 pointer-events-none">
                        <svg width="60" height="60" viewBox="0 0 100 100">
                          <circle cx="50" cy="50" r="45" fill="none" stroke={cert.accentColor} stroke-width="2"/>
                          <circle cx="50" cy="50" r="35" fill="none" stroke={cert.accentColor} stroke-width="1" stroke-dasharray="4 4"/>
                          <text x="50" y="55" font-size="12" text-anchor="middle" fill={cert.accentColor} font-weight="bold">OFFICIAL</text>
                        </svg>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-4 text-center">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-full shadow-sm border border-gray-100 text-xs text-gray-500">
              <i class="bi bi-pencil-square text-[#2679ec]"></i>
              <span>Klik pada teks untuk mengedit</span>
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-4">
          <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
            <h4 class="font-bold text-gray-900 text-sm mb-4 flex items-center gap-2">
              <i class="bi bi-download text-[#2679ec]"></i>
              Download Sertifikat
            </h4>
            <div class="space-y-2.5">
              {updatedCertificateTypes.map((cert) => (
                <button 
                  key={cert.id}
                  id={`download-btn-${cert.id}`}
                  class="cert-download-btn w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-white font-semibold transition-all hover:-translate-y-0.5 shadow-md hover:shadow-lg text-sm"
                  style={`background: ${cert.accentColor};`}
                  data-type={cert.id}
                  onclick="handleDownload(this)"
                >
                  <i class="bi bi-download"></i>
                  {cert.badge}
                </button>
              ))}
            </div>
            <p class="text-[10px] text-gray-400 mt-3 text-center">
              <i class="bi bi-info-circle"></i> PNG • 2.5x resolution
            </p>
          </div>

          <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
            <h4 class="font-bold text-gray-900 text-sm mb-4 flex items-center gap-2">
              <i class="bi bi-pencil text-[#2679ec]"></i>
              Edit Cepat
            </h4>
            
            <div class="space-y-3">
              {updatedCertificateTypes.map((cert) => (
                <div key={cert.id} class="edit-form-group hidden" data-type={cert.id}>
                  <div class="space-y-2.5">
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">Nama Peserta</label>
                      <input 
                        type="text" 
                        class="edit-input w-full px-3 py-2 text-sm rounded-lg border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all"
                        data-target={`name-${cert.id}`}
                        value={cert.defaultName}
                        placeholder="Masukkan nama"
                      />
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">Kategori</label>
                      <input 
                        type="text" 
                        class="edit-input w-full px-3 py-2 text-sm rounded-lg border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all"
                        data-target={`category-${cert.id}`}
                        value={cert.defaultCategory}
                        placeholder="Masukkan kategori"
                      />
                    </div>
                    {cert.id === 'finisher' && (
                      <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Waktu</label>
                        <input 
                          type="text" 
                          class="edit-input w-full px-3 py-2 text-sm rounded-lg border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all"
                          data-target={`time-${cert.id}`}
                          value={cert.defaultTime}
                          placeholder="00:00:00"
                        />
                      </div>
                    )}
                    {cert.id === 'winner' && (
                      <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Posisi</label>
                        <input 
                          type="text" 
                          class="edit-input w-full px-3 py-2 text-sm rounded-lg border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all"
                          data-target={`position-${cert.id}`}
                          value="Juara 1"
                          placeholder="Juara 1 / 2 / 3"
                        />
                      </div>
                    )}
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">Nomor BIB</label>
                      <input 
                        type="text" 
                        class="edit-input w-full px-3 py-2 text-sm rounded-lg border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all"
                        data-target={`bib-${cert.id}`}
                        value={cert.defaultBib}
                        placeholder="Masukkan nomor BIB"
                      />
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">No. Sertifikat</label>
                      <input 
                        type="text" 
                        class="edit-input w-full px-3 py-2 text-sm rounded-lg border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all"
                        data-target={`certno-${cert.id}`}
                        value="001"
                        placeholder="Nomor sertifikat"
                      />
                    </div>
                    <button 
                      onclick="resetCertificate('${cert.id}')"
                      class="w-full text-sm text-gray-500 hover:text-[#2679ec] transition-colors py-1.5 border border-dashed border-gray-200 rounded-lg hover:border-[#2679ec]/30"
                    >
                      <i class="bi bi-arrow-counterclockwise mr-1"></i> Reset ke default
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <button 
            onclick="resetAllCertificates()"
            class="w-full py-2.5 text-sm text-gray-500 hover:text-red-500 transition-colors border border-dashed border-gray-200 rounded-xl hover:border-red-300"
          >
            <i class="bi bi-arrow-counterclockwise mr-1"></i> Reset Semua
          </button>

          <div class="bg-[#F0F7FF] rounded-xl p-4 border border-[#0033A0]/10">
            <h5 class="text-sm font-bold text-gray-900 mb-2 flex items-center gap-2">
              <i class="bi bi-database text-[#0033A0]"></i>
              Sertifikat Tersimpan
            </h5>
            <div class="space-y-1.5 max-h-40 overflow-y-auto">
              {participantsData.length === 0 ? (
                <p class="text-xs text-gray-400">Belum ada sertifikat tersimpan</p>
              ) : (
                participantsData.map(p => {
                  const cert = certificatesData[p.id];
                  return (
                    <div key={p.id} class="flex items-center justify-between text-xs py-1.5 border-b border-gray-100 last:border-0">
                      <span class="font-medium text-gray-700">{p.fullName}</span>
                      {cert ? (
                        <a href={cert.url || '#'} target="_blank" class="text-[#20B082] hover:underline font-semibold flex items-center gap-1">
                          <i class="bi bi-check-circle-fill text-[10px]"></i> Lihat
                        </a>
                      ) : (
                        <span class="text-gray-400 text-[10px]">Belum issued</span>
                      )}
                    </div>
                  );
                })
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-10">
          <span class="text-[#2679ec] font-semibold text-sm uppercase tracking-wider">Keunggulan</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2">Desain Premium & Interaktif</h2>
          <p class="text-gray-500 text-base max-w-2xl mx-auto">Edit nama dan data peserta secara real-time sebelum download.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-[#F7F8FC] rounded-2xl p-6 text-center hover:shadow-lg transition-all hover:-translate-y-1">
            <div class="w-16 h-16 bg-[#2679ec]/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <i class="bi bi-pencil-square text-2xl text-[#2679ec]"></i>
            </div>
            <h4 class="font-bold text-gray-900">Edit Real-Time</h4>
            <p class="text-gray-500 text-sm mt-2">Klik langsung pada sertifikat atau gunakan form untuk mengedit data.</p>
          </div>

          <div class="bg-[#F7F8FC] rounded-2xl p-6 text-center hover:shadow-lg transition-all hover:-translate-y-1">
            <div class="w-16 h-16 bg-[#2679ec]/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <i class="bi bi-palette text-2xl text-[#2679ec]"></i>
            </div>
            <h4 class="font-bold text-gray-900">6 Kategori</h4>
            <p class="text-gray-500 text-sm mt-2">Tersedia 6 jenis sertifikat untuk berbagai kategori penghargaan.</p>
          </div>

          <div class="bg-[#F7F8FC] rounded-2xl p-6 text-center hover:shadow-lg transition-all hover:-translate-y-1">
            <div class="w-16 h-16 bg-[#2679ec]/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <i class="bi bi-download text-2xl text-[#2679ec]"></i>
            </div>
            <h4 class="font-bold text-gray-900">Download PNG</h4>
            <p class="text-gray-500 text-sm mt-2">Simpan sertifikat sebagai gambar PNG resolusi tinggi.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-gradient-to-br from-[#001a4d] via-[#002266] to-[#0033A0] text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
