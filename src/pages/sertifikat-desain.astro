<script>
  // ============================================================
  // DATA SERTIFIKAT UNTUK RESET
  // ============================================================
  const certificateTypes = [
    { id: 'finisher', defaultName: 'BUDI SANTOSO', defaultCategory: '5K Fun Run', defaultTime: '00:25:30', defaultBib: '001' },
    { id: 'participant', defaultName: 'SITI RAHAYU', defaultCategory: '10K Fun Run', defaultTime: '', defaultBib: '002' },
    { id: 'winner', defaultName: 'ANDI WIJAYA', defaultCategory: '5K Fun Run', defaultTime: '00:27:45', defaultBib: '003' },
    { id: 'volunteer', defaultName: 'TIM RELAWAN', defaultCategory: 'Volunteer', defaultTime: '', defaultBib: 'V-001' },
    { id: 'sponsor', defaultName: 'PT. MAJU JAYA', defaultCategory: 'Sponsor Utama', defaultTime: '', defaultBib: 'S-001' },
    { id: 'media', defaultName: 'RADAR KEDIRI', defaultCategory: 'Media Partner', defaultTime: '', defaultBib: 'M-001' },
  ];

  // ============================================================
  // DOWNLOAD FUNCTION - GLOBAL
  // ============================================================
  function handleDownload(btn) {
    const type = btn.dataset.type;
    const title = btn.closest('.space-y-2.5').querySelector(`[data-type="${type}"]`)?.dataset.title || 'Sertifikat';
    const fileName = 'Sertifikat_' + title.replace(/ /g, '_') + '_WaruTuri';
    
    console.log('🟢 Downloading:', type, fileName);
    
    const wrapper = document.querySelector(`.certificate-wrapper[data-type="${type}"]`);
    if (!wrapper) {
      console.error('❌ Wrapper not found');
      alert('Sertifikat tidak ditemukan!');
      return;
    }

    const element = wrapper.querySelector('.certificate-card');
    if (!element) {
      console.error('❌ Certificate card not found');
      alert('Elemen sertifikat tidak ditemukan!');
      return;
    }

    const originalText = btn.innerHTML;
    btn.innerHTML = '<span class="animate-spin inline-block w-4 h-4 border-2 border-white/30 border-t-white rounded-full mr-2"></span> Loading...';
    btn.disabled = true;
    btn.style.opacity = '0.7';

    const editables = element.querySelectorAll('[contenteditable="true"]');
    editables.forEach(el => {
      el.setAttribute('contenteditable', 'false');
    });

    html2canvas(element, {
      scale: 2.5,
      useCORS: true,
      backgroundColor: '#ffffff',
      logging: false,
      allowTaint: true,
      width: element.scrollWidth,
      height: element.scrollHeight,
    })
    .then(canvas => {
      const link = document.createElement('a');
      link.download = `${fileName}.png`;
      link.href = canvas.toDataURL('image/png', 1.0);
      link.click();

      editables.forEach(el => {
        el.setAttribute('contenteditable', 'true');
      });

      btn.innerHTML = originalText;
      btn.disabled = false;
      btn.style.opacity = '1';
      
      console.log('✅ Download successful!');
    })
    .catch(err => {
      console.error('❌ Error:', err);
      
      editables.forEach(el => {
        el.setAttribute('contenteditable', 'true');
      });

      btn.innerHTML = originalText;
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.style.background = '#ef4444';
      setTimeout(() => {
        btn.style.background = '';
      }, 3000);
      alert('Terjadi kesalahan: ' + err.message);
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    const navButtons = document.querySelectorAll('.cert-nav-btn');
    const certificates = document.querySelectorAll('.certificate-wrapper');
    const downloadButtons = document.querySelectorAll('.cert-download-btn');
    const editForms = document.querySelectorAll('.edit-form-group');

    navButtons.forEach(btn => {
      btn.addEventListener('click', function() {
        const target = this.dataset.target;
        const color = this.dataset.color;

        navButtons.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        this.style.background = color;
        this.style.color = 'white';
        
        navButtons.forEach(b => {
          if (b !== this) {
            b.style.background = '';
            b.style.color = '';
          }
        });

        certificates.forEach(cert => {
          cert.classList.remove('active');
          cert.classList.add('hidden');
          if (cert.dataset.type === target) {
            cert.classList.remove('hidden');
            cert.classList.add('active');
          }
        });

        editForms.forEach(form => {
          form.classList.remove('active');
          form.classList.add('hidden');
          if (form.dataset.type === target) {
            form.classList.remove('hidden');
            form.classList.add('active');
          }
        });

        downloadButtons.forEach(btn => {
          btn.style.display = btn.dataset.type === target ? 'inline-flex' : 'none';
        });
      });
    });

    if (navButtons.length > 0) {
      navButtons[0].click();
    }

    document.querySelectorAll('.editable-name, .editable-text').forEach(el => {
      el.addEventListener('input', function() {
        const id = this.id;
        const input = document.querySelector(`.edit-input[data-target="${id}"]`);
        if (input && input.value !== this.textContent) {
          input.value = this.textContent;
        }
      });

      el.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          this.blur();
        }
      });
    });

    document.querySelectorAll('.edit-input').forEach(input => {
      input.addEventListener('input', function() {
        const targetId = this.dataset.target;
        const targetEl = document.getElementById(targetId);
        if (targetEl) {
          targetEl.textContent = this.value || this.placeholder || ' ';
          if (!this.value && this.placeholder) {
            targetEl.textContent = this.placeholder;
          }
        }
      });
    });

    window.resetCertificate = function(type) {
      const cert = certificateTypes.find(c => c.id === type);
      if (!cert) return;

      const nameEl = document.getElementById(`name-${type}`);
      if (nameEl) nameEl.textContent = cert.defaultName;
      
      const categoryEl = document.getElementById(`category-${type}`);
      if (categoryEl) categoryEl.textContent = cert.defaultCategory;
      
      const timeEl = document.getElementById(`time-${type}`);
      if (timeEl && cert.defaultTime) timeEl.textContent = cert.defaultTime;
      
      const positionEl = document.getElementById(`position-${type}`);
      if (positionEl) positionEl.textContent = 'Juara 1';
      
      const bibEl = document.getElementById(`bib-${type}`);
      if (bibEl) bibEl.textContent = cert.defaultBib;
      
      const certnoEl = document.getElementById(`certno-${type}`);
      if (certnoEl) certnoEl.textContent = '001';

      const inputs = document.querySelectorAll(`.edit-input[data-target^="${type}"]`);
      inputs.forEach(input => {
        const targetId = input.dataset.target;
        if (targetId.includes('position')) {
          input.value = 'Juara 1';
        } else if (targetId.includes('time')) {
          input.value = cert.defaultTime || '';
        } else if (targetId.includes('certno')) {
          input.value = '001';
        } else {
          const defaultMap = {
            [`name-${type}`]: cert.defaultName,
            [`category-${type}`]: cert.defaultCategory,
            [`bib-${type}`]: cert.defaultBib,
          };
          input.value = defaultMap[targetId] || '';
        }
      });
    };

    window.resetAllCertificates = function() {
      if (!confirm('Reset semua sertifikat ke default?')) return;
      certificateTypes.forEach(cert => {
        resetCertificate(cert.id);
      });
    };
  });
</script>