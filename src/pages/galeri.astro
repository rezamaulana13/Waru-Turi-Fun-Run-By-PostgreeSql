---
// src/pages/galeri.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
import { db, galleries } from '../db/index.js';
import { desc } from 'drizzle-orm';

// ===== AMBIL DATA GALLERY DARI DATABASE =====
let galleryData: any[] = [];

try {
  const result = await db.select().from(galleries).orderBy(desc(galleries.createdAt));
  galleryData = result;
  console.log('📸 Gallery data loaded:', galleryData.length);
} catch (error) {
  console.error('Error fetching gallery data:', error);
  galleryData = [];
}

// Featured gallery
const featuredGalleries = galleryData.filter((g: any) => g.isFeatured === true);
const featured = featuredGalleries.length > 0 ? featuredGalleries[0] : null;

// Kategori filter - disesuaikan dengan data yang ada
// Kita bisa ambil kategori unik dari database atau pakai static
const categories = [
  { value: 'all', label: 'Semua', icon: 'bi-grid' },
  { value: 'featured', label: '⭐ Unggulan', icon: 'bi-star' },
];

const totalPhotos = galleryData.length;
const totalCategories = categories.length - 1;
const totalFeatured = featuredGalleries.length;

// Konversi ke JSON untuk JavaScript
const galleryDataJSON = JSON.stringify(galleryData);
---

<BaseLayout title="Galeri - Waru Turi Fun Run 2026">
  <Navbar />

  <!-- Hero Section -->
  <section class="relative py-20 sm:py-28 lg:py-36 bg-gradient-to-br from-[#001a4d] via-[#002266] to-[#0033A0] text-white overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-[-50%] right-[-20%] w-[800px] h-[800px] bg-blue-500/10 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-[-40%] left-[-10%] w-[600px] h-[600px] bg-indigo-500/10 rounded-full blur-3xl animate-float-delay"></div>
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="0.03"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
    </div>
    
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-5 py-2.5 rounded-full text-sm font-semibold mb-6 border border-white/20 animate-fade-down">
          <i class="bi bi-images text-[#FFD700]"></i>
          Galeri Foto
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold mb-6 animate-fade-down animation-delay-200">
          Galeri <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#FFD700] to-[#FFA500]">Waru Turi</span> Fun Run
        </h1>
        <p class="text-lg sm:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed animate-fade-down animation-delay-400">
          Dokumentasi momen-momen terbaik dari Waru Turi Fun Run 2026.
        </p>
        
        <!-- Statistik -->
        <div class="flex flex-wrap justify-center gap-4 mt-10 animate-fade-down animation-delay-600">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-8 py-4 border border-white/10 hover:bg-white/20 transition-all duration-300">
            <p class="text-3xl font-bold text-[#FFD700]">{totalPhotos}</p>
            <p class="text-xs text-white/70 uppercase tracking-wider">Total Foto</p>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-8 py-4 border border-white/10 hover:bg-white/20 transition-all duration-300">
            <p class="text-3xl font-bold text-[#20B082]">{totalCategories}</p>
            <p class="text-xs text-white/70 uppercase tracking-wider">Kategori</p>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-8 py-4 border border-white/10 hover:bg-white/20 transition-all duration-300">
            <p class="text-3xl font-bold text-[#FF6B00]">{totalFeatured}</p>
            <p class="text-xs text-white/70 uppercase tracking-wider">Unggulan</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Filter Section -->
  <section class="py-5 bg-white/80 backdrop-blur-md border-b border-gray-100 sticky top-16 z-40 shadow-sm">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap gap-2" id="filterButtons">
          {categories.map(cat => (
            <button 
              class={`filter-btn px-4 py-2.5 rounded-xl text-sm font-medium transition-all duration-300 flex items-center gap-2 ${
                cat.value === 'all' 
                  ? 'bg-[#0033A0] text-white shadow-lg shadow-[#0033A0]/20 scale-105' 
                  : 'bg-gray-100 text-gray-600 hover:bg-gray-200 hover:scale-105'
              }`}
              data-category={cat.value}
              onclick="window.filterGallery('{cat.value}')"
            >
              <i class={`bi ${cat.icon}`}></i>
              {cat.label}
            </button>
          ))}
        </div>
        <div class="text-sm text-gray-500 bg-gray-100 px-4 py-2 rounded-full">
          <i class="bi bi-images me-1"></i>
          <span id="visibleCount">{totalPhotos}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-16 bg-gradient-to-b from-[#F4F7FC] to-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Featured Photo -->
      {featured && (
        <div class="mb-12 animate-fade-up">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl group">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
            <img 
              src={featured.imageUrl} 
              alt={featured.title || 'Featured'}
              class="w-full h-[300px] sm:h-[400px] lg:h-[500px] object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
              onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22800%22 height=%22500%22%3E%3Crect width=%22800%22 height=%22500%22 fill=%22%233b82f6%22/%3E%3Ctext x=%2250%%22 y=%2250%%22 text-anchor=%22middle%22 dy=%22.3em%22 fill=%22%23ffffff%22 font-size=%2224%22%3EImage Not Found%3C/text%3E%3C/svg%3E'"
            />
            <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8 z-20">
              <div class="flex items-center gap-3 mb-3">
                <span class="bg-gradient-to-r from-[#FFD700] to-[#FFA500] text-gray-900 text-xs font-bold px-4 py-1.5 rounded-full flex items-center gap-1 shadow-lg">
                  <i class="bi bi-star-fill"></i>
                  Unggulan
                </span>
              </div>
              <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white">{featured.title || 'Untitled'}</h2>
              <p class="text-white/80 text-sm sm:text-base mt-2 max-w-2xl">{featured.description || ''}</p>
            </div>
            <div class="absolute inset-0 flex items-center justify-center z-10 opacity-0 group-hover:opacity-100 transition-all duration-500">
              <div class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center border-2 border-white/40">
                <i class="bi bi-arrows-fullscreen text-white text-2xl"></i>
              </div>
            </div>
          </div>
        </div>
      )}

      <!-- Gallery Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5" id="galleryGrid">
        {galleryData.length === 0 ? (
          <div class="col-span-full text-center py-20">
            <div class="w-32 h-32 rounded-full bg-gradient-to-br from-blue-50 to-indigo-50 flex items-center justify-center mx-auto mb-6 shadow-inner">
              <i class="bi bi-images text-5xl text-blue-300"></i>
            </div>
            <h3 class="text-2xl font-bold text-gray-700 mb-2">Belum Ada Foto</h3>
            <p class="text-gray-400 max-w-md mx-auto">
              Galeri foto Waru Turi Fun Run 2026 akan segera diisi dengan momen-momen terbaik. 
              Pantau terus halaman ini untuk update terbaru!
            </p>
            <div class="mt-6 flex flex-wrap justify-center gap-3">
              <span class="inline-flex items-center gap-2 px-4 py-2 bg-blue-50 text-blue-600 rounded-full text-sm">
                <i class="bi bi-camera"></i>
                Segera Hadir
              </span>
              <span class="inline-flex items-center gap-2 px-4 py-2 bg-purple-50 text-purple-600 rounded-full text-sm">
                <i class="bi bi-clock-history"></i>
                Dalam Persiapan
              </span>
            </div>
            
            <!-- Preview Placeholder -->
            <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 max-w-4xl mx-auto opacity-50">
              {[1,2,3,4,5,6,7,8].map((item) => (
                <div key={item} class="aspect-square rounded-xl bg-gradient-to-br from-gray-100 to-gray-200 animate-pulse flex items-center justify-center">
                  <i class="bi bi-image text-4xl text-gray-300"></i>
                </div>
              ))}
            </div>
            <p class="text-xs text-gray-400 mt-4">
              <i class="bi bi-arrow-up"></i> Preview placeholder - Foto akan segera ditambahkan
            </p>
          </div>
        ) : (
          galleryData.map((item: any, index: number) => {
            // Tentukan kategori untuk filter (featured atau all)
            const category = item.isFeatured ? 'featured' : 'all';
            
            return (
              <div 
                class="gallery-item group relative rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 cursor-pointer bg-white"
                data-category={category}
                data-index={index}
                onclick="window.openLightbox({index: {index}})"
              >
                <div class="relative overflow-hidden aspect-square">
                  <img 
                    src={item.imageUrl} 
                    alt={item.title || 'Gallery'}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    loading="lazy"
                    onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22%3E%3Crect width=%22200%22 height=%22200%22 fill=%22%23f3f4f6%22/%3E%3Ctext x=%2250%%22 y=%2250%%22 text-anchor=%22middle%22 dy=%22.3em%22 fill=%22%239ca3af%22 font-size=%2214%22%3ENo Image%3C/text%3E%3C/svg%3E'"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  
                  {item.isFeatured && (
                    <div class="absolute top-3 right-3 z-10">
                      <span class="bg-gradient-to-r from-[#FFD700] to-[#FFA500] text-gray-900 text-[10px] font-bold px-2 py-0.5 rounded-full shadow-lg flex items-center gap-1">
                        <i class="bi bi-star-fill text-[8px]"></i>
                        Featured
                      </span>
                    </div>
                  )}
                  
                  <div class="absolute bottom-0 left-0 right-0 p-4 text-white transform translate-y-full group-hover:translate-y-0 transition-transform duration-500 z-10">
                    <h3 class="font-semibold text-sm">{item.title || 'Untitled'}</h3>
                    <p class="text-xs text-white/80 truncate">{item.description || ''}</p>
                  </div>
                  
                  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all duration-500 z-10">
                    <div class="w-14 h-14 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center border-2 border-white/40 group-hover:scale-110 transition-transform">
                      <i class="bi bi-arrows-fullscreen text-white text-xl"></i>
                    </div>
                  </div>
                </div>

                <div class="p-3 bg-white block sm:hidden">
                  <h4 class="font-medium text-gray-800 text-xs truncate">{item.title || 'Untitled'}</h4>
                </div>
              </div>
            );
          })
        )}
      </div>

      <!-- Debug info (hanya untuk development) -->
      {import.meta.env.DEV && galleryData.length > 0 && (
        <div class="mt-8 text-center text-xs text-gray-400">
          <i class="bi bi-database"></i> Total data: {galleryData.length} items
        </div>
      )}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-br from-[#001a4d] via-[#002266] to-[#0033A0] text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-[-50%] right-[-20%] w-[800px] h-[800px] bg-white/10 rounded-full"></div>
    </div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">
          Ikuti Kami di <span class="text-[#FFD700]">Media Sosial</span>
        </h2>
        <p class="text-white/80 text-base mb-8">
          Dapatkan update terbaru dan foto-foto menarik lainnya dari Waru Turi Fun Run.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="#" class="inline-flex items-center gap-2.5 bg-gradient-to-r from-[#E1306C] to-[#C13584] hover:scale-105 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-300 shadow-lg hover:shadow-xl">
            <i class="bi bi-instagram text-xl"></i>
            Instagram
          </a>
          <a href="#" class="inline-flex items-center gap-2.5 bg-gradient-to-r from-[#1DA1F2] to-[#0d95e8] hover:scale-105 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-300 shadow-lg hover:shadow-xl">
            <i class="bi bi-twitter-x text-xl"></i>
            Twitter
          </a>
          <a href="#" class="inline-flex items-center gap-2.5 bg-gradient-to-r from-[#4267B2] to-[#365899] hover:scale-105 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-300 shadow-lg hover:shadow-xl">
            <i class="bi bi-facebook text-xl"></i>
            Facebook
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<!-- Lightbox Modal -->
<div id="lightbox" class="fixed inset-0 z-50 hidden bg-black/95 backdrop-blur-lg">
  <div class="flex items-center justify-center h-full w-full p-4">
    <button 
      onclick="window.closeLightbox()"
      class="absolute top-6 right-6 text-white/70 hover:text-white text-4xl transition-all duration-300 hover:scale-110 hover:rotate-90 z-20"
    >
      <i class="bi bi-x-lg"></i>
    </button>
    
    <button 
      onclick="window.prevImage()"
      class="absolute left-6 text-white/50 hover:text-white text-4xl transition-all duration-300 hover:scale-110 z-20 hidden sm:block"
    >
      <i class="bi bi-chevron-left"></i>
    </button>
    
    <button 
      onclick="window.nextImage()"
      class="absolute right-6 text-white/50 hover:text-white text-4xl transition-all duration-300 hover:scale-110 z-20 hidden sm:block"
    >
      <i class="bi bi-chevron-right"></i>
    </button>
    
    <div class="relative max-w-6xl w-full max-h-[90vh]">
      <div class="relative bg-black/20 rounded-2xl overflow-hidden">
        <img id="lightboxImage" src="" alt="" class="w-full h-auto max-h-[80vh] object-contain rounded-2xl">
        <div id="lightboxInfo" class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/90 via-black/50 to-transparent rounded-b-2xl">
          <h3 id="lightboxTitle" class="text-white font-bold text-xl sm:text-2xl"></h3>
          <p id="lightboxDescription" class="text-white/70 text-sm sm:text-base mt-1"></p>
          <div class="flex items-center gap-4 mt-2">
            <span id="lightboxDate" class="text-white/50 text-xs flex items-center gap-1">
              <i class="bi bi-calendar3"></i>
            </span>
          </div>
        </div>
      </div>
      <div class="absolute top-6 left-6 bg-black/50 backdrop-blur-sm text-white text-xs px-3 py-1.5 rounded-full z-20">
        <span id="lightboxCounter">1 / 1</span>
      </div>
    </div>
  </div>
</div>

<script>
  // ============================================================
  // DATA GALLERY dari database
  // ============================================================
  const galleryItems = JSON.parse('{galleryDataJSON}').map((item: any, index: number) => ({
    id: item.id,
    title: item.title || 'Untitled',
    image: item.imageUrl,
    description: item.description || '',
    isFeatured: item.isFeatured || false,
    date: item.createdAt ? new Date(item.createdAt).toLocaleDateString('id-ID', {
      day: 'numeric',
      month: 'long',
      year: 'numeric'
    }) : '',
    index: index
  }));

  console.log('📸 Gallery items loaded:', galleryItems.length);

  let currentIndex = 0;
  let filteredData = [...galleryItems];

  // ============================================================
  // FILTER GALLERY
  // ============================================================
  window.filterGallery = function(category) {
    console.log('🔍 Filtering:', category);
    
    // Update active button
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.classList.remove('bg-[#0033A0]', 'text-white', 'shadow-lg', 'shadow-[#0033A0]/20', 'scale-105');
      btn.classList.add('bg-gray-100', 'text-gray-600');
    });
    
    const activeBtn = document.querySelector(`.filter-btn[data-category="${category}"]`);
    if (activeBtn) {
      activeBtn.classList.remove('bg-gray-100', 'text-gray-600');
      activeBtn.classList.add('bg-[#0033A0]', 'text-white', 'shadow-lg', 'shadow-[#0033A0]/20', 'scale-105');
    }
    
    // Filter items
    const items = document.querySelectorAll('.gallery-item[data-category]');
    let visibleCount = 0;
    
    items.forEach(item => {
      const itemCategory = item.dataset.category || 'all';
      if (category === 'all' || itemCategory === category) {
        item.style.display = 'block';
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });
    
    // Update filtered data for lightbox
    filteredData = galleryItems.filter(item => 
      category === 'all' || (category === 'featured' && item.isFeatured)
    );
    
    // Update count
    const visibleCountEl = document.getElementById('visibleCount');
    if (visibleCountEl) {
      visibleCountEl.textContent = visibleCount;
    }
    
    console.log('👁️ Visible count:', visibleCount);
  };

  // ============================================================
  // LIGHTBOX
  // ============================================================
  window.openLightbox = function(data) {
    const index = data.index;
    if (index === undefined || index < 0 || index >= filteredData.length) {
      console.warn('Invalid index:', index);
      return;
    }
    
    currentIndex = index;
    updateLightbox(currentIndex);
    document.getElementById('lightbox').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    console.log('🖼️ Lightbox opened:', filteredData[currentIndex]?.title);
  };

  window.closeLightbox = function() {
    document.getElementById('lightbox').classList.add('hidden');
    document.body.style.overflow = 'auto';
  };

  function updateLightbox(index) {
    const item = filteredData[index];
    if (!item) return;
    
    const img = document.getElementById('lightboxImage');
    img.src = item.image;
    img.alt = item.title;
    
    document.getElementById('lightboxTitle').textContent = item.title;
    document.getElementById('lightboxDescription').textContent = item.description || '';
    document.getElementById('lightboxDate').textContent = item.date || '';
    document.getElementById('lightboxCounter').textContent = `${index + 1} / ${filteredData.length}`;
  }

  window.prevImage = function() {
    if (currentIndex > 0) {
      currentIndex--;
      updateLightbox(currentIndex);
    }
  };

  window.nextImage = function() {
    if (currentIndex < filteredData.length - 1) {
      currentIndex++;
      updateLightbox(currentIndex);
    }
  };

  // ============================================================
  // KEYBOARD SHORTCUTS
  // ============================================================
  document.addEventListener('keydown', (e) => {
    const lightbox = document.getElementById('lightbox');
    if (!lightbox.classList.contains('hidden')) {
      if (e.key === 'Escape') window.closeLightbox();
      if (e.key === 'ArrowLeft') window.prevImage();
      if (e.key === 'ArrowRight') window.nextImage();
    }
  });

  // ============================================================
  // CLOSE LIGHTBOX ON CLICK OUTSIDE
  // ============================================================
  document.getElementById('lightbox')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) {
      window.closeLightbox();
    }
  });

  // ============================================================
  // INITIALIZE
  // ============================================================
  document.addEventListener('DOMContentLoaded', function() {
    console.log('🚀 Gallery page initialized');
    console.log('📊 Total items:', galleryItems.length);
    console.log('⭐ Featured items:', galleryItems.filter(item => item.isFeatured).length);
    
    // Set default filter to 'all'
    window.filterGallery('all');
  });
</script>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-30px, -20px) scale(1.1); }
  }
  @keyframes float-delay {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(30px, 20px) scale(1.1); }
  }
  @keyframes fade-down {
    from { opacity: 0; transform: translateY(-30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-float {
    animation: float 8s ease-in-out infinite;
  }
  .animate-float-delay {
    animation: float-delay 10s ease-in-out infinite;
  }
  .animate-fade-down {
    animation: fade-down 0.8s ease-out forwards;
  }
  .animate-fade-up {
    animation: fade-up 0.8s ease-out forwards;
  }
  .animation-delay-200 {
    animation-delay: 0.2s;
  }
  .animation-delay-400 {
    animation-delay: 0.4s;
  }
  .animation-delay-600 {
    animation-delay: 0.6s;
  }
  
  .gallery-item {
    transition: all 0.3s ease;
  }
  
  .gallery-item:hover {
    transform: translateY(-8px);
  }
  
  #lightbox {
    animation: fadeIn 0.3s ease-out;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  #lightboxImage {
    animation: zoomIn 0.3s ease-out;
  }
  
  @keyframes zoomIn {
    from { transform: scale(0.95); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .filter-btn {
      font-size: 0.75rem;
      padding: 6px 12px;
    }
    
    .filter-btn i {
      font-size: 0.8rem;
    }
