---
// src/pages/artikel/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/common/Navbar.astro';
import Footer from '../../components/common/Footer.astro';
import { db, articles } from '../../db';
import { eq, and, ne, desc } from 'drizzle-orm';

const { slug } = Astro.params;

let artikel: any = null;
let relatedArticles: any[] = [];
let error = '';

try {
  const result = await db.select()
    .from(articles)
    .where(and(
      eq(articles.slug, slug || ''),
      eq(articles.status, 'published')
    ));

  if (result.length > 0) {
    artikel = result[0];

    // Tambah view count — best effort, jangan sampai bikin halaman gagal
    // kalau update ini error (misal artikel di-hapus barengan saat diakses).
    try {
      await db.update(articles)
        .set({ viewCount: (artikel.viewCount || 0) + 1 })
        .where(eq(articles.id, artikel.id));
    } catch (e) {
      console.error('Gagal update view count:', e);
    }

    // Artikel terkait: kategori sama, exclude artikel ini sendiri
    if (artikel.category) {
      const related = await db.select()
        .from(articles)
        .where(and(
          eq(articles.category, artikel.category),
          eq(articles.status, 'published'),
          ne(articles.id, artikel.id)
        ))
        .orderBy(desc(articles.createdAt));
      relatedArticles = related.slice(0, 3);
    }
  }
} catch (e: any) {
  error = e.message;
  console.error('Error fetching article detail:', e);
}

// ===== 404 kalau artikel tidak ada / bukan published =====
if (!artikel) {
  Astro.response.status = 404;
}

// ===== HELPER FUNCTIONS =====
function formatDate(dateStr: string | Date): string {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function getReadTime(content: string): number {
  if (!content) return 1;
  const words = content.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

function getCategoryColor(category: string): string {
  const colorMap: Record<string, string> = {
    'Tips & Trik': 'bg-blue-100 text-blue-700',
    'Peralatan': 'bg-purple-100 text-purple-700',
    'Nutrisi': 'bg-green-100 text-green-700',
    'Latihan': 'bg-orange-100 text-orange-700',
    'Kesehatan': 'bg-emerald-100 text-emerald-700',
    'Event': 'bg-red-100 text-red-700',
  };
  return colorMap[category] || 'bg-gray-100 text-gray-700';
}

// Konverter markdown ringan — mendukung persis apa yang dijanjikan di form admin:
// # ## ### heading, **bold**, *italic*, - list, paragraf antar baris kosong.
// Konten di-escape dulu supaya aman dari HTML/script yang ke-input di textarea.
function renderContent(raw: string): string {
  if (!raw) return '';

  const escapeHtml = (str: string) =>
    str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');

  const inlineFormat = (text: string) =>
    text
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>');

  const lines = escapeHtml(raw).split(/\r?\n/);
  let html = '';
  let inList = false;

  for (const rawLine of lines) {
    const line = rawLine.trim();

    if (line === '') {
      if (inList) { html += '</ul>'; inList = false; }
      continue;
    }

    const headingMatch = line.match(/^(#{1,3})\s+(.*)$/);
    if (headingMatch) {
      if (inList) { html += '</ul>'; inList = false; }
      const level = headingMatch[1].length + 2; // h3–h5 biar proporsional di dalam artikel
      html += `<h${level}>${inlineFormat(headingMatch[2])}</h${level}>`;
      continue;
    }

    if (line.startsWith('- ')) {
      if (!inList) { html += '<ul>'; inList = true; }
      html += `<li>${inlineFormat(line.slice(2))}</li>`;
      continue;
    }

    if (inList) { html += '</ul>'; inList = false; }
    html += `<p>${inlineFormat(line)}</p>`;
  }

  if (inList) html += '</ul>';
  return html;
}

const contentHtml = artikel ? renderContent(artikel.content) : '';
const tags: string[] = (artikel?.tags || []) as string[];
const pageTitle = artikel ? `${artikel.title} - Waru Turi Fun Run 2026` : 'Artikel Tidak Ditemukan';
const pageDescription = artikel
  ? (artikel.metaDescription || artikel.excerpt || '')
  : 'Artikel yang kamu cari tidak ditemukan atau sudah tidak dipublikasikan.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navbar />

  {error && (
    <section class="py-4 bg-red-50 border-b border-red-200">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-red-700 text-sm">
          <i class="bi bi-exclamation-circle-fill mr-1"></i>
          Gagal memuat artikel: {error}
        </p>
      </div>
    </section>
  )}

  {artikel ? (
    <div class="artikel-page">
      <!-- ===== BREADCRUMB + TITLE (berdiri sendiri di paling atas) ===== -->
      <section class="bg-white pt-8 md:pt-12 pb-6 md:pb-8 border-b border-gray-100">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-3xl mx-auto">
            <nav class="text-xs text-gray-400 mb-4 flex items-center gap-2">
              <a href="/" class="hover:text-[#2679ec] transition">Home</a>
              <span>›</span>
              <a href="/artikel" class="hover:text-[#2679ec] transition">Artikel</a>
              <span>›</span>
              <span class="text-gray-500 line-clamp-1">{artikel.title}</span>
            </nav>

            {artikel.category && (
              <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold mb-4 ${getCategoryColor(artikel.category)}`}>
                {artikel.category}
              </span>
            )}

            <h1 class="text-3xl md:text-[2.75rem] font-extrabold text-gray-900 leading-tight tracking-tight">
              {artikel.title}
            </h1>

            {artikel.subtitle && (
              <p class="text-gray-500 text-base md:text-lg mt-4 leading-relaxed">
                {artikel.subtitle}
              </p>
            )}

            <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-gray-500 mt-6 pt-6 border-t border-gray-100">
              <span class="flex items-center gap-1.5">
                <i class="bi bi-person-circle text-gray-400"></i>
                {artikel.authorName || 'Admin'}
              </span>
              <span class="flex items-center gap-1.5">
                <i class="bi bi-calendar3 text-gray-400"></i>
                {formatDate(artikel.createdAt)}
              </span>
              <span class="flex items-center gap-1.5">
                <i class="bi bi-clock text-gray-400"></i>
                {getReadTime(artikel.content)} min read
              </span>
              <span class="flex items-center gap-1.5">
                <i class="bi bi-eye text-gray-400"></i>
                {(artikel.viewCount || 0) + 1} views
              </span>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== FEATURED IMAGE (ukuran asli, tidak dipotong) ===== -->
      {artikel.featuredImage && (
        <section class="bg-white pt-8 md:pt-10">
          <div class="container mx-auto px-4 sm:px-6 lg:px-8">
            <div class="max-w-4xl mx-auto">
              <img
                src={artikel.featuredImage}
                alt={artikel.title}
                class="w-full h-auto rounded-2xl"
              />
            </div>
          </div>
        </section>
      )}

      <!-- ===== CONTENT ===== -->
      <section class="py-10 bg-white">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-3xl mx-auto">
            <article class="artikel-content" set:html={contentHtml} />

            {tags.length > 0 && (
              <div class="flex flex-wrap items-center gap-2 mt-10 pt-6 border-t border-gray-100">
                <i class="bi bi-tags text-gray-400 mr-1"></i>
                {tags.map((tag) => (
                  <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <div class="mt-8">
              <a href="/artikel" class="inline-flex items-center gap-2 text-[#2679ec] font-semibold text-sm hover:gap-3 transition-all">
                <i class="bi bi-arrow-left"></i>
                Kembali ke Semua Artikel
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== RELATED ARTICLES ===== -->
      {relatedArticles.length > 0 && (
        <section class="py-12 bg-[#F7F8FC]">
          <div class="container mx-auto px-4 sm:px-6 lg:px-8">
            <div class="max-w-5xl mx-auto">
              <div class="flex items-center gap-3 mb-6">
                <span class="w-1 h-7 bg-[#2679ec] rounded-full"></span>
                <h2 class="text-xl font-bold text-gray-900">Artikel Terkait</h2>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                {relatedArticles.map((rel) => (
                  <a
                    href={`/artikel/${rel.slug}`}
                    class="group block bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-gray-100 hover:-translate-y-1"
                  >
                    <div class="relative h-36 overflow-hidden">
                      {rel.featuredImage ? (
                        <img
                          src={rel.featuredImage}
                          alt={rel.title}
                          class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                          loading="lazy"
                        />
                      ) : (
                        <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                          <i class="bi bi-image text-3xl text-gray-400"></i>
                        </div>
                      )}
                    </div>
                    <div class="p-4">
                      <h3 class="text-sm font-bold text-gray-900 group-hover:text-[#2679ec] transition-colors line-clamp-2">
                        {rel.title}
                      </h3>
                      <p class="text-xs text-gray-400 mt-2">{formatDate(rel.createdAt)}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- ===== CTA ===== -->
      <section class="py-14 bg-gradient-to-br from-[#001a4d] via-[#002266] to-[#0033A0] text-white">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-2xl mx-auto text-center">
            <h2 class="text-2xl sm:text-3xl font-extrabold mb-3">
              Siap Bergabung di <span class="text-[#FFD700]">Waru Turi</span>?
            </h2>
            <p class="text-white/80 text-sm mb-6">
              Daftar sekarang dan rasakan pengalaman lari yang tak terlupakan!
            </p>
            <a href="/p/ticket-sold.html" class="inline-flex items-center gap-2.5 bg-[#FFD700] hover:bg-[#FFC107] text-gray-900 font-bold px-8 py-3.5 rounded-2xl transition-all duration-300 shadow-xl hover:-translate-y-1">
              <i class="bi bi-ticket-perforated text-lg"></i> Daftar Sekarang
            </a>
          </div>
        </div>
      </section>
    </div>
  ) : (
    <!-- ===== NOT FOUND ===== -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-lg mx-auto text-center">
          <div class="w-28 h-28 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="bi bi-file-earmark-x text-5xl text-gray-400"></i>
          </div>
          <h1 class="text-2xl font-bold text-gray-900 mb-3">Artikel Tidak Ditemukan</h1>
          <p class="text-gray-500 mb-6">
            Artikel yang kamu cari tidak ada, sudah dihapus, atau belum dipublikasikan.
          </p>
          <a href="/artikel" class="inline-flex items-center gap-2 px-6 py-3 bg-[#2679ec] text-white rounded-xl hover:bg-[#1a5fc7] transition">
            <i class="bi bi-arrow-left"></i>
            Kembali ke Artikel
          </a>
        </div>
      </div>
    </section>
  )}

  <Footer />
</BaseLayout>

<style>
  /* Font Open Sans untuk seluruh halaman artikel */
  @import url('https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap');

  .artikel-page {
    font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .artikel-content {
    color: #374151;
    font-size: 17px;
    line-height: 1.85;
  }
  .artikel-content :global(h3) {
    font-size: 22px;
    font-weight: 800;
    color: #111827;
    margin-top: 32px;
    margin-bottom: 12px;
  }
  .artikel-content :global(h4) {
    font-size: 19px;
    font-weight: 700;
    color: #111827;
    margin-top: 24px;
    margin-bottom: 10px;
  }
  .artikel-content :global(h5) {
    font-size: 16px;
    font-weight: 700;
    color: #111827;
    margin-top: 20px;
    margin-bottom: 8px;
  }
  .artikel-content :global(p) {
    margin-bottom: 16px;
  }
  .artikel-content :global(ul) {
    list-style: disc;
    padding-left: 22px;
    margin-bottom: 16px;
  }
  .artikel-content :global(li) {
    margin-bottom: 6px;
  }
  .artikel-content :global(strong) {
    font-weight: 700;
    color: #111827;
  }
</style>