// Data Filosofi
const philosophyItems = [
  {
    id: 'tenun-wikara',
    title: 'Motif Tenun Wikara',
    description:
      'Simbol kejayaan Kediri lintas zaman (masa lalu, sekarang, dan masa depan). Setiap guratan warna pada tenun ini membawa pesan mendalam bagi setiap pemenang:',
    imageUrl:
      'https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEiM_vty0rqUoTkHudVvgtXj6xQ2fp1MET_n2BL0tXdLKN_l4kHuHEufbMI5LbQf7EI_Xb9_1GwyaFwX5oVh23g-GSwCyrrdZFhxHwzjh9oKCysA6JI7rfShN8ViS82S84ovdTW13Zp_EpsGGNyBczATXCxO9CUMg5qyNlY3wypDuRgJOQyRgQCnsb6EfKLX/s515-rw/ASSET%20MEDALI%20-%20KAIN%20TENUN%20WIKARA.png',
    tags: ['Kuning: Makmur', 'Merah: Jaya', 'Putih: Suci', 'Coklat: Adil'],
  },
  {
