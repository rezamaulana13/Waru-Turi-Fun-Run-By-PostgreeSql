---
// src/pages/auth/forgot-password.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Lupa Password - Waru Turi Fun Run">
  <div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-2xl shadow-lg">
      <div>
        <h2 class="text-center text-3xl font-bold text-gray-900">Lupa Password</h2>
        <p class="mt-2 text-center text-sm text-gray-600">
          Masukkan email Anda, kami akan kirim link reset password
        </p>
      </div>

      <form id="forgotForm" class="mt-8 space-y-6">
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
            placeholder="admin@waruturi.com"
          />
        </div>

        <div id="message" class="hidden"></div>

        <button
          type="submit"
          id="submitBtn"
          class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Kirim Link Reset
        </button>

        <div class="text-center">
          <a href="/auth/login" class="text-sm text-primary-600 hover:text-primary-700">
            Kembali ke Login
          </a>
        </div>
      </form>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('forgotForm');
      const submitBtn = document.getElementById('submitBtn');
      const messageDiv = document.getElementById('message');

      if (!form || !submitBtn || !messageDiv) {
        console.error('❌ Elements not found!');
        return;
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Disable button
        submitBtn.disabled = true;
        submitBtn.textContent = 'Mengirim...';
        messageDiv.className = 'hidden';

        const emailInput = document.getElementById('email');
        const email = emailInput?.value || '';

        try {
          const response = await fetch('/api/auth/forgot-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email })
          });

          const data = await response.json();

          messageDiv.className = 'p-4 rounded-lg text-sm';
          
          if (response.ok) {
            messageDiv.className += ' bg-green-50 text-green-700 border border-green-200';
            
            let html = `<p class="font-medium">${data.message || 'Link reset password telah dikirim.'}</p>`;
            
            // Tampilkan link dengan style yang rapi (hanya untuk testing)
            if (data.resetLink) {
              html += `
                <div class="mt-3 p-3 bg-gray-50 rounded-lg border border-gray-200">
                  <p class="text-xs text-gray-500 mb-1">🔗 Link Testing (copy & paste):</p>
                  <a 
                    href="${data.resetLink}" 
                    target="_blank" 
                    class="text-sm text-primary-600 hover:text-primary-700 hover:underline break-all font-mono"
                  >
                    ${data.resetLink}
                  </a>
                  <br>
                  <button 
                    onclick="navigator.clipboard.writeText('${data.resetLink}')"
                    class="mt-2 text-xs bg-gray-200 hover:bg-gray-300 px-3 py-1 rounded transition-colors"
                  >
                    📋 Copy Link
                  </button>
                </div>
              `;
            }
            
            messageDiv.innerHTML = html;
            submitBtn.remove();
          } else {
            messageDiv.className += ' bg-red-50 text-red-700 border border-red-200';
            messageDiv.textContent = data.error || 'Terjadi kesalahan. Silakan coba lagi.';
            submitBtn.disabled = false;
            submitBtn.textContent = 'Kirim Link Reset';
          }
        } catch (error) {
          console.error('Error:', error);
          messageDiv.className = 'p-4 rounded-lg text-sm bg-red-50 text-red-700 border border-red-200';
          messageDiv.textContent = 'Terjadi kesalahan. Silakan coba lagi.';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Kirim Link Reset';
        }
      });
    });
  </script>
</BaseLayout>