---
// src/pages/auth/login.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Login - Waru Turi Fun Run 2027">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-[#001a4d] via-[#002266] to-[#0033A0] p-4 relative overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute top-10 right-10 w-96 h-96 bg-blue-400/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-10 left-10 w-80 h-80 bg-indigo-400/10 rounded-full blur-3xl animate-float-delay"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-500/5 rounded-full blur-3xl"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="80" height="80" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="0.03"%3E%3Cpath d="M50 50v-5h-5v5h-5v5h5v5h5v-5h5v-5h-5zm0-40V5h-5v5h-5v5h5v5h5v-5h5v-5h-5zM10 50v-5H5v5H0v5h5v5h5v-5h5v-5H10zM10 10V5H5v5H0v5h5v5h5v-5h5v-5H10z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-400/20 to-transparent"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-400/20 to-transparent"></div>

    <!-- Main Card -->
    <div class="relative z-10 w-full max-w-5xl bg-white/10 backdrop-blur-2xl rounded-3xl border border-white/10 shadow-2xl overflow-hidden">
      <div class="flex flex-col lg:flex-row">
        
        <!-- Left Side - Branding -->
        <div class="lg:w-5/12 p-8 lg:p-12 bg-gradient-to-br from-blue-600/20 to-indigo-600/20 backdrop-blur-sm relative overflow-hidden">
          <div class="absolute -top-20 -right-20 w-64 h-64 bg-blue-400/10 rounded-full blur-2xl"></div>
          <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-indigo-400/10 rounded-full blur-2xl"></div>
          
          <div class="relative z-10 flex flex-col h-full">
            <div class="mb-8">
              <div class="inline-block p-3 bg-white/10 backdrop-blur-sm rounded-2xl border border-white/10">
                <img 
                  src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEj_7yqZkol2_oh-DOsILVsPCd4wV11OjAalFSlWtVwgX-ryCIq6eL8swt_xsLkmxpEC4FQYEUFr38libsnOhSPimz7DcWGHpA09petmLf_YWdDVKDHSrZlHV2j3aoYNsmQwmLMJCd2-Qfk2IdjRUlk6beTlQbJVb362F3FjKjs2L2nqBke4V_NTeCDBc816/s704/logo%20fun%20run%202026.webp" 
                  alt="Waru Turi Fun Run"
                  class="h-12 mx-auto"
                />
              </div>
            </div>

            <div class="flex-1 flex flex-col justify-center">
              <blockquote class="text-white space-y-4">
                <p class="text-2xl font-light leading-relaxed">
                  "Lari bukan tentang kecepatan,<br />
                  <span class="font-semibold text-white/90">tapi tentang ketekunan</span>"
                </p>
                <footer class="text-blue-300/60 text-sm">
                  — Waru Turi Fun Run 2027
                </footer>
              </blockquote>

              <div class="mt-8 flex items-center gap-8 pt-6 border-t border-white/10">
                <div>
                  <div class="text-2xl font-bold text-white">5K</div>
                  <div class="text-blue-300/60 text-xs uppercase tracking-wider">Jarak</div>
                </div>
                <div class="w-px h-8 bg-white/10"></div>
                <div>
                  <div class="text-2xl font-bold text-white">1000+</div>
                  <div class="text-blue-300/60 text-xs uppercase tracking-wider">Peserta</div>
                </div>
                <div class="w-px h-8 bg-white/10"></div>
                <div>
                  <div class="text-2xl font-bold text-white">2027</div>
                  <div class="text-blue-300/60 text-xs uppercase tracking-wider">Tahun</div>
                </div>
              </div>
            </div>

            <div class="mt-8 pt-6 border-t border-white/10">
              <p class="text-blue-300/40 text-xs text-center">
                &copy; 2027 Waru Turi Fun Run
              </p>
            </div>
          </div>
        </div>

        <!-- Right Side - Form -->
        <div class="lg:w-7/12 p-8 lg:p-12 bg-white/95 backdrop-blur-sm">
          <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Selamat Datang</h1>
            <p class="text-sm text-gray-500 mt-2">
              Masuk ke akun Anda untuk melanjutkan
            </p>
          </div>

          <!-- Alert -->
          <div id="alert" class="hidden rounded-xl p-4 mb-6 animate-fade-in">
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 mt-0.5">
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <p id="alert-message" class="text-sm font-medium"></p>
            </div>
          </div>

          <!-- Form -->
          <form id="login-form" class="space-y-5">
            <!-- Email -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">
                Alamat Email
              </label>
              <div class="relative group">
                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-600 transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  value="admin@waruturi.com"
                  class="w-full pl-12 pr-4 py-3.5 bg-gray-50 border-2 border-gray-200 rounded-xl focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all outline-none text-gray-900 placeholder:text-gray-400 text-sm"
                  placeholder="nama@email.com"
                  autocomplete="email"
                />
              </div>
            </div>

            <!-- Password -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label class="block text-sm font-medium text-gray-700">
                  Kata Sandi
                </label>
                <a href="/auth/forgot-password" class="text-xs text-blue-600 hover:text-blue-700 font-medium transition hover:underline">
                  Lupa sandi?
                </a>
              </div>
              <div class="relative group">
                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-600 transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                </div>
                <input
                  id="password"
                  name="password"
                  type="password"
                  required
                  value="admin123"
                  class="w-full pl-12 pr-12 py-3.5 bg-gray-50 border-2 border-gray-200 rounded-xl focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all outline-none text-gray-900 placeholder:text-gray-400 text-sm"
                  placeholder="••••••••"
                  autocomplete="current-password"
                />
                <button
                  type="button"
                  id="togglePassword"
                  class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors"
                >
                  <svg class="w-5 h-5" id="passwordIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                </button>
              </div>
            </div>

            <!-- Remember Me -->
            <div class="flex items-center justify-between">
              <label class="flex items-center gap-2.5 text-sm text-gray-600 cursor-pointer group">
                <div class="relative">
                  <input
                    type="checkbox"
                    name="remember"
                    class="w-4 h-4 text-blue-600 border-2 border-gray-300 rounded focus:ring-4 focus:ring-blue-100 focus:ring-offset-0 transition-all"
                  />
                </div>
                <span class="group-hover:text-gray-800 transition-colors">Ingat saya</span>
              </label>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              id="submit-button"
              class="w-full py-3.5 px-4 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white text-sm font-semibold rounded-xl transition-all duration-300 disabled:opacity-70 disabled:cursor-not-allowed shadow-lg shadow-blue-100 hover:shadow-xl hover:shadow-blue-200 hover:-translate-y-0.5 active:translate-y-0"
            >
              <span id="submit-text" class="flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                </svg>
                Masuk
              </span>
            </button>
          </form>

          <!-- Register Link -->
          <div class="mt-6 text-center">
            <p class="text-sm text-gray-500">
              Belum punya akun? 
              <a href="/auth/register" class="text-blue-600 hover:text-blue-700 font-semibold transition hover:underline">
                Daftar sekarang
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    @keyframes float {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(-30px, -20px) scale(1.1); }
    }
    @keyframes float-delay {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(30px, 20px) scale(1.1); }
    }
    @keyframes fade-in {
      from { opacity: 0; transform: translateY(-10px) scale(0.95); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
    .animate-float {
      animation: float 8s ease-in-out infinite;
    }
    .animate-float-delay {
      animation: float-delay 10s ease-in-out infinite;
    }
    .animate-fade-in {
      animation: fade-in 0.3s ease-out forwards;
    }
  </style>

  <script>
    // ============================================================
    // DOM ELEMENTS
    // ============================================================
    const form = document.getElementById('login-form');
    const submitButton = document.getElementById('submit-button');
    const submitText = document.getElementById('submit-text');
    const alert = document.getElementById('alert');
    const alertMessage = document.getElementById('alert-message');

    // ============================================================
    // TOGGLE PASSWORD
    // ============================================================
    const togglePassword = document.getElementById('togglePassword');
    const passwordInput = document.getElementById('password');
    const passwordIcon = document.getElementById('passwordIcon');

    togglePassword?.addEventListener('click', () => {
      const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
      passwordInput.setAttribute('type', type);
      if (type === 'password') {
        passwordIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />';
      } else {
        passwordIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />';
      }
    });

    // ============================================================
    // CHECK REGISTERED
    // ============================================================
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('registered') === 'true') {
      showAlert('success', '🎉 Registrasi berhasil! Silakan masuk.');
    }

    // ============================================================
    // HANDLE LOGIN
    // ============================================================
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      alert.classList.add('hidden');
      submitButton.disabled = true;
      submitText.innerHTML = `
        <svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Memproses...
      `;

      const formData = new FormData(form);
      const data = {
        email: formData.get('email'),
        password: formData.get('password'),
        remember: formData.get('remember') === 'on',
      };

      try {
        console.log('📤 Sending login request...');
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await response.json();
        console.log('📥 Response:', result);

        if (!response.ok || !result.success) {
          showAlert('error', result.message || 'Login gagal');
          resetButton();
          return;
        }

        // Login sukses
        console.log('✅ Login success!');
        console.log('👤 User:', result.data?.user);
        console.log('🔀 Redirect to:', result.data?.redirectUrl);

        // Simpan ke localStorage
        if (result.data?.token) {
          localStorage.setItem('token', result.data.token);
        }
        if (result.data?.user) {
          localStorage.setItem('user', JSON.stringify(result.data.user));
        }

        showAlert('success', '✅ Login berhasil! Mengalihkan...');

        // ===== REDIRECT MANUAL =====
        const redirectUrl = result.data?.redirectUrl || '/';
        console.log('🔀 Redirecting to:', redirectUrl);
        
        // Gunakan window.location.replace agar tidak bisa back
        setTimeout(() => {
          window.location.replace(redirectUrl);
        }, 500);

      } catch (error) {
        console.error('❌ Login error:', error);
        showAlert('error', 'Terjadi kesalahan. Silakan coba lagi.');
        resetButton();
      }
    });

    // ===== RESET BUTTON =====
    function resetButton() {
      submitButton.disabled = false;
      submitText.innerHTML = `
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
        </svg>
        Masuk
      `;
    }

    // ===== SHOW ALERT =====
    function showAlert(type, message) {
      alert.classList.remove('hidden', 'bg-red-50', 'bg-green-50', 'border-red-200', 'border-green-200');
      
      if (type === 'error') {
        alert.classList.add('bg-red-50', 'border-2', 'border-red-200');
        alertMessage.className = 'text-sm font-medium text-red-600';
      } else {
        alert.classList.add('bg-green-50', 'border-2', 'border-green-200');
        alertMessage.className = 'text-sm font-medium text-green-600';
      }
      
      alertMessage.textContent = message;
      
      clearTimeout(window.alertTimeout);
      window.alertTimeout = setTimeout(() => {
        alert.classList.add('hidden');
      }, 5000);
    }

    // ============================================================
// CEK SUDAH LOGIN - VERIFY DULU
// ============================================================
const token = localStorage.getItem('token');
if (token) {
  // Biarkan AdminLayout yang handle redirect
  // Tapi cek dulu valid atau tidak
  console.log('🔑 Token exists, but verifying...');
  
  // Hapus token kalau invalid (AdminLayout akan redirect ke login)
  // Token yang expired bakal di-reject oleh AdminLayout
  // Jadi biarkan saja, AdminLayout yang handle
}
  </script>
</BaseLayout>