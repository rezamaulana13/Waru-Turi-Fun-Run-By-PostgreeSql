---
// src/pages/kontak.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';

// Data kontak
const contactInfo = {
  address: 'Bendungan Waru Turi, Kabupaten Kediri, Jawa Timur',
  phone: '+62 815-5257-733',
  email: 'officialwaruturirun@gmail.com',
  instagram: 'radarkedirievent',
  facebook: 'offprint.radarkediri.7',
  maps: 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d31605.51368422654!2d112.0307!3d-7.8496!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e7854e7a4a5c7c9%3A0x8f3e8a1f3c9a4b2d!2sWaru%20Turi!5e0!3m2!1sid!2sid!4v1700000000000',
};

const workingHours = [
  { day: 'Senin - Jumat', hours: '08:00 - 17:00 WIB' },
  { day: 'Sabtu', hours: '08:00 - 14:00 WIB' },
  { day: 'Minggu', hours: 'Tutup' },
];

const faqs = [
  {
    question: 'Bagaimana cara mendaftar Waru Turi Fun Run 2026?',
    answer: 'Anda dapat mendaftar melalui halaman pendaftaran di website kami atau datang langsung ke sekretariat panitia di Bendungan Waru Turi.'
  },
  {
    question: 'Berapa biaya pendaftaran?',
    answer: 'Biaya pendaftaran bervariasi tergantung kategori: 5K Fun Run Rp 150.000, 10K Fun Run Rp 200.000, dan 5K Pelajar Rp 99.000.'
  },
  {
    question: 'Apakah ada batas usia untuk peserta?',
    answer: 'Ya, minimal usia 12 tahun untuk kategori 5K dan 15 tahun untuk kategori 10K. Untuk kategori pelajar, minimal usia 12-18 tahun.'
  },
  {
    question: 'Apa yang didapatkan peserta setelah mendaftar?',
    answer: 'Peserta mendapatkan jersey eksklusif, nomor dada, medali finisher (jika finish), sertifikat elektronik, dan berbagai fasilitas lainnya.'
  },
];
---

<BaseLayout title="Kontak - Waru Turi Fun Run 2026" description="Hubungi panitia Waru Turi Fun Run 2026 untuk informasi pendaftaran, kerjasama, atau pertanyaan lainnya.">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section class="kontak-hero">
    <div class="kontak-overlay"></div>
    <div class="kontak-hero-content">
      <h2 class="kontak-title">Hubungi Kami</h2>
      <p class="kontak-subtitle">
        Ada pertanyaan tentang Waru Turi Fun Run 2026? Tim kami siap membantu Anda.
        Hubungi kami melalui form berikut atau kunjungi sekretariat kami.
      </p>
      <div class="kontak-breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <span>Kontak</span>
      </div>
    </div>
  </section>

  <!-- ===== CONTACT SECTION ===== -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Contact Info Cards -->
          <div class="lg:col-span-1 space-y-4">
            <div class="bg-[#F7F8FC] rounded-2xl p-6 border border-gray-100 hover:border-[#2679ec]/20 hover:shadow-lg transition-all">
              <div class="w-12 h-12 bg-[#2679ec]/10 rounded-xl flex items-center justify-center mb-4">
                <i class="bi bi-geo-alt text-2xl text-[#2679ec]"></i>
              </div>
              <h4 class="font-bold text-gray-900 text-sm mb-2">Alamat</h4>
              <p class="text-gray-600 text-sm leading-relaxed">{contactInfo.address}</p>
            </div>

            <div class="bg-[#F7F8FC] rounded-2xl p-6 border border-gray-100 hover:border-[#2679ec]/20 hover:shadow-lg transition-all">
              <div class="w-12 h-12 bg-[#2679ec]/10 rounded-xl flex items-center justify-center mb-4">
                <i class="bi bi-telephone text-2xl text-[#2679ec]"></i>
              </div>
              <h4 class="font-bold text-gray-900 text-sm mb-2">Telepon</h4>
              <a href={`tel:${contactInfo.phone}`} class="text-gray-600 text-sm hover:text-[#2679ec] transition-colors">
                {contactInfo.phone}
              </a>
            </div>

            <div class="bg-[#F7F8FC] rounded-2xl p-6 border border-gray-100 hover:border-[#2679ec]/20 hover:shadow-lg transition-all">
              <div class="w-12 h-12 bg-[#2679ec]/10 rounded-xl flex items-center justify-center mb-4">
                <i class="bi bi-envelope text-2xl text-[#2679ec]"></i>
              </div>
              <h4 class="font-bold text-gray-900 text-sm mb-2">Email</h4>
              <a href={`mailto:${contactInfo.email}`} class="text-gray-600 text-sm hover:text-[#2679ec] transition-colors break-all">
                {contactInfo.email}
              </a>
            </div>

            <div class="bg-[#F7F8FC] rounded-2xl p-6 border border-gray-100 hover:border-[#2679ec]/20 hover:shadow-lg transition-all">
              <div class="w-12 h-12 bg-[#2679ec]/10 rounded-xl flex items-center justify-center mb-4">
                <i class="bi bi-clock text-2xl text-[#2679ec]"></i>
              </div>
              <h4 class="font-bold text-gray-900 text-sm mb-2">Jam Operasional</h4>
              {workingHours.map((item) => (
                <div key={item.day} class="flex justify-between text-sm text-gray-600 py-0.5">
                  <span>{item.day}</span>
                  <span class={item.hours === 'Tutup' ? 'text-red-500 font-medium' : ''}>{item.hours}</span>
                </div>
              ))}
            </div>

            <!-- Social Media -->
            <div class="bg-[#F7F8FC] rounded-2xl p-6 border border-gray-100 hover:border-[#2679ec]/20 hover:shadow-lg transition-all">
              <h4 class="font-bold text-gray-900 text-sm mb-4">Ikuti Kami</h4>
              <div class="flex gap-3">
                <a 
                  href={`https://instagram.com/${contactInfo.instagram}`} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 rounded-xl flex items-center justify-center text-white hover:scale-110 transition-transform shadow-md"
                >
                  <i class="bi bi-instagram text-xl"></i>
                </a>
                <a 
                  href={`https://facebook.com/${contactInfo.facebook}`} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="w-12 h-12 bg-[#1877F2] rounded-xl flex items-center justify-center text-white hover:scale-110 transition-transform shadow-md"
                >
                  <i class="bi bi-facebook text-xl"></i>
                </a>
                <a 
                  href={`https://wa.me/${contactInfo.phone.replace(/\s/g, '')}`} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="w-12 h-12 bg-[#25D366] rounded-xl flex items-center justify-center text-white hover:scale-110 transition-transform shadow-md"
                >
                  <i class="bi bi-whatsapp text-xl"></i>
                </a>
                <a 
                  href={`mailto:${contactInfo.email}`}
                  class="w-12 h-12 bg-[#EA4335] rounded-xl flex items-center justify-center text-white hover:scale-110 transition-transform shadow-md"
                >
                  <i class="bi bi-envelope text-xl"></i>
                </a>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="lg:col-span-2">
            <div class="bg-white rounded-3xl shadow-xl border border-gray-100 p-8 md:p-10">
              <div class="mb-8">
                <h3 class="text-2xl font-bold text-gray-900">Kirim Pesan</h3>
                <p class="text-gray-500 text-sm mt-2">Isi form di bawah ini dan tim kami akan menghubungi Anda segera.</p>
              </div>

              <form id="contact-form" class="space-y-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2" for="name">
                      Nama Lengkap <span class="text-red-500">*</span>
                    </label>
                    <input 
                      type="text" 
                      id="name" 
                      name="name" 
                      required
                      placeholder="Masukkan nama Anda"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all text-sm"
                    />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2" for="email">
                      Email <span class="text-red-500">*</span>
                    </label>
                    <input 
                      type="email" 
                      id="email" 
                      name="email" 
                      required
                      placeholder="Masukkan email Anda"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all text-sm"
                    />
                  </div>
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2" for="subject">
                    Subjek <span class="text-red-500">*</span>
                  </label>
                  <input 
                    type="text" 
                    id="subject" 
                    name="subject" 
                    required
                    placeholder="Masukkan subjek pesan"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all text-sm"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2" for="message">
                    Pesan <span class="text-red-500">*</span>
                  </label>
                  <textarea 
                    id="message" 
                    name="message" 
                    required
                    rows="5"
                    placeholder="Tulis pesan Anda di sini..."
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all text-sm resize-none"
                  ></textarea>
                </div>

                <div class="flex items-start gap-3">
                  <input 
                    type="checkbox" 
                    id="agree" 
                    name="agree" 
                    required
                    class="mt-1 w-4 h-4 rounded border-gray-300 text-[#2679ec] focus:ring-[#2679ec]/20"
                  />
                  <label for="agree" class="text-sm text-gray-600">
                    Saya setuju dengan kebijakan privasi dan menyetujui data saya diolah untuk keperluan komunikasi.
                  </label>
                </div>

                <button 
                  type="submit" 
                  class="w-full md:w-auto px-10 py-3.5 bg-[#2679ec] hover:bg-[#1a5fc7] text-white font-semibold rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1 flex items-center justify-center gap-2"
                >
                  <i class="bi bi-send"></i>
                  Kirim Pesan
                </button>

                <!-- Form feedback -->
                <div id="form-success" class="hidden p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm">
                  <i class="bi bi-check-circle-fill mr-2"></i>
                  Pesan Anda berhasil dikirim! Kami akan menghubungi Anda segera.
                </div>
                <div id="form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
                  <i class="bi bi-exclamation-circle-fill mr-2"></i>
                  Terjadi kesalahan. Silakan coba lagi atau hubungi kami melalui WhatsApp.
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MAP SECTION ===== -->
  <section class="py-16 bg-[#F7F8FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-10">
          <span class="text-[#2679ec] font-semibold text-sm uppercase tracking-wider">Lokasi</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-3">Temukan Kami</h2>
          <p class="text-gray-500 text-base max-w-2xl mx-auto">Kunjungi sekretariat kami di Bendungan Waru Turi, Kediri.</p>
        </div>

        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
          <div class="relative w-full h-[400px] md:h-[450px]">
            <iframe 
              src={contactInfo.maps}
              class="w-full h-full"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Lokasi Bendungan Waru Turi"
            ></iframe>
            <div class="absolute bottom-4 left-4 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-3 shadow-lg border border-white">
              <div class="flex items-center gap-2 text-sm">
                <i class="bi bi-geo-alt text-[#2679ec] text-lg"></i>
                <span class="font-medium text-gray-700">Bendungan Waru Turi</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ SECTION ===== -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <span class="text-[#2679ec] font-semibold text-sm uppercase tracking-wider">FAQ</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-3">Pertanyaan yang Sering Diajukan</h2>
          <p class="text-gray-500 text-base max-w-2xl mx-auto">Temukan jawaban untuk pertanyaan-pertanyaan umum seputar Waru Turi Fun Run 2026.</p>
        </div>

        <div class="space-y-4">
          {faqs.map((faq, index) => (
            <div key={index} class="faq-item bg-[#F7F8FC] rounded-2xl border border-gray-100 hover:border-[#2679ec]/20 transition-all overflow-hidden">
              <button class="faq-toggle w-full px-6 py-4 flex items-center justify-between text-left hover:bg-white/50 transition-colors">
                <span class="font-semibold text-gray-900 text-sm md:text-base">{faq.question}</span>
                <span class="flex-shrink-0 ml-4 w-8 h-8 bg-[#2679ec]/10 rounded-full flex items-center justify-center text-[#2679ec] transition-transform duration-300">
                  <i class="bi bi-chevron-down"></i>
                </span>
              </button>
              <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300">
                <div class="px-6 pb-4 text-gray-600 text-sm leading-relaxed border-t border-gray-100 pt-4">
                  {faq.answer}
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-8">
          <p class="text-gray-500 text-sm">Masih ada pertanyaan? <a href="#" onclick="document.getElementById('contact-form').scrollIntoView({behavior: 'smooth'}); return false;" class="text-[#2679ec] font-semibold hover:underline">Hubungi kami</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="py-16 bg-gradient-to-br from-[#001a4d] via-[#002266] to-[#0033A0] text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">
          Siap Bergabung di <span class="text-[#FFD700]">Waru Turi</span>?
        </h2>
        <p class="text-white/80 text-base mb-8 leading-relaxed">
          Daftar sekarang dan jadilah bagian dari sejarah Waru Turi Fun Run 2026. 
          Kami siap membantu Anda di setiap langkah!
        </p>
        <a href="/p/ticket-sold.html" class="inline-flex items-center gap-2.5 bg-[#FFD700] hover:bg-[#FFC107] text-gray-900 font-bold px-10 py-4 rounded-2xl transition-all duration-300 shadow-2xl hover:shadow-3xl hover:-translate-y-1">
          <i class="bi bi-ticket-perforated text-lg"></i> Daftar Sekarang
        </a>
        <p class="text-white/40 text-xs mt-4">
          <i class="bi bi-clock-history mr-1"></i> Kuota terbatas, segera daftar!
        </p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .kontak-hero {
    position: relative;
    width: 100%;
    min-height: 420px;
    background: linear-gradient(135deg, rgba(11, 124, 255, 0.85), rgba(0, 182, 219, 0.85)),
      url('https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhLgtAHbzolMJkhEg_42wG0oVMGz24ls7ax9m3XUknvO8pkQA6NK93M3Opv9zTOczYPgXH1f92LEGnrmKRFA5JoG9W7Yj8MwGXouQ64OBF6A4IrjBcO_g_0576t4CPIlxVYzu3kLEvdI6tyP8D44Je7U7sRmo_aYGXc_Pgq5R0y9oJoRXtA2GjOrW-XxTiJ/s1280/header.jpg') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }
  .kontak-overlay {
    position: absolute;
    inset: 0;
    background: transparent;
    z-index: 1;
  }
  .kontak-hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    padding: 0 20px;
  }
  .kontak-title {
    font-size: 52px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 18px;
    letter-spacing: 1px;
  }
  .kontak-subtitle {
    font-size: 17px;
    line-height: 1.7;
    color: #e0f7fa;
    margin-bottom: 28px;
  }
  .kontak-breadcrumb {
    font-size: 14px;
    color: #e0f7fa;
  }
  .kontak-breadcrumb a {
    color: #fff;
    font-weight: 700;
    text-decoration: none;
  }
  .kontak-breadcrumb a:hover {
    color: #FFD700;
  }
  .kontak-breadcrumb span {
    margin: 0 6px;
  }

  @media (max-width: 768px) {
    .kontak-hero {
      min-height: 340px;
      background-attachment: scroll;
    }
    .kontak-title {
      font-size: 36px;
    }
    .kontak-subtitle {
      font-size: 15px;
    }
  }

  /* ===== CONTACT FORM ===== */
  #contact-form input:focus,
  #contact-form textarea:focus {
    outline: none;
  }

  #contact-form input:invalid:not(:placeholder-shown),
  #contact-form textarea:invalid:not(:placeholder-shown) {
    border-color: #ef4444;
  }

  #contact-form input:valid:not(:placeholder-shown),
  #contact-form textarea:valid:not(:placeholder-shown) {
    border-color: #22c55e;
  }

  /* ===== FAQ ===== */
  .faq-item.active .faq-toggle span:last-child {
    transform: rotate(180deg);
  }

  .faq-item.active .faq-answer {
    max-height: 500px;
  }

  .faq-item.active {
    border-color: #2679ec;
    box-shadow: 0 4px 20px rgba(38, 121, 236, 0.08);
  }

  /* ===== MAP ===== */
  .map-container iframe {
    filter: none;
  }

  /* ===== ANIMASI ===== */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .faq-item {
    animation: fadeInUp 0.5s ease-out forwards;
  }
  .faq-item:nth-child(1) { animation-delay: 0.05s; }
  .faq-item:nth-child(2) { animation-delay: 0.1s; }
  .faq-item:nth-child(3) { animation-delay: 0.15s; }
  .faq-item:nth-child(4) { animation-delay: 0.2s; }
</style>

<!-- ===== FORM HANDLER ===== -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contact-form');
    const successDiv = document.getElementById('form-success');
    const errorDiv = document.getElementById('form-error');

    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();

        // Sembunyikan feedback sebelumnya
        successDiv.classList.add('hidden');
        errorDiv.classList.add('hidden');

        // Ambil data form
        const formData = new FormData(form);
        const data = {
          name: formData.get('name'),
          email: formData.get('email'),
          subject: formData.get('subject'),
          message: formData.get('message'),
        };

        // Validasi sederhana
        if (!data.name || !data.email || !data.subject || !data.message) {
          errorDiv.classList.remove('hidden');
          errorDiv.textContent = 'Mohon isi semua field yang wajib diisi (*).';
          return;
        }

        // Simulasi pengiriman (ganti dengan API call sebenarnya)
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<span class="animate-spin inline-block w-5 h-5 border-2 border-white/30 border-t-white rounded-full mr-2"></span> Mengirim...';
        submitBtn.disabled = true;

        setTimeout(() => {
          // Success (simulasi)
          successDiv.classList.remove('hidden');
          successDiv.innerHTML = '<i class="bi bi-check-circle-fill mr-2"></i> Pesan Anda berhasil dikirim! Kami akan menghubungi Anda segera.';
          form.reset();
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;

          // Scroll ke success message
          successDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });

          // Sembunyikan setelah 5 detik
          setTimeout(() => {
            successDiv.classList.add('hidden');
          }, 5000);
        }, 2000);
      });
    }

    // ===== FAQ TOGGLE =====
    const faqToggles = document.querySelectorAll('.faq-toggle');
    faqToggles.forEach(toggle => {
      toggle.addEventListener('click', function() {
        const item = this.closest('.faq-item');
        const isActive = item.classList.contains('active');

        // Tutup semua FAQ lain
        document.querySelectorAll('.faq-item.active').forEach(el => {
          if (el !== item) {
            el.classList.remove('active');
          }
        });

        // Toggle yang diklik
        if (isActive) {
          item.classList.remove('active');
        } else {
          item.classList.add('active');
        }
      });
    });

    // ===== SMOOTH SCROLL =====
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href === '#') return;
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });
  });
</script>