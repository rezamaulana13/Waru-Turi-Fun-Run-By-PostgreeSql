---
// src/pages/kontak.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';

// Data kontak
const contactInfo = {
  address: 'Bendungan Waru Turi, Kabupaten Kediri, Jawa Timur',
  phone: '+62 815-5257-733',
  email: 'officialwaruturirun@gmail.com',
  instagram: 'radarkedirievent',
  facebook: 'offprint.radarkediri.7',
  maps: 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d31605.51368422654!2d112.0307!3d-7.8496!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e7854e7a4a5c7c9%3A0x8f3e8a1f3c9a4b2d!2sWaru%20Turi!5e0!3m2!1sid!2sid!4v1700000000000',
};

const workingHours = [
  { day: 'Senin - Jumat', hours: '08:00 - 17:00 WIB' },
  { day: 'Sabtu', hours: '08:00 - 14:00 WIB' },
  { day: 'Minggu', hours: 'Tutup' },
];

const faqs = [
  {
    question: 'Bagaimana cara mendaftar Waru Turi Fun Run 2026?',
    answer: 'Anda dapat mendaftar melalui halaman pendaftaran di website kami dengan mengklik tombol "Daftar Sekarang" atau datang langsung ke sekretariat panitia di Bendungan Waru Turi. Pendaftaran online akan dibuka mulai 1 Januari 2026.'
  },
  {
    question: 'Berapa biaya pendaftaran?',
    answer: 'Biaya pendaftaran bervariasi tergantung kategori: 5K Fun Run (Umum) Rp 150.000, 10K Fun Run (Umum) Rp 200.000, dan 5K Pelajar (SMP/SMA) Rp 99.000. Harga sudah termasuk jersey, nomor dada, medali finisher, dan fasilitas lainnya.'
  },
  {
    question: 'Apakah ada batas usia untuk peserta?',
    answer: 'Ya, ada batas usia untuk setiap kategori: Minimal 12 tahun untuk kategori 5K Fun Run, Minimal 15 tahun untuk kategori 10K Fun Run, dan Khusus 12-18 tahun untuk kategori Pelajar. Peserta di bawah 17 tahun wajib didampingi orang tua/wali saat registrasi.'
  },
  {
    question: 'Apa saja yang didapatkan peserta setelah mendaftar?',
    answer: 'Peserta mendapatkan paket lengkap yang terdiri dari: Jersey eksklusif Waru Turi Fun Run 2026, Nomor dada bernomor, Medali finisher (khusus yang menyelesaikan rute), Sertifikat elektronik, Water station di setiap 2.5 km, Medical support di sepanjang rute, Refreshment di garis finish, dan Dokumentasi resmi acara.'
  },
  {
    question: 'Bagaimana cara pembayaran pendaftaran?',
    answer: 'Pembayaran dapat dilakukan melalui transfer bank ke rekening panitia: BNI (00987654321 a.n Panitia Waru Turi Run), Mandiri (1234567890 a.n Panitia Waru Turi Run), atau BCA (0987654321 a.n Panitia Waru Turi Run). Bukti transfer wajib diunggah melalui form pendaftaran.'
  },
  {
    question: 'Apakah ada refund jika saya batal ikut?',
    answer: 'Tidak ada refund untuk pendaftaran yang sudah dibayar. Namun, Anda dapat mentransfer tiket ke peserta lain maksimal H-7 sebelum acara dengan menghubungi panitia melalui email atau WhatsApp. Biaya administrasi transfer sebesar Rp 25.000 akan dikenakan.'
  },
  {
    question: 'Kapan dan di mana acara Waru Turi Fun Run 2026 dilaksanakan?',
    answer: 'Acara akan dilaksanakan pada Minggu, 15 Maret 2026, mulai pukul 05.30 WIB hingga selesai. Lokasi start dan finish di Bendungan Waru Turi, Kabupaten Kediri, Jawa Timur. Peserta diharapkan hadir 1 jam sebelum start untuk registrasi ulang dan pemanasan.'
  },
  {
    question: 'Apa yang harus dibawa pada hari perlombaan?',
    answer: 'Pada hari perlombaan, peserta wajib membawa: Kartu identitas (KTP/SIM/Kartu Pelajar) untuk verifikasi, Nomor dada yang sudah ditempel di depan jersey, Jersey Waru Turi Fun Run 2026, Sepatu lari yang nyaman, Air minum pribadi (disarankan), dan Perlengkapan pribadi lainnya (handuk, sandal cadangan, dll).'
  },
  {
    question: 'Apakah ada batasan waktu untuk menyelesaikan rute?',
    answer: 'Ya, ada batas waktu (cut off time) untuk setiap kategori: 5K Fun Run: 1 Jam 30 Menit (batas waktu finish pukul 08.00 WIB), 10K Fun Run: 2 Jam 30 Menit (batas waktu finish pukul 09.00 WIB). Peserta yang tidak mencapai finish hingga batas waktu dinyatakan DNF (Did Not Finish).'
  },
  {
    question: 'Bagaimana cara menghubungi panitia jika ada pertanyaan?',
    answer: 'Anda dapat menghubungi panitia melalui: Email: officialwaruturirun@gmail.com, WhatsApp: +62 815-5257-733, atau datang langsung ke sekretariat panitia di Bendungan Waru Turi. Kami siap membantu Anda Senin-Jumat pukul 08.00-17.00 WIB.'
  },
];
---

<BaseLayout title="Kontak - Waru Turi Fun Run 2026" description="Hubungi panitia Waru Turi Fun Run 2026 untuk informasi pendaftaran, kerjasama, atau pertanyaan lainnya.">
  <Navbar />

  <!-- ===== HERO ===== -->
  <section class="kontak-hero">
    <div class="kontak-overlay"></div>
    <div class="kontak-hero-content">
      <h1 class="kontak-title">Hubungi Kami</h1>
      <p class="kontak-subtitle">
        Ada pertanyaan tentang Waru Turi Fun Run 2026? Tim kami siap membantu Anda.
        Hubungi kami melalui form berikut atau kunjungi sekretariat kami.
      </p>
      <div class="kontak-breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <span>Kontak</span>
      </div>
    </div>
  </section>

  <!-- ===== CONTACT SECTION ===== -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Info Cards -->
        <div class="contact-info">
          <div class="contact-card">
            <div class="contact-icon">
              <i class="bi bi-geo-alt"></i>
            </div>
            <h4>Alamat</h4>
            <p>{contactInfo.address}</p>
          </div>

          <div class="contact-card">
            <div class="contact-icon">
              <i class="bi bi-telephone"></i>
            </div>
            <h4>Telepon</h4>
            <a href={`tel:${contactInfo.phone}`}>{contactInfo.phone}</a>
          </div>

          <div class="contact-card">
            <div class="contact-icon">
              <i class="bi bi-envelope"></i>
            </div>
            <h4>Email</h4>
            <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
          </div>

          <div class="contact-card">
            <div class="contact-icon">
              <i class="bi bi-clock"></i>
            </div>
            <h4>Jam Operasional</h4>
            {workingHours.map((item) => (
              <div key={item.day} class="hours-row">
                <span>{item.day}</span>
                <span class={item.hours === 'Tutup' ? 'hours-closed' : ''}>{item.hours}</span>
              </div>
            ))}
          </div>

          <!-- Social Media -->
          <div class="contact-card social-card">
            <h4>Ikuti Kami</h4>
            <div class="social-icons">
              <a 
                href={`https://instagram.com/${contactInfo.instagram}`} 
                target="_blank" 
                rel="noopener noreferrer"
                class="social-icon instagram"
                aria-label="Instagram"
              >
                <i class="bi bi-instagram"></i>
              </a>
              <a 
                href={`https://facebook.com/${contactInfo.facebook}`} 
                target="_blank" 
                rel="noopener noreferrer"
                class="social-icon facebook"
                aria-label="Facebook"
              >
                <i class="bi bi-facebook"></i>
              </a>
              <a 
                href={`https://wa.me/${contactInfo.phone.replace(/\s/g, '')}`} 
                target="_blank" 
                rel="noopener noreferrer"
                class="social-icon whatsapp"
                aria-label="WhatsApp"
              >
                <i class="bi bi-whatsapp"></i>
              </a>
              <a 
                href={`mailto:${contactInfo.email}`}
                class="social-icon email"
                aria-label="Email"
              >
                <i class="bi bi-envelope"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-wrapper">
          <div class="form-container">
            <div class="form-header">
              <h3>Kirim Pesan</h3>
              <p>Isi form di bawah ini dan tim kami akan menghubungi Anda segera.</p>
            </div>

            <form id="contact-form">
              <div class="form-row">
                <div class="form-group">
                  <label for="name">Nama Lengkap <span class="required">*</span></label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    required
                    placeholder="Masukkan nama Anda"
                  />
                </div>
                <div class="form-group">
                  <label for="email">Email <span class="required">*</span></label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required
                    placeholder="Masukkan email Anda"
                  />
                </div>
              </div>

              <div class="form-group">
                <label for="phone">Nomor WhatsApp</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone" 
                  placeholder="Contoh: 08123456789"
                />
              </div>

              <div class="form-group">
                <label for="subject">Subjek <span class="required">*</span></label>
                <input 
                  type="text" 
                  id="subject" 
                  name="subject" 
                  required
                  placeholder="Masukkan subjek pesan"
                />
              </div>

              <div class="form-group">
                <label for="message">Pesan <span class="required">*</span></label>
                <textarea 
                  id="message" 
                  name="message" 
                  required
                  rows="4"
                  placeholder="Tulis pesan Anda di sini..."
                ></textarea>
              </div>

              <div class="form-check">
                <input 
                  type="checkbox" 
                  id="agree" 
                  name="agree" 
                  required
                />
                <label for="agree">
                  Saya setuju dengan kebijakan privasi dan menyetujui data saya diolah untuk keperluan komunikasi.
                </label>
              </div>

              <button type="submit" class="submit-btn" id="submitBtn">
                <i class="bi bi-send"></i>
                Kirim Pesan
              </button>

              <div id="form-success" class="form-feedback success hidden">
                <i class="bi bi-check-circle-fill"></i>
                <div>
                  <strong>Pesan berhasil dikirim!</strong>
                  <p>Tim kami akan menghubungi Anda dalam 1x24 jam melalui email atau WhatsApp.</p>
                </div>
              </div>
              <div id="form-error" class="form-feedback error hidden">
                <i class="bi bi-exclamation-circle-fill"></i>
                <div>
                  <strong>Gagal mengirim pesan!</strong>
                  <p>Silakan coba lagi atau hubungi kami langsung melalui WhatsApp di <a href="https://wa.me/628155257733" target="_blank">+62 815-5257-733</a></p>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MAP SECTION ===== -->
  <section class="map-section">
    <div class="container">
      <div class="map-header">
        <span class="section-tag">Lokasi</span>
        <h2>Temukan Kami</h2>
        <p>Kunjungi sekretariat kami di Bendungan Waru Turi, Kediri.</p>
      </div>

      <div class="map-container">
        <iframe 
          src={contactInfo.maps}
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Lokasi Bendungan Waru Turi"
        ></iframe>
        <div class="map-label">
          <i class="bi bi-geo-alt"></i>
          <span>Bendungan Waru Turi</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ SECTION ===== -->
  <section class="faq-section">
    <div class="container">
      <div class="faq-header">
        <span class="section-tag">FAQ</span>
        <h2>Pertanyaan yang Sering Diajukan</h2>
        <p>Temukan jawaban untuk pertanyaan-pertanyaan umum seputar Waru Turi Fun Run 2026.</p>
      </div>

      <div class="faq-list">
        {faqs.map((faq, index) => (
          <div key={index} class="faq-item">
            <button class="faq-toggle" type="button">
              <span class="faq-question">{faq.question}</span>
              <span class="faq-icon">
                <i class="bi bi-chevron-down"></i>
              </span>
            </button>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="faq-footer">
        <p>Masih ada pertanyaan? <a href="#" onclick="document.getElementById('contact-form').scrollIntoView({behavior: 'smooth'}); return false;">Hubungi kami</a></p>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Sudah Siap <span>Bergabung</span>?</h2>
        <p>Daftar sekarang dan jadilah bagian dari sejarah Waru Turi Fun Run 2026. Kami siap membantu Anda di setiap langkah!</p>
        <a href="/daftar" class="cta-btn">
          <i class="bi bi-ticket-perforated"></i> Daftar Sekarang
        </a>
        <p class="cta-note">
          <i class="bi bi-clock-history"></i> Kuota terbatas, segera daftar!
        </p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* ===== CONTAINER ===== */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ===== HERO ===== */
  .kontak-hero {
    position: relative;
    width: 100%;
    min-height: 300px;
    background: linear-gradient(135deg, rgba(11, 124, 255, 0.85), rgba(0, 182, 219, 0.85)),
      url('https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhLgtAHbzolMJkhEg_42wG0oVMGz24ls7ax9m3XUknvO8pkQA6NK93M3Opv9zTOczYPgXH1f92LEGnrmKRFA5JoG9W7Yj8MwGXouQ64OBF6A4IrjBcO_g_0576t4CPIlxVYzu3kLEvdI6tyP8D44Je7U7sRmo_aYGXc_Pgq5R0y9oJoRXtA2GjOrW-xXTiJ/s1280/header.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }
  
  .kontak-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  
  .kontak-hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    padding: 0 20px;
  }
  
  .kontak-title {
    font-size: 2.2rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 10px;
  }
  
  .kontak-subtitle {
    font-size: 1rem;
    line-height: 1.6;
    color: #e0f7fa;
    margin-bottom: 20px;
  }
  
  .kontak-breadcrumb {
    font-size: 0.85rem;
    color: #e0f7fa;
  }
  
  .kontak-breadcrumb a {
    color: #fff;
    font-weight: 600;
    text-decoration: none;
  }
  
  .kontak-breadcrumb a:hover {
    color: #FFD700;
  }
  
  .kontak-breadcrumb span {
    margin: 0 6px;
  }

  /* ===== CONTACT SECTION ===== */
  .contact-section {
    padding: 60px 0;
    background: #ffffff;
  }
  
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 40px;
    max-width: 1100px;
    margin: 0 auto;
  }
  
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  .contact-card {
    background: #f8f9fa;
    border-radius: 16px;
    padding: 20px;
    border: 1px solid #f0f0f0;
    transition: all 0.3s ease;
  }
  
  .contact-card:hover {
    border-color: rgba(38, 121, 236, 0.2);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
  }
  
  .contact-icon {
    width: 44px;
    height: 44px;
    background: rgba(38, 121, 236, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }
  
  .contact-icon i {
    font-size: 1.2rem;
    color: #2679ec;
  }
  
  .contact-card h4 {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 4px;
  }
  
  .contact-card p,
  .contact-card a {
    font-size: 0.9rem;
    color: #4a4a4a;
    text-decoration: none;
    line-height: 1.5;
  }
  
  .contact-card a:hover {
    color: #2679ec;
  }
  
  .hours-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: #4a4a4a;
    padding: 2px 0;
  }
  
  .hours-closed {
    color: #ef4444;
    font-weight: 600;
  }
  
  .social-card h4 {
    margin-bottom: 12px;
  }
  
  .social-icons {
    display: flex;
    gap: 10px;
  }
  
  .social-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.2rem;
    transition: all 0.3s ease;
    text-decoration: none;
  }
  
  .social-icon:hover {
    transform: scale(1.08);
  }
  
  .social-icon.instagram {
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
  }
  
  .social-icon.facebook {
    background: #1877F2;
  }
  
  .social-icon.whatsapp {
    background: #25D366;
  }
  
  .social-icon.email {
    background: #EA4335;
  }

  /* ===== CONTACT FORM ===== */
  .contact-form-wrapper {
    background: #ffffff;
    border-radius: 20px;
    border: 1px solid #f0f0f0;
    padding: 32px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
  }
  
  .form-header {
    margin-bottom: 24px;
  }
  
  .form-header h3 {
    font-size: 1.4rem;
    font-weight: 800;
    color: #1a1a1a;
  }
  
  .form-header p {
    font-size: 0.9rem;
    color: #666;
    margin-top: 4px;
  }
  
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  
  .form-group {
    margin-bottom: 16px;
  }
  
  .form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 6px;
  }
  
  .form-group .required {
    color: #ef4444;
  }
  
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 10px 14px;
    border: 2px solid #e8edf5;
    border-radius: 12px;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    background: #fafafa;
    font-family: inherit;
  }
  
  .form-group input:focus,
  .form-group textarea:focus {
    border-color: #2679ec;
    background: #ffffff;
    outline: none;
    box-shadow: 0 0 0 4px rgba(38, 121, 236, 0.08);
  }
  
  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }
  
  .form-check {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: 16px 0;
  }
  
  .form-check input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin-top: 2px;
    accent-color: #2679ec;
    flex-shrink: 0;
  }
  
  .form-check label {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.5;
  }
  
  .submit-btn {
    width: 100%;
    padding: 12px 32px;
    background: #2679ec;
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  
  .submit-btn:hover {
    background: #1a5fc7;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(38, 121, 236, 0.25);
  }
  
  .submit-btn:active {
    transform: translateY(0);
  }
  
  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }
  
  .form-feedback {
    margin-top: 16px;
    padding: 16px 20px;
    border-radius: 12px;
    font-size: 0.9rem;
    display: none;
    align-items: flex-start;
    gap: 12px;
  }
  
  .form-feedback.show {
    display: flex;
  }
  
  .form-feedback i {
    font-size: 1.4rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  
  .form-feedback strong {
    display: block;
    margin-bottom: 2px;
  }
  
  .form-feedback p {
    margin: 0;
    font-weight: 400;
  }
  
  .form-feedback p a {
    color: inherit;
    font-weight: 600;
    text-decoration: underline;
  }
  
  .form-feedback.success {
    background: #f0fdf4;
    border: 1px solid #86efac;
    color: #15803d;
  }
  
  .form-feedback.error {
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #dc2626;
  }

  /* ===== MAP SECTION ===== */
  .map-section {
    padding: 60px 0;
    background: #f8f9fa;
  }
  
  .map-header {
    text-align: center;
    margin-bottom: 32px;
  }
  
  .section-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #2679ec;
    margin-bottom: 6px;
  }
  
  .map-header h2 {
    font-size: 1.8rem;
    font-weight: 800;
    color: #1a1a1a;
    margin-bottom: 4px;
  }
  
  .map-header p {
    font-size: 0.95rem;
    color: #666;
  }
  
  .map-container {
    position: relative;
    background: #ffffff;
