---
// src/pages/artikel.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
import { db, articles } from '../db';
import { eq, desc, and } from 'drizzle-orm';

// ===== GET ALL PUBLISHED ARTICLES =====
let artikelData: any[] = [];
let error = '';

try {
  const result = await db.select()
    .from(articles)
    .where(eq(articles.status, 'published'))
    .orderBy(desc(articles.createdAt));

  artikelData = result || [];
} catch (e: any) {
  error = e.message;
  console.error('Error fetching articles:', e);
}

// ===== HELPER FUNCTIONS =====
function formatDate(dateStr: string | Date): string {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
}

function getCategoryColor(category: string): string {
  const colorMap: Record<string, string> = {
    'Tips & Trik': 'bg-blue-100 text-blue-700',
    'Peralatan': 'bg-purple-100 text-purple-700',
    'Nutrisi': 'bg-green-100 text-green-700',
    'Latihan': 'bg-orange-100 text-orange-700',
    'Kesehatan': 'bg-emerald-100 text-emerald-700',
    'Event': 'bg-red-100 text-red-700',
  };
  return colorMap[category] || 'bg-gray-100 text-gray-700';
}

function getReadTime(content: string): number {
  if (!content) return 1;
  const words = content.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

function truncateText(text: string, maxLength: number = 150): string {
  if (!text) return '';
  if (text.length <= maxLength) return text;
  return text.substring(0, maxLength) + '...';
}

// ===== GET UNIQUE CATEGORIES =====
const categories = [...new Set(artikelData.map(a => a.category).filter(Boolean))];

// ===== SEPARATE FEATURED ARTICLES =====
// Featured: 2 artikel terbaru, ditampilkan di section "Artikel Pilihan".
// Grid "Semua Artikel" tetap berisi SEMUA artikel (termasuk yang featured),
// supaya tiap artikel selalu muncul di grid utama dan bisa kefilter sesuai
// kategorinya masing-masing (mis. artikel kategori "Event" tetap muncul
// baik di filter "Semua" maupun filter "Event").
const featuredArticles = artikelData.slice(0, 2);
const regularArticles = artikelData;

// ===== CHECK IF ARTICLES EXIST =====
const hasArticles = artikelData.length > 0;
---

<BaseLayout title="Artikel - Waru Turi Fun Run 2026" description="Kumpulan artikel dan tips menarik seputar lari, kesehatan, dan Waru Turi Fun Run 2026.">
  <div class="artikel-page">
    <Navbar />

    <!-- ===== HERO (judul berdiri sendiri di awal halaman) ===== -->
    <section class="artikel-hero">
      <div class="artikel-overlay"></div>
      <div class="artikel-hero-content">
        <div class="artikel-breadcrumb">
          <a href="/">Home</a>
          <span>›</span>
          <span>Artikel</span>
        </div>
        <h1 class="artikel-title">Artikel & Tips</h1>
        <p class="artikel-subtitle">
          Temukan berbagai artikel menarik seputar lari, kesehatan, nutrisi, dan informasi seputar Waru Turi Fun Run 2026.
        </p>
      </div>
    </section>

    {error && (
      <section class="py-4 bg-red-50 border-b border-red-200">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <p class="text-red-700 text-sm">
            <i class="bi bi-exclamation-circle-fill mr-1"></i>
            Gagal memuat artikel: {error}
          </p>
        </div>
      </section>
    )}

    <!-- ===== CATEGORY FILTER ===== -->
    <section class="py-6 bg-white border-b border-gray-100 sticky top-[72px] z-40 shadow-sm">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto flex flex-wrap gap-2 justify-center">
          <button class="category-filter-btn active px-4 py-2 rounded-full text-sm font-medium transition-all" data-category="all">
            Semua
          </button>
          {categories.map((category) => (
            <button key={category} class="category-filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all" data-category={category}>
              {category}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== CONTENT ===== -->
    {hasArticles ? (
      <>
        <!-- ===== FEATURED ARTICLES ===== -->
        {featuredArticles.length > 0 && (
          <section class="py-10 bg-[#F7F8FC]">
            <div class="container mx-auto px-4 sm:px-6 lg:px-8">
              <div class="max-w-6xl mx-auto">
                <div class="flex items-center gap-3 mb-8">
                  <span class="w-1 h-8 bg-[#FFD700] rounded-full"></span>
                  <h2 class="text-2xl font-bold text-gray-900">Artikel Pilihan</h2>
                  <span class="text-sm text-gray-400">|</span>
                  <span class="text-sm text-gray-500">Kami rekomendasikan untuk Anda</span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  {featuredArticles.map((artikel) => (
                    <a href={`/artikel/${artikel.slug}`} class="group block bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden border border-gray-100 hover:border-[#2679ec]/30 hover:-translate-y-2">
                      <div class="relative h-56 overflow-hidden">
                        {artikel.featuredImage ? (
                          <img
                            src={artikel.featuredImage}
                            alt={artikel.title}
                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                            loading="lazy"
                          />
                        ) : (
                          <div class="w-full h-full bg-gradient-to-br from-blue-100 to-blue-200 flex items-center justify-center">
                            <i class="bi bi-image text-5xl text-blue-400"></i>
                          </div>
                        )}
                        <div class="absolute top-4 left-4">
                          <span class={`px-3 py-1 rounded-full text-xs font-bold ${getCategoryColor(artikel.category)}`}>
                            {artikel.category}
                          </span>
                        </div>
                        <div class="absolute top-4 right-4">
                          <span class="px-3 py-1 rounded-full text-xs font-bold bg-[#FFD700] text-gray-900">
                            <i class="bi bi-star-fill mr-1"></i> Featured
                          </span>
                        </div>
                      </div>
                      <div class="p-6">
                        <h3 class="text-xl font-bold text-gray-900 group-hover:text-[#2679ec] transition-colors line-clamp-2">
                          {artikel.title}
                        </h3>
                        <p class="text-gray-600 text-sm mt-2 line-clamp-3">
                          {artikel.excerpt || truncateText(artikel.content || '', 150)}
                        </p>
                        <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
                          <div class="flex items-center gap-2 text-xs text-gray-500">
                            <i class="bi bi-person-circle"></i>
                            <span>{artikel.authorName || 'Admin'}</span>
                            <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                            <i class="bi bi-calendar3"></i>
                            <span>{formatDate(artikel.createdAt)}</span>
                          </div>
                          <span class="text-xs text-gray-400 flex items-center gap-1">
                            <i class="bi bi-clock"></i>
                            {getReadTime(artikel.content)} min read
                          </span>
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </section>
        )}

        <!-- ===== ARTICLES GRID ===== -->
        <section class="py-10 bg-white" id="artikel-grid">
          <div class="container mx-auto px-4 sm:px-6 lg:px-8">
            <div class="max-w-6xl mx-auto">
              <div class="flex items-center gap-3 mb-8">
                <span class="w-1 h-8 bg-[#2679ec] rounded-full"></span>
                <h2 class="text-2xl font-bold text-gray-900">Semua Artikel</h2>
                <span class="text-sm text-gray-400">|</span>
                <span class="text-sm text-gray-500">{artikelData.length} artikel</span>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {regularArticles.map((artikel) => (
                  <a
                    key={artikel.id}
                    href={`/artikel/${artikel.slug}`}
                    class="artikel-card group block bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-500 overflow-hidden border border-gray-100 hover:border-[#2679ec]/20 hover:-translate-y-2"
                    data-category={artikel.category}
                  >
                    <div class="relative h-48 overflow-hidden">
                      {artikel.featuredImage ? (
                        <img
                          src={artikel.featuredImage}
                          alt={artikel.title}
                          class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                          loading="lazy"
                        />
                      ) : (
                        <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                          <i class="bi bi-image text-4xl text-gray-400"></i>
                        </div>
                      )}
                      <div class="absolute top-3 left-3">
                        <span class={`px-2.5 py-1 rounded-full text-xs font-bold ${getCategoryColor(artikel.category)}`}>
                          {artikel.category}
                        </span>
                      </div>
                    </div>
                    <div class="p-5">
                      <h3 class="text-base font-bold text-gray-900 group-hover:text-[#2679ec] transition-colors line-clamp-2">
                        {artikel.title}
                      </h3>
                      <p class="text-gray-600 text-sm mt-2 line-clamp-2">
                        {artikel.excerpt || truncateText(artikel.content || '', 120)}
                      </p>
                      <div class="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                        <div class="flex items-center gap-2 text-xs text-gray-500">
                          <i class="bi bi-person-circle"></i>
                          <span>{artikel.authorName || 'Admin'}</span>
                        </div>
                        <div class="flex items-center gap-2 text-xs text-gray-400">
                          <i class="bi bi-calendar3"></i>
                          <span>{formatDate(artikel.createdAt)}</span>
                          <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                          <i class="bi bi-clock"></i>
                          <span>{getReadTime(artikel.content)}m</span>
                        </div>
                      </div>
                    </div>
                  </a>
                ))}
              </div>

              <!-- Empty State untuk filter -->
              <div id="artikel-empty" class="hidden text-center py-16">
                <i class="bi bi-journal text-6xl text-gray-300 block mb-4"></i>
                <p class="text-gray-500 text-lg font-medium">Tidak ada artikel dalam kategori ini</p>
                <p class="text-gray-400 text-sm mt-1">Coba pilih kategori lain</p>
              </div>
            </div>
          </div>
        </section>
      </>
    ) : (
      <!-- ===== EMPTY STATE - Belum Ada Artikel ===== -->
      <section class="py-20 bg-white">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8">
          <div class="max-w-2xl mx-auto text-center">
            <div class="w-32 h-32 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
              <i class="bi bi-newspaper text-5xl text-gray-400"></i>
            </div>
            <h2 class="text-3xl font-bold text-gray-900 mb-3">Belum Ada Artikel</h2>
            <p class="text-gray-600 text-lg mb-6">
              Saat ini belum ada artikel yang dipublikasikan.
              Silakan cek kembali nanti untuk artikel menarik seputar lari dan Waru Turi Fun Run 2026.
            </p>
            <div class="flex flex-wrap gap-3 justify-center">
              <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-[#2679ec] text-white rounded-xl hover:bg-[#1a5fc7] transition">
                <i class="bi bi-house"></i>
                Kembali ke Beranda
              </a>
              <a href="/p/ticket-sold.html" class="inline-flex items-center gap-2 px-6 py-3 bg-[#FFD700] text-gray-900 rounded-xl hover:bg-[#FFC107] transition">
                <i class="bi bi-ticket"></i>
                Daftar Sekarang
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- ===== NEWSLETTER ===== -->
    <section class="py-16 bg-[#F7F8FC]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <div class="bg-white rounded-3xl shadow-xl p-8 md:p-12 text-center border border-gray-100">
            <div class="w-16 h-16 bg-[#2679ec]/10 rounded-full flex items-center justify-center mx-auto mb-6">
              <i class="bi bi-envelope-paper text-3xl text-[#2679ec]"></i>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-3">Subscribe Newsletter</h3>
            <p class="text-gray-600 text-base mb-6 leading-relaxed">
              Dapatkan artikel dan tips terbaru seputar lari dan informasi Waru Turi Fun Run 2026 langsung di email Anda.
            </p>
            <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
              <input
                type="email"
                placeholder="Masukkan email Anda"
                class="flex-1 px-4 py-3 rounded-full border border-gray-200 focus:border-[#2679ec] focus:ring-2 focus:ring-[#2679ec]/20 outline-none transition-all text-sm"
                required
              />
              <button type="submit" class="px-6 py-3 bg-[#2679ec] hover:bg-[#1a5fc7] text-white font-semibold rounded-full transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1 text-sm whitespace-nowrap">
                Subscribe
              </button>
            </form>
            <p class="text-xs text-gray-400 mt-3">* Kami tidak akan spam. Anda bisa unsubscribe kapan saja.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="py-16 bg-gradient-to-br from-[#001a4d] via-[#002266] to-[#0033A0] text-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">
            Siap Bergabung di <span class="text-[#FFD700]">Waru Turi</span>?
          </h2>
          <p class="text-white/80 text-base mb-8 leading-relaxed">
            Baca artikel inspiratif, persiapkan diri, dan daftar sekarang untuk pengalaman lari yang tak terlupakan!
          </p>
          <a href="/p/ticket-sold.html" class="inline-flex items-center gap-2.5 bg-[#FFD700] hover:bg-[#FFC107] text-gray-900 font-bold px-10 py-4 rounded-2xl transition-all duration-300 shadow-2xl hover:shadow-3xl hover:-translate-y-1">
            <i class="bi bi-ticket-perforated text-lg"></i> Daftar Sekarang
          </a>
          <p class="text-white/40 text-xs mt-4">
            <i class="bi bi-clock-history mr-1"></i> Kuota terbatas, segera daftar!
          </p>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</BaseLayout>

<style>
  /* Font Open Sans untuk seluruh halaman artikel */
  @import url('https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap');

  .artikel-page {
    font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  /* ===== HERO ===== */
  .artikel-hero {
    position: relative;
    width: 100%;
    min-height: 340px;
    background: linear-gradient(135deg, rgba(11, 124, 255, 0.88), rgba(0, 51, 160, 0.9)),
      url('https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhLgtAHbzolMJkhEg_42wG0oVMGz24ls7ax9m3XUknvO8pkQA6NK93M3Opv9zTOczYPgXH1f92LEGnrmKRFA5JoG9W7Yj8MwGXouQ64OBF6A4IrjBcO_g_0576t4CPIlxVYzu3kLEvdI6tyP8D44Je7U7sRmo_aYGXc_Pgq5R0y9oJoRXtA2GjOrW-XxTiJ/s1280/header.jpg') center/cover no-repeat fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }
  .artikel-overlay {
    position: absolute;
    inset: 0;
    background: transparent;
    z-index: 1;
  }
  .artikel-hero-content {
    position: relative;
    z-index: 2;
    max-width: 720px;
    padding: 0 20px;
  }
  .artikel-breadcrumb {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 16px;
  }
  .artikel-breadcrumb a {
    color: #fff;
    font-weight: 600;
    text-decoration: none;
  }
  .artikel-breadcrumb a:hover {
    color: #FFD700;
  }
  .artikel-breadcrumb span {
    margin: 0 6px;
  }
  .artikel-title {
    font-size: 44px;
    font-weight: 800;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 14px;
  }
  .artikel-subtitle {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .artikel-hero {
      min-height: 280px;
      background-attachment: scroll;
    }
    .artikel-title {
      font-size: 30px;
    }
    .artikel-subtitle {
      font-size: 14px;
    }
  }

  /* ===== CATEGORY FILTER ===== */
  .category-filter-btn {
    background: #f3f4f6;
    color: #6b7280;
    border: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
  }
  .category-filter-btn:hover {
    background: #e5e7eb;
    color: #374151;
  }
  .category-filter-btn.active {
    background: #2679ec;
    color: white;
    border-color: #2679ec;
    box-shadow: 0 4px 12px rgba(38, 121, 236, 0.3);
  }

  /* ===== ARTICLES ===== */
  .artikel-card {
    animation: fadeInUp 0.5s ease-out forwards;
  }
  .artikel-card:nth-child(1) { animation-delay: 0.05s; }
  .artikel-card:nth-child(2) { animation-delay: 0.1s; }
  .artikel-card:nth-child(3) { animation-delay: 0.15s; }
  .artikel-card:nth-child(4) { animation-delay: 0.2s; }
  .artikel-card:nth-child(5) { animation-delay: 0.25s; }
  .artikel-card:nth-child(6) { animation-delay: 0.3s; }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== LINE CLAMP ===== */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ===== STICKY NAV ===== */
  .sticky {
    position: sticky;
    top: 72px;
    z-index: 40;
  }

  @media (max-width: 768px) {
    .sticky {
      top: 64px;
    }
  }
</style>

<!-- ===== CATEGORY FILTER SCRIPT ===== -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterButtons = document.querySelectorAll('.category-filter-btn');
    const artikelCards = document.querySelectorAll('.artikel-card');
    const emptyState = document.getElementById('artikel-empty');
    const featuredSection = document.querySelector('.bg-\\[\\#F7F8FC\\]');

    let currentCategory = 'all';

    function filterArticles(category: string) {
      let visibleCount = 0;

      artikelCards.forEach(card => {
        const cardCategory = card.dataset.category || '';
        if (category === 'all' || cardCategory === category) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      // Show/hide empty state
      if (emptyState) {
        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
        } else {
          emptyState.classList.add('hidden');
        }
      }

      // Show/hide featured section jika filter bukan 'all'
      if (featuredSection) {
        if (category !== 'all') {
          featuredSection.style.display = 'none';
        } else {
          featuredSection.style.display = '';
        }
      }
    }

    // Event listener untuk filter button
    filterButtons.forEach(btn => {
      btn.addEventListener('click', function() {
        filterButtons.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        currentCategory = this.dataset.category;
        filterArticles(currentCategory);
      });
    });

    // Inisialisasi
    filterArticles('all');
  });
</script>