    price: 450000,
    stock: 50,
    soldCount: 180,
    status: 'sold_out',
    category: 'Limited',
    image: 'https://picsum.photos/seed/jersey3/400/400',
    race: { id: '2', name: 'Waru Turi Run 2026' },
    sizes: [
      { id: '8', name: 'S' },
      { id: '9', name: 'M' },
      { id: '10', name: 'L' },
      { id: '11', name: 'XL' },
      { id: '12', name: 'XXL' },
