---
// src/pages/admin/jerseys/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';

// Data dummy untuk sementara
const dummyJerseys = [
  {
    id: '1',
    name: 'Jersey Elite 2027',
    description: 'Jersey premium untuk Waru Turi Run 2027 dengan bahan berkualitas tinggi',
    price: 350000,
    stock: 150,
    soldCount: 45,
    status: 'available',
    category: 'Premium',
    image: 'https://picsum.photos/seed/jersey1/400/400',
    race: { id: '1', name: 'Waru Turi Run 2027' },
    sizes: [
      { id: '1', name: 'S' },
      { id: '2', name: 'M' },
      { id: '3', name: 'L' },
      { id: '4', name: 'XL' },
