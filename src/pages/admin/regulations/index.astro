---
// src/pages/admin/regulations/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';

// Data dummy untuk sementara
const regulations = [
  {
    id: '1',
    title: 'Peraturan Umum Waru Turi Run 2027',
    category: 'Umum',
    description: 'Peraturan dasar yang berlaku untuk seluruh peserta Waru Turi Run 2027',
    content: `1. Peserta wajib mendaftar secara online melalui website resmi Waru Turi Run
2. Peserta harus dalam kondisi sehat dan bugar untuk mengikuti lomba
3. Peserta wajib mengenakan nomor dada yang telah disediakan panitia
4. Peserta dilarang menggunakan kendaraan bermotor selama perlombaan
5. Peserta wajib mengikuti jalur yang telah ditentukan
6. Peserta yang melanggar peraturan akan dikenakan sanksi diskualifikasi`,
    status: 'active',
    priority: 1,
    icon: 'bi bi-file-text',
    createdAt: '2026-07-10',
    updatedAt: '2026-07-10',
  },
  {
    id: '2',
    title: 'Peraturan Perlengkapan Peserta',
    category: 'Perlengkapan',
    description: 'Ketentuan perlengkapan yang wajib digunakan oleh peserta selama perlombaan',
    content: `1. Peserta wajib menggunakan jersey resmi Waru Turi Run
2. Peserta wajib menggunakan sepatu lari yang layak
3. Peserta dilarang menggunakan alat bantu mekanis
4. Peserta wajib membawa air minum sendiri
5. Peserta direkomendasikan menggunakan pelindung matahari
6. Peserta wajib menggunakan nomor dada yang terlihat jelas`,
    status: 'active',
    priority: 2,
    icon: 'bi bi-backpack',
    createdAt: '2026-07-09',
    updatedAt: '2026-07-09',
  },
  {
    id: '3',
    title: 'Peraturan Keselamatan dan Kesehatan',
    category: 'Keselamatan',
    description: 'Aturan keselamatan dan kesehatan yang harus dipatuhi selama event berlangsung',
    content: `1. Peserta wajib melakukan pemanasan sebelum perlombaan
2. Peserta wajib menjaga jarak aman dengan peserta lain
3. Peserta wajib mengikuti instruksi petugas kesehatan
4. Peserta dilarang memaksakan diri jika mengalami cedera
5. Peserta wajib melaporkan kondisi kesehatan ke petugas medis
6. Peserta wajib menjaga kebersihan lingkungan`,
    status: 'active',
    priority: 3,
    icon: 'bi bi-heart-pulse',
    createdAt: '2026-07-08',
    updatedAt: '2026-07-08',
  },
  {
    id: '4',
    title: 'Peraturan Kategori Lomba',
    category: 'Kategori',
    description: 'Ketentuan kategori lomba yang tersedia di Waru Turi Run',
    content: `1. Kategori 5K: Untuk pelari pemula dan keluarga
2. Kategori 10K: Untuk pelari menengah
3. Kategori Half Marathon: Untuk pelari berpengalaman
4. Kategori Marathon: Untuk pelari elit
5. Peserta hanya boleh mengikuti satu kategori
6. Perpindahan kategori tidak diperbolehkan setelah pendaftaran`,
    status: 'active',
    priority: 4,
    icon: 'bi bi-trophy',
    createdAt: '2026-07-07',
    updatedAt: '2026-07-07',
  },
  {
    id: '5',
    title: 'Peraturan Sanksi dan Diskualifikasi',
    category: 'Sanksi',
    description: 'Aturan mengenai sanksi dan diskualifikasi peserta yang melanggar peraturan',
    content: `1. Peserta yang melanggar peraturan akan mendapatkan peringatan
2. Pelanggaran berat akan dikenakan diskualifikasi
3. Peserta yang didiskualifikasi tidak berhak mendapatkan medali
4. Keputusan panitia bersifat mutlak dan tidak dapat diganggu gugat
5. Peserta dapat mengajukan banding secara tertulis dalam 3x24 jam
6. Panitia berhak menambahkan sanksi sesuai kebijakan`,
    status: 'inactive',
    priority: 5,
    icon: 'bi bi-exclamation-triangle',
    createdAt: '2026-07-06',
    updatedAt: '2026-07-06',
  },
  {
    id: '6',
    title: 'Peraturan Pendaftaran dan Pembayaran',
    category: 'Pendaftaran',
    description: 'Ketentuan pendaftaran dan pembayaran untuk mengikuti Waru Turi Run',
    content: `1. Pendaftaran dilakukan secara online melalui website resmi
2. Pembayaran dapat dilakukan melalui transfer bank atau e-wallet
3. Batas waktu pendaftaran 7 hari sebelum event
4. Biaya pendaftaran tidak dapat dikembalikan
5. Peserta wajib mengisi data dengan benar dan lengkap
6. Peserta akan mendapatkan nomor peserta setelah pembayaran terverifikasi`,
    status: 'active',
    priority: 6,
    icon: 'bi bi-credit-card',
    createdAt: '2026-07-05',
    updatedAt: '2026-07-05',
  },
];

// Helper function untuk format tanggal
function formatDate(date: string): string {
  return new Date(date).toLocaleDateString('id-ID', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });
}

// Helper function untuk get color status
function getStatusColor(status: string): string {
  return status === 'active' 
    ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 border-green-200 dark:border-green-800'
    : 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 border-red-200 dark:border-red-800';
}

// Helper function untuk get icon color
function getIconColor(category: string): string {
  const colors: Record<string, string> = {
    'Umum': 'text-blue-600 dark:text-blue-400',
    'Perlengkapan': 'text-purple-600 dark:text-purple-400',
    'Keselamatan': 'text-green-600 dark:text-green-400',
    'Kategori': 'text-yellow-600 dark:text-yellow-400',
    'Sanksi': 'text-red-600 dark:text-red-400',
    'Pendaftaran': 'text-orange-600 dark:text-orange-400',
  };
  return colors[category] || 'text-gray-600 dark:text-gray-400';
}
---

<AdminLayout title="Regulasi - Admin Panel">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <div>
          <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">
            <i class="bi bi-file-text text-blue-600 dark:text-blue-400 mr-2"></i>
            Manajemen Regulasi
          </h1>
          <p class="text-gray-500 dark:text-gray-400 mt-1">
            Kelola peraturan dan regulasi Waru Turi Run
          </p>
        </div>
        <div class="flex gap-3">
          <button class="px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition flex items-center gap-2">
            <i class="bi bi-download"></i>
            Export
          </button>
          <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center gap-2" onclick="openModal()">
            <i class="bi bi-plus-lg"></i>
            Tambah Regulasi
          </button>
        </div>
      </div>
    </div>

    <!-- Filter & Search -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4 mb-6">
      <div class="flex flex-col md:flex-row gap-4">
        <div class="flex-1 relative">
          <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500"></i>
          <input 
            type="text" 
            placeholder="Cari regulasi..." 
            class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            id="searchInput"
          />
        </div>
        <div class="flex gap-3">
          <select class="px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            <option value="">Semua Kategori</option>
            <option value="Umum">Umum</option>
            <option value="Perlengkapan">Perlengkapan</option>
            <option value="Keselamatan">Keselamatan</option>
            <option value="Kategori">Kategori</option>
            <option value="Sanksi">Sanksi</option>
            <option value="Pendaftaran">Pendaftaran</option>
          </select>
          <select class="px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            <option value="">Semua Status</option>
            <option value="active">Aktif</option>
            <option value="inactive">Tidak Aktif</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Total Regulasi</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">{regulations.length}</p>
          </div>
          <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-file-text text-2xl text-blue-600 dark:text-blue-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-green-600 dark:text-green-400">↑ 5 regulasi aktif</span>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Aktif</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">
              {regulations.filter(r => r.status === 'active').length}
            </p>
          </div>
          <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-check-circle text-2xl text-green-600 dark:text-green-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-gray-500 dark:text-gray-400">Regulasi berlaku</span>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Kategori</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">
              {new Set(regulations.map(r => r.category)).size}
            </p>
          </div>
          <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-tags text-2xl text-purple-600 dark:text-purple-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-gray-500 dark:text-gray-400">Total kategori</span>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Total Poin</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">
              {regulations.reduce((acc, r) => acc + (r.content?.split('\n').length || 0), 0)}
            </p>
          </div>
          <div class="w-12 h-12 bg-yellow-100 dark:bg-yellow-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-list-ol text-2xl text-yellow-600 dark:text-yellow-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-gray-500 dark:text-gray-400">Total peraturan</span>
        </div>
      </div>
    </div>

    <!-- Regulations List -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-200/50 dark:border-gray-700/50">
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">No</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Judul</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Kategori</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Prioritas</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tanggal</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200/50 dark:divide-gray-700/50">
            {regulations.map((regulation, index) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition" data-id={regulation.id}>
                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-300">{index + 1}</td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class={`
                      w-9 h-9 rounded-lg flex items-center justify-center
                      ${regulation.status === 'active' ? 'bg-blue-50 dark:bg-blue-900/20' : 'bg-gray-100 dark:bg-gray-700'}
                    `}>
                      <i class={`${regulation.icon} ${getIconColor(regulation.category)}`}></i>
                    </div>
                    <div>
                      <p class="text-sm font-medium text-gray-900 dark:text-white line-clamp-1">
                        {regulation.title}
                      </p>
                      <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-1">
                        {regulation.description}
                      </p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class="px-2.5 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 text-xs font-medium rounded-full">
                    {regulation.category}
                  </span>
                </td>
                <td class="px-6 py-4">
                  <span class={`
                    px-2.5 py-1 text-xs font-medium rounded-full
                    ${getStatusColor(regulation.status)}
                  `}>
                    {regulation.status === 'active' ? 'Aktif' : 'Tidak Aktif'}
                  </span>
                </td>
                <td class="px-6 py-4">
                  <span class="px-2.5 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 text-xs font-medium rounded-full">
                    {regulation.priority}
                  </span>
                </td>
                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-300">
                  {formatDate(regulation.createdAt)}
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    <button onclick="viewRegulation('{regulation.id}')" class="p-1.5 text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition" title="Lihat">
                      <i class="bi bi-eye"></i>
                    </button>
                    <button onclick="editRegulation('{regulation.id}')" class="p-1.5 text-yellow-600 dark:text-yellow-400 hover:bg-yellow-50 dark:hover:bg-yellow-900/20 rounded-lg transition" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button onclick="deleteRegulation('{regulation.id}')" class="p-1.5 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition" title="Hapus">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="px-6 py-4 border-t border-gray-200/50 dark:border-gray-700/50 flex items-center justify-between flex-wrap gap-3">
        <p class="text-sm text-gray-500 dark:text-gray-400">
          Menampilkan <span class="font-medium">1</span> - <span class="font-medium">{Math.min(10, regulations.length)}</span> dari <span class="font-medium">{regulations.length}</span> data
        </p>
        <div class="flex items-center gap-2">
          <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition disabled:opacity-50" disabled>
            <i class="bi bi-chevron-left"></i>
          </button>
          <button class="px-3 py-1.5 rounded-lg bg-blue-600 text-white">1</button>
          <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">2</button>
          <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">3</button>
          <span class="text-gray-500 dark:text-gray-400">...</span>
          <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">10</button>
          <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
            <i class="bi bi-chevron-right"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Tambah/Edit Regulasi -->
  <div id="modal" class="fixed inset-0 z-50 flex items-center justify-center px-4 opacity-0 invisible transition-all duration-300">
    <div class="absolute inset-0 bg-black/50" onclick="closeModal()"></div>
    <div class="relative bg-white dark:bg-gray-800 rounded-2xl max-w-3xl w-full max-h-[90vh] overflow-y-auto shadow-2xl transform scale-95 transition-all duration-300">
      <div class="sticky top-0 bg-white dark:bg-gray-800 z-10 px-6 py-4 border-b border-gray-200/50 dark:border-gray-700/50 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
          <i class="bi bi-plus-circle text-blue-600 dark:text-blue-400 mr-2"></i>
          <span id="modalTitle">Tambah Regulasi Baru</span>
        </h3>
        <button onclick="closeModal()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      
      <form id="regulationForm" class="p-6 space-y-4">
        <!-- Judul -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Judul Regulasi <span class="text-red-500">*</span>
          </label>
          <input 
            type="text" 
            id="regulationTitle"
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            placeholder="Masukkan judul regulasi"
            required
          />
        </div>

        <!-- Deskripsi -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Deskripsi Singkat <span class="text-red-500">*</span>
          </label>
          <input 
            type="text" 
            id="regulationDescription"
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            placeholder="Deskripsi singkat regulasi"
            required
          />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Kategori -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              Kategori <span class="text-red-500">*</span>
            </label>
            <select 
              id="regulationCategory"
              class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              required
            >
              <option value="">Pilih Kategori</option>
              <option value="Umum">Umum</option>
              <option value="Perlengkapan">Perlengkapan</option>
              <option value="Keselamatan">Keselamatan</option>
              <option value="Kategori">Kategori</option>
              <option value="Sanksi">Sanksi</option>
              <option value="Pendaftaran">Pendaftaran</option>
            </select>
          </div>

          <!-- Status -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              Status <span class="text-red-500">*</span>
            </label>
            <select 
              id="regulationStatus"
              class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              required
            >
              <option value="active">Aktif</option>
              <option value="inactive">Tidak Aktif</option>
            </select>
          </div>

          <!-- Prioritas -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              Prioritas <span class="text-red-500">*</span>
            </label>
            <input 
              type="number" 
              id="regulationPriority"
              class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
              placeholder="1"
              min="1"
              required
            />
          </div>
        </div>

        <!-- Icon -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Icon <span class="text-red-500">*</span>
          </label>
          <select 
            id="regulationIcon"
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            required
          >
            <option value="bi bi-file-text">📄 File Text</option>
            <option value="bi bi-backpack">🎒 Perlengkapan</option>
            <option value="bi bi-heart-pulse">💚 Kesehatan</option>
            <option value="bi bi-trophy">🏆 Kategori</option>
            <option value="bi bi-exclamation-triangle">⚠️ Sanksi</option>
            <option value="bi bi-credit-card">💳 Pendaftaran</option>
            <option value="bi bi-shield-check">🛡️ Keamanan</option>
            <option value="bi bi-clock">⏰ Waktu</option>
          </select>
        </div>

        <!-- Konten -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Konten Regulasi <span class="text-red-500">*</span>
          </label>
          <p class="text-xs text-gray-400 dark:text-gray-500 mb-2">
            Tulis setiap peraturan pada baris baru (contoh: 1. Peraturan pertama)
          </p>
          <textarea 
            id="regulationContent"
            rows="8" 
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none font-mono text-sm"
            placeholder="1. Peraturan pertama&#10;2. Peraturan kedua&#10;3. Peraturan ketiga"
            required
          ></textarea>
        </div>

        <!-- Submit Buttons -->
        <div class="sticky bottom-0 bg-white dark:bg-gray-800 pt-4 border-t border-gray-200/50 dark:border-gray-700/50 flex justify-end gap-3">
          <button type="button" onclick="closeModal()" class="px-6 py-2 border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">
            Batal
          </button>
          <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center gap-2">
            <i class="bi bi-check-lg"></i>
            <span id="submitText">Simpan</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal View Detail -->
  <div id="viewModal" class="fixed inset-0 z-50 flex items-center justify-center px-4 opacity-0 invisible transition-all duration-300">
    <div class="absolute inset-0 bg-black/50" onclick="closeViewModal()"></div>
    <div class="relative bg-white dark:bg-gray-800 rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl transform scale-95 transition-all duration-300">
      <div class="sticky top-0 bg-white dark:bg-gray-800 z-10 px-6 py-4 border-b border-gray-200/50 dark:border-gray-700/50 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
          <i class="bi bi-eye text-blue-600 dark:text-blue-400 mr-2"></i>
          Detail Regulasi
        </h3>
        <button onclick="closeViewModal()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      
      <div class="p-6 space-y-4" id="viewContent">
        <!-- Content akan diisi oleh JavaScript -->
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="fixed bottom-6 right-6 bg-gray-900 dark:bg-gray-800 text-white px-6 py-4 rounded-xl shadow-lg transform translate-y-full opacity-0 transition-all duration-300 flex items-center gap-3 z-50">
    <i class="bi bi-check-circle-fill text-green-400"></i>
    <span id="toast-message">Regulasi berhasil disimpan!</span>
    <button onclick="hideToast()" class="text-gray-400 hover:text-white transition">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>

  <script>
    // ============================================================
    // DATA REGULATIONS
    // ============================================================
    const regulationsData = [
      { id: '1', title: 'Peraturan Umum Waru Turi Run 2027', category: 'Umum', description: 'Peraturan dasar yang berlaku untuk seluruh peserta', content: '1. Peserta wajib mendaftar secara online melalui website resmi\n2. Peserta harus dalam kondisi sehat dan bugar\n3. Peserta wajib mengenakan nomor dada\n4. Peserta dilarang menggunakan kendaraan bermotor\n5. Peserta wajib mengikuti jalur yang telah ditentukan\n6. Peserta yang melanggar akan dikenakan sanksi', status: 'active', priority: 1, icon: 'bi bi-file-text' },
      { id: '2', title: 'Peraturan Perlengkapan Peserta', category: 'Perlengkapan', description: 'Ketentuan perlengkapan yang wajib digunakan', content: '1. Peserta wajib menggunakan jersey resmi\n2. Peserta wajib menggunakan sepatu lari yang layak\n3. Peserta dilarang menggunakan alat bantu mekanis\n4. Peserta wajib membawa air minum sendiri\n5. Peserta direkomendasikan menggunakan pelindung matahari', status: 'active', priority: 2, icon: 'bi bi-backpack' },
      { id: '3', title: 'Peraturan Keselamatan dan Kesehatan', category: 'Keselamatan', description: 'Aturan keselamatan dan kesehatan yang harus dipatuhi', content: '1. Peserta wajib melakukan pemanasan sebelum perlombaan\n2. Peserta wajib menjaga jarak aman\n3. Peserta wajib mengikuti instruksi petugas kesehatan\n4. Peserta dilarang memaksakan diri jika cedera\n5. Peserta wajib melaporkan kondisi kesehatan ke petugas medis', status: 'active', priority: 3, icon: 'bi bi-heart-pulse' },
    ];

    // ============================================================
    // MODAL FUNCTIONS
    // ============================================================
    const modal = document.getElementById('modal');
    const viewModal = document.getElementById('viewModal');
    const modalTitle = document.getElementById('modalTitle');
    const submitText = document.getElementById('submitText');
    const regulationForm = document.getElementById('regulationForm');
    let editingId = null;

    function openModal() {
      modal.classList.remove('opacity-0', 'invisible');
      modal.querySelector('.relative').classList.remove('scale-95');
      modal.querySelector('.relative').classList.add('scale-100');
      document.body.style.overflow = 'hidden';
      resetForm();
    }
    window.openModal = openModal;

    function closeModal() {
      modal.classList.add('opacity-0', 'invisible');
      modal.querySelector('.relative').classList.remove('scale-100');
      modal.querySelector('.relative').classList.add('scale-95');
      document.body.style.overflow = '';
      resetForm();
    }
    window.closeModal = closeModal;

    function resetForm() {
      regulationForm.reset();
      editingId = null;
      modalTitle.textContent = 'Tambah Regulasi Baru';
      submitText.textContent = 'Simpan';
      document.getElementById('regulationPriority').value = '';
    }

    // ============================================================
    // VIEW REGULATION
    // ============================================================
    function viewRegulation(id) {
      const reg = regulationsData.find(r => r.id === id);
      if (!reg) return;

      const content = document.getElementById('viewContent');
      content.innerHTML = `
        <div class="flex items-start gap-4 p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
          <div class="w-12 h-12 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
            <i class="${reg.icon} text-2xl text-blue-600 dark:text-blue-400"></i>
          </div>
          <div class="flex-1">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white">${reg.title}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">${reg.description}</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
            <p class="text-xs text-gray-500 dark:text-gray-400">Kategori</p>
            <p class="text-sm font-medium text-gray-900 dark:text-white">${reg.category}</p>
          </div>
          <div class="p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
            <p class="text-xs text-gray-500 dark:text-gray-400">Status</p>
            <span class="text-sm font-medium ${reg.status === 'active' ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400'}">
              ${reg.status === 'active' ? '✅ Aktif' : '❌ Tidak Aktif'}
            </span>
          </div>
          <div class="p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
            <p class="text-xs text-gray-500 dark:text-gray-400">Prioritas</p>
            <p class="text-sm font-medium text-gray-900 dark:text-white">#${reg.priority}</p>
          </div>
          <div class="p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
            <p class="text-xs text-gray-500 dark:text-gray-400">Jumlah Poin</p>
            <p class="text-sm font-medium text-gray-900 dark:text-white">${reg.content.split('\n').filter(line => line.trim()).length} peraturan</p>
          </div>
        </div>

        <div>
          <h4 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">📋 Daftar Peraturan</h4>
          <div class="space-y-2">
            ${reg.content.split('\n').filter(line => line.trim()).map((line, index) => `
              <div class="flex items-start gap-3 p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
                <span class="w-6 h-6 flex items-center justify-center bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 text-xs font-bold rounded-full flex-shrink-0">
                  ${index + 1}
                </span>
                <p class="text-sm text-gray-700 dark:text-gray-300">${line.replace(/^\d+\.\s*/, '')}</p>
              </div>
            `).join('')}
          </div>
        </div>
      `;

      viewModal.classList.remove('opacity-0', 'invisible');
      viewModal.querySelector('.relative').classList.remove('scale-95');
      viewModal.querySelector('.relative').classList.add('scale-100');
      document.body.style.overflow = 'hidden';
    }
    window.viewRegulation = viewRegulation;

    function closeViewModal() {
      viewModal.classList.add('opacity-0', 'invisible');
      viewModal.querySelector('.relative').classList.remove('scale-100');
      viewModal.querySelector('.relative').classList.add('scale-95');
      document.body.style.overflow = '';
    }
    window.closeViewModal = closeViewModal;

    // ============================================================
    // EDIT REGULATION
    // ============================================================
    function editRegulation(id) {
      const reg = regulationsData.find(r => r.id === id);
      if (!reg) return;

      editingId = id;
      modalTitle.textContent = 'Edit Regulasi';
      submitText.textContent = 'Update';
      
      document.getElementById('regulationTitle').value = reg.title;
      document.getElementById('regulationDescription').value = reg.description;
      document.getElementById('regulationCategory').value = reg.category;
      document.getElementById('regulationStatus').value = reg.status;
      document.getElementById('regulationPriority').value = reg.priority;
      document.getElementById('regulationIcon').value = reg.icon;
      document.getElementById('regulationContent').value = reg.content;
      
      openModal();
    }
    window.editRegulation = editRegulation;

    // ============================================================
    // DELETE REGULATION
    // ============================================================
    function deleteRegulation(id) {
      if (!confirm('Yakin ingin menghapus regulasi ini?')) return;
      
      const row = document.querySelector(`tr[data-id="${id}"]`);
      if (row) {
        row.style.transform = 'scale(0.9)';
        row.style.opacity = '0';
        setTimeout(() => {
          row.remove();
          showToast('Regulasi berhasil dihapus!');
          updateStats();
        }, 300);
      }
    }
    window.deleteRegulation = deleteRegulation;

    // ============================================================
    // UPDATE STATISTICS
    // ============================================================
    function updateStats() {
      const rows = document.querySelectorAll('tbody tr');
      const total = rows.length;
      const active = document.querySelectorAll('tbody tr .text-green-700').length;
      const categories = new Set();
      rows.forEach(row => {
        const cat = row.querySelectorAll('td')[2]?.textContent?.trim();
        if (cat) categories.add(cat);
      });
      
      const statCards = document.querySelectorAll('.grid-cols-1.sm\\:grid-cols-2 .bg-white');
      if (statCards.length >= 4) {
        const totalCount = statCards[0].querySelector('.text-2xl');
        if (totalCount) totalCount.textContent = total;
        
        const activeCount = statCards[1].querySelector('.text-2xl');
        if (activeCount) activeCount.textContent = active;
        
        const categoryCount = statCards[2].querySelector('.text-2xl');
        if (categoryCount) categoryCount.textContent = categories.size;
      }
    }

    // ============================================================
    // FORM SUBMISSION
    // ============================================================
    regulationForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const title = document.getElementById('regulationTitle').value.trim();
      const description = document.getElementById('regulationDescription').value.trim();
      const category = document.getElementById('regulationCategory').value;
      const status = document.getElementById('regulationStatus').value;
      const priority = document.getElementById('regulationPriority').value;
      const icon = document.getElementById('regulationIcon').value;
      const content = document.getElementById('regulationContent').value.trim();
      
      if (!title || !description || !category || !priority || !content) {
        showToast('⚠️ Mohon lengkapi semua field yang wajib diisi');
        return;
      }

      // Simulate save
      showToast(editingId ? '✅ Regulasi berhasil diupdate!' : '✅ Regulasi berhasil ditambahkan!');
      
      setTimeout(() => {
        closeModal();
        setTimeout(() => location.reload(), 500);
      }, 1000);
    });

    // ============================================================
    // SEARCH
    // ============================================================
    const searchInput = document.getElementById('searchInput');
    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      const rows = document.querySelectorAll('tbody tr');
      
      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(query) ? '' : 'none';
      });
    });

    // ============================================================
    // TOAST
    // ============================================================
    function showToast(message) {
      const toast = document.getElementById('toast');
      const toastMessage = document.getElementById('toast-message');
      
      if (toast && toastMessage) {
        toastMessage.textContent = message;
        toast.classList.remove('translate-y-full', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
        
        setTimeout(hideToast, 3000);
      }
    }
    window.showToast = showToast;

    function hideToast() {
      const toast = document.getElementById('toast');
      if (toast) {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('translate-y-full', 'opacity-0');
      }
    }
    window.hideToast = hideToast;

    // ============================================================
    // KEYBOARD SHORTCUTS
    // ============================================================
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeModal();
        closeViewModal();
      }
    });

    console.log('✅ Regulasi Admin Panel loaded');
  </script>
</AdminLayout>