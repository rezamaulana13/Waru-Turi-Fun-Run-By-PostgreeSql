---
// src/pages/admin/about/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, aboutContent } from '../../../db/index.js';
import { eq, asc } from 'drizzle-orm';

// ===== CEK AUTH ADMIN =====
const token = Astro.cookies.get('token')?.value;
let isAdmin = false;

if (token) {
  const { verifyToken } = await import('../../../lib/auth.js');
  const decoded = verifyToken(token);
  if (decoded && typeof decoded !== 'string') {
    const { users } = await import('../../../db/schema.js');
    const user = await db.select().from(users).where(eq(users.id, decoded.id));
    if (user && user.length > 0 && (user[0].role === 'admin' || user[0].role === 'super_admin')) {
      isAdmin = true;
    }
  }
}

if (!isAdmin) {
  return Astro.redirect('/auth/login');
}

// ===== AMBIL DATA =====
let aboutData = [];
let editData = null;
const editId = Astro.url.searchParams.get('edit');

try {
  aboutData = await db.select().from(aboutContent).orderBy(asc(aboutContent.section), asc(aboutContent.order));
  
  if (editId) {
    const result = await db.select().from(aboutContent).where(eq(aboutContent.id, parseInt(editId)));
    if (result.length > 0) {
      editData = result[0];
    }
  }
} catch (error) {
  console.error('Error fetching about data:', error);
}

const sectionOptions = ['hero', 'about', 'visi_misi', 'organizer', 'stats', 'benefits', 'event_info', 'prices'];
const isEdit = editData !== null;
---

<AdminLayout title="Kelola About - Waru Turi Fun Run">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
          <i class="bi bi-info-circle text-blue-600 mr-2"></i>
          Kelola Halaman About
        </h1>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          Kelola semua konten halaman About (Hero, About, Visi Misi, dll)
        </p>
      </div>
      <div class="flex gap-3">
        <a href="/about" target="_blank" class="px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 transition text-sm flex items-center gap-2">
          <i class="bi bi-eye"></i> Preview
        </a>
      </div>
    </div>

    <!-- Alert -->
    <div id="alert" class="hidden rounded-lg p-4 mb-4 text-sm"></div>

    <!-- ===== FORM TAMBAH / EDIT ===== -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden mb-6">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
          <i class="bi bi-plus-lg text-blue-600 mr-2"></i>
          Tambah Konten Baru
        </h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Isi form di bawah untuk menambahkan konten baru</p>
      </div>
      <div class="p-6">
        <form id="aboutForm" class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <input type="hidden" id="editId" value="" />

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Section <span class="text-red-500">*</span></label>
            <select id="formSection" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-sm focus:ring-2 focus:ring-blue-500">
              {sectionOptions.map(s => (
                <option value={s}>{s}</option>
              ))}
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Key <span class="text-red-500">*</span></label>
            <input type="text" id="formKey" placeholder="Contoh: title, description" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-sm" />
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Value</label>
            <textarea id="formValue" rows="3" placeholder="Isi konten..." class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-sm resize-none"></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Image URL (opsional)</label>
            <input type="text" id="formImage" placeholder="https://example.com/image.jpg" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-sm" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Order (urutan tampilan)</label>
            <input type="number" id="formOrder" value="0" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-sm" />
          </div>

          <div class="md:col-span-2 flex gap-3">
            <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center gap-2">
              <i class="bi bi-save"></i>
              Simpan Konten
            </button>
            <button type="reset" class="px-6 py-2 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-300 transition">
              <i class="bi bi-arrow-counterclockwise"></i> Reset
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- ===== TABEL DATA ===== -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">
            <i class="bi bi-table text-blue-600 mr-2"></i>
            Semua Konten About
          </h2>
          <p class="text-sm text-gray-500 dark:text-gray-400">Total {aboutData.length} konten</p>
        </div>
        <div class="flex items-center gap-2">
          <input 
            type="text" 
            id="searchInput" 
            placeholder="Cari konten..." 
            class="px-3 py-1.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-sm focus:ring-2 focus:ring-blue-500"
          />
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-700/50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Section</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Key</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Value</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-700" id="tableBody">
            {aboutData.length === 0 ? (
              <tr>
                <td colspan="4" class="px-4 py-8 text-center text-gray-500">
                  <i class="bi bi-inbox text-3xl block mb-2"></i>
                  Belum ada konten. Silakan tambahkan melalui form di atas.
                </td>
              </tr>
            ) : (
              aboutData.map((item: any) => (
                <tr key={item.id} class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition">
                  <td class="px-4 py-3">
                    <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">
                      {item.section}
                    </span>
                  </td>
                  <td class="px-4 py-3 font-medium text-gray-900 dark:text-white">{item.key}</td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-400 max-w-xs truncate">
                    {item.value || item.imageUrl || '-'}
                  </td>
                  <td class="px-4 py-3 text-center">
                    <div class="flex items-center justify-center gap-1">
                      <a href={"/admin/about?edit=" + item.id} class="p-1.5 text-green-600 hover:bg-green-50 rounded-lg transition" title="Edit">
                        <i class="bi bi-pencil text-sm"></i>
                      </a>
                      <button class="delete-btn p-1.5 text-red-600 hover:bg-red-50 rounded-lg transition" data-id={item.id} title="Hapus">
                        <i class="bi bi-trash3 text-sm"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    // ============================================================
    // SHOW ALERT
    // ============================================================
    function showAlert(type, message) {
      const el = document.getElementById('alert');
      el.classList.remove('hidden', 'bg-green-50', 'bg-red-50', 'text-green-700', 'text-red-700');
      if (type === 'success') {
        el.className = 'rounded-lg p-4 bg-green-50 border border-green-200 text-green-700 text-sm';
      } else {
        el.className = 'rounded-lg p-4 bg-red-50 border border-red-200 text-red-700 text-sm';
      }
      el.textContent = message;
      el.classList.remove('hidden');
      setTimeout(() => el.classList.add('hidden'), 4000);
    }

    // ============================================================
    // DELETE
    // ============================================================
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const id = this.dataset.id;
        if (!confirm('Yakin ingin menghapus konten ini?')) return;
        
        try {
          const res = await fetch('/api/admin/about?id=' + id, { method: 'DELETE' });
          const result = await res.json();
          if (result.success) {
            showAlert('success', '✅ Konten berhasil dihapus!');
            setTimeout(() => location.reload(), 800);
          } else {
            showAlert('error', '❌ Gagal: ' + (result.error || ''));
          }
        } catch (e) {
          showAlert('error', '❌ Error: ' + e.message);
        }
      });
    });

    // ============================================================
    // FORM SUBMIT (TAMBAH)
    // ============================================================
    document.getElementById('aboutForm')?.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const data = {
        section: document.getElementById('formSection').value,
        key: document.getElementById('formKey').value.trim(),
        value: document.getElementById('formValue').value.trim(),
        imageUrl: document.getElementById('formImage').value.trim(),
        order: parseInt(document.getElementById('formOrder').value) || 0,
      };

      if (!data.key) {
        showAlert('error', '⚠️ Key / Nama konten wajib diisi!');
        return;
      }

      const btn = this.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Menyimpan...';

      try {
        const res = await fetch('/api/admin/about', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        const result = await res.json();
        
        if (result.success) {
          showAlert('success', '✅ Konten berhasil ditambahkan!');
          setTimeout(() => location.reload(), 800);
        } else {
          showAlert('error', '❌ Gagal: ' + (result.error || ''));
          btn.disabled = false;
          btn.innerHTML = 'Simpan Konten';
        }
      } catch (e) {
        showAlert('error', '❌ Error: ' + e.message);
        btn.disabled = false;
        btn.innerHTML = 'Simpan Konten';
      }
    });

    // ============================================================
    // SEARCH
    // ============================================================
    document.getElementById('searchInput')?.addEventListener('input', function(e) {
      const search = e.target.value.toLowerCase();
      const rows = document.querySelectorAll('#tableBody tr');
      rows.forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(search) ? '' : 'none';
      });
    });
  </script>
</AdminLayout>