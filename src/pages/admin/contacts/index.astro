// Helper function untuk format tanggal
function formatDate(date: string): string {
  return new Date(date).toLocaleDateString('id-ID', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}

// Helper function untuk get status color
function getStatusColor(status: string): string {
  const colors: Record<string, string> = {
    read: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
    unread: 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400',
    replied: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400',
  };
  return colors[status] || 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400';
}

// Helper function untuk get status label
function getStatusLabel(status: string): string {
  const labels: Record<string, string> = {
    read: 'Sudah Dibaca',
    unread: 'Belum Dibaca',
    replied: 'Sudah Dibalas',
  };
  return labels[status] || status;
}

// Helper function untuk get priority color
function getPriorityColor(priority: string): string {
  const colors: Record<string, string> = {
    high: 'text-red-600 dark:text-red-400',
    medium: 'text-yellow-600 dark:text-yellow-400',
    low: 'text-green-600 dark:text-green-400',
  };
  return colors[priority] || 'text-gray-600 dark:text-gray-400';
}

// Helper function untuk get priority label
function getPriorityLabel(priority: string): string {
  const labels: Record<string, string> = {
    high: 'Tinggi',
    medium: 'Sedang',
    low: 'Rendah',
  };
  return labels[priority] || priority;
}
---

<AdminLayout title="Kontak - Admin Panel">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <div>
          <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">
            <i class="bi bi-envelope text-blue-600 dark:text-blue-400 mr-2"></i>
            Manajemen Kontak
          </h1>
          <p class="text-gray-500 dark:text-gray-400 mt-1">
            Kelola pesan dan kontak dari pengunjung
          </p>
        </div>
        <div class="flex gap-3">
          <button class="px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition flex items-center gap-2">
            <i class="bi bi-download"></i>
            Export
          </button>
          <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center gap-2">
            <i class="bi bi-check-all"></i>
            Tandai Semua Dibaca
          </button>
        </div>
      </div>
    </div>

    <!-- Filter & Search -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4 mb-6">
      <div class="flex flex-col md:flex-row gap-4">
        <div class="flex-1 relative">
          <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500"></i>
          <input 
            type="text" 
            placeholder="Cari kontak..." 
            class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            id="searchInput"
          />
        </div>
        <div class="flex gap-3">
          <select class="px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            <option value="">Semua Status</option>
            <option value="unread">Belum Dibaca</option>
            <option value="read">Sudah Dibaca</option>
            <option value="replied">Sudah Dibalas</option>
          </select>
          <select class="px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            <option value="">Semua Prioritas</option>
            <option value="high">Tinggi</option>
            <option value="medium">Sedang</option>
            <option value="low">Rendah</option>
          </select>
          <select class="px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            <option value="">Semua Kategori</option>
            <option value="Pendaftaran">Pendaftaran</option>
            <option value="Sponsor">Sponsor</option>
            <option value="Teknis">Teknis</option>
            <option value="Saran">Saran</option>
            <option value="Informasi">Informasi</option>
            <option value="Kerjasama">Kerjasama</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Total Pesan</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">{contacts.length}</p>
          </div>
          <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-envelope text-2xl text-blue-600 dark:text-blue-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-green-600 dark:text-green-400">↑ 2 pesan baru</span>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Belum Dibaca</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">
              {contacts.filter(c => c.status === 'unread').length}
            </p>
          </div>
          <div class="w-12 h-12 bg-red-100 dark:bg-red-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-envelope-exclamation text-2xl text-red-600 dark:text-red-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-red-500 dark:text-red-400">Perlu perhatian</span>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Sudah Dibalas</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">
              {contacts.filter(c => c.response).length}
            </p>
          </div>
          <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-check-circle text-2xl text-green-600 dark:text-green-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-gray-500 dark:text-gray-400">Sudah ditangani</span>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Prioritas Tinggi</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">
              {contacts.filter(c => c.priority === 'high').length}
            </p>
          </div>
          <div class="w-12 h-12 bg-yellow-100 dark:bg-yellow-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-exclamation-triangle text-2xl text-yellow-600 dark:text-yellow-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-yellow-600 dark:text-yellow-400">Perlu segera ditangani</span>
        </div>
      </div>
    </div>

    <!-- Contacts List -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-200/50 dark:border-gray-700/50">
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                <input type="checkbox" class="rounded border-gray-300 dark:border-gray-600" />
              </th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Pengirim</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Subjek</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Kategori</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Prioritas</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tanggal</th>
              <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200/50 dark:divide-gray-700/50">
            {contacts.map((contact) => (
              <tr class={`hover:bg-gray-50 dark:hover:bg-gray-700/50 transition ${contact.status === 'unread' ? 'bg-blue-50/50 dark:bg-blue-900/5' : ''}`} data-id={contact.id}>
                <td class="px-6 py-4">
                  <input type="checkbox" class="rounded border-gray-300 dark:border-gray-600" />
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 text-white flex items-center justify-center text-sm font-bold">
                      {contact.name.charAt(0)}
                    </div>
                    <div>
                      <p class="text-sm font-medium text-gray-900 dark:text-white">
                        {contact.name}
                        {contact.status === 'unread' && (
                          <span class="ml-2 inline-block w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
                        )}
                      </p>
                      <p class="text-xs text-gray-500 dark:text-gray-400">{contact.email}</p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <p class="text-sm text-gray-700 dark:text-gray-300 font-medium line-clamp-1">
                    {contact.subject}
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-1">
                    {contact.message.substring(0, 50)}...
                  </p>
                </td>
                <td class="px-6 py-4">
                  <span class="px-2.5 py-1 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 text-xs font-medium rounded-full">
                    {contact.category}
                  </span>
                </td>
                <td class="px-6 py-4">
                  <span class={`
                    px-2.5 py-1 text-xs font-medium rounded-full
                    ${getStatusColor(contact.status)}
                  `}>
                    {getStatusLabel(contact.status)}
                  </span>
                </td>
                <td class="px-6 py-4">
                  <span class={`text-sm font-medium ${getPriorityColor(contact.priority)}`}>
                    {getPriorityLabel(contact.priority)}
                  </span>
                </td>
                <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-300">
                  {formatDate(contact.createdAt)}
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    <button onclick="viewContact('{contact.id}')" class="p-1.5 text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition" title="Lihat">
                      <i class="bi bi-eye"></i>
                    </button>
                    <button onclick="replyContact('{contact.id}')" class="p-1.5 text-green-600 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-lg transition" title="Balas">
                      <i class="bi bi-reply"></i>
                    </button>
                    <button onclick="deleteContact('{contact.id}')" class="p-1.5 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition" title="Hapus">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="px-6 py-4 border-t border-gray-200/50 dark:border-gray-700/50 flex items-center justify-between flex-wrap gap-3">
        <p class="text-sm text-gray-500 dark:text-gray-400">
          Menampilkan <span class="font-medium">1</span> - <span class="font-medium">{Math.min(10, contacts.length)}</span> dari <span class="font-medium">{contacts.length}</span> data
        </p>
        <div class="flex items-center gap-2">
          <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition disabled:opacity-50" disabled>
            <i class="bi bi-chevron-left"></i>
          </button>
          <button class="px-3 py-1.5 rounded-lg bg-blue-600 text-white">1</button>
          <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">2</button>
          <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">3</button>
          <span class="text-gray-500 dark:text-gray-400">...</span>
          <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">10</button>
          <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
            <i class="bi bi-chevron-right"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal View Contact -->
  <div id="viewModal" class="fixed inset-0 z-50 flex items-center justify-center px-4 opacity-0 invisible transition-all duration-300">
    <div class="absolute inset-0 bg-black/50" onclick="closeViewModal()"></div>
    <div class="relative bg-white dark:bg-gray-800 rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl transform scale-95 transition-all duration-300">
      <div class="sticky top-0 bg-white dark:bg-gray-800 z-10 px-6 py-4 border-b border-gray-200/50 dark:border-gray-700/50 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
          <i class="bi bi-envelope-open text-blue-600 dark:text-blue-400 mr-2"></i>
          Detail Pesan
        </h3>
        <button onclick="closeViewModal()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      
      <div class="p-6" id="viewContent">
        <!-- Content akan diisi oleh JavaScript -->
      </div>
    </div>
  </div>

  <!-- Modal Reply Contact -->
  <div id="replyModal" class="fixed inset-0 z-50 flex items-center justify-center px-4 opacity-0 invisible transition-all duration-300">
    <div class="absolute inset-0 bg-black/50" onclick="closeReplyModal()"></div>
    <div class="relative bg-white dark:bg-gray-800 rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl transform scale-95 transition-all duration-300">
      <div class="sticky top-0 bg-white dark:bg-gray-800 z-10 px-6 py-4 border-b border-gray-200/50 dark:border-gray-700/50 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
          <i class="bi bi-reply text-green-600 dark:text-green-400 mr-2"></i>
          Balas Pesan
        </h3>
        <button onclick="closeReplyModal()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      
      <form id="replyForm" class="p-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Kepada
          </label>
          <input 
            type="text" 
            id="replyTo"
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            disabled
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Subjek
          </label>
          <input 
            type="text" 
            id="replySubject"
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Pesan Balasan <span class="text-red-500">*</span>
          </label>
          <textarea 
            id="replyMessage"
            rows="6" 
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"
            placeholder="Tulis balasan Anda di sini..."
            required
          ></textarea>
        </div>

        <div class="flex items-center gap-3">
          <input type="checkbox" id="markAsRead" checked class="rounded border-gray-300 dark:border-gray-600" />
          <label for="markAsRead" class="text-sm text-gray-700 dark:text-gray-300">
            Tandai sebagai sudah dibaca
          </label>
        </div>

        <div class="flex justify-end gap-3">
          <button type="button" onclick="closeReplyModal()" class="px-6 py-2 border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">
            Batal
          </button>
          <button type="submit" class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition flex items-center gap-2">
            <i class="bi bi-send"></i>
            Kirim Balasan
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="fixed bottom-6 right-6 bg-gray-900 dark:bg-gray-800 text-white px-6 py-4 rounded-xl shadow-lg transform translate-y-full opacity-0 transition-all duration-300 flex items-center gap-3 z-50">
    <i class="bi bi-check-circle-fill text-green-400"></i>
    <span id="toast-message">Pesan berhasil dihapus!</span>
    <button onclick="hideToast()" class="text-gray-400 hover:text-white transition">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>

  <script>
    // ============================================================
    // CONTACT DATA
    // ============================================================
    const contactsData = [
      { id: '1', name: 'Ahmad Fauzi', email: 'ahmad.fauzi@email.com', subject: 'Pertanyaan Pendaftaran', message: 'Assalamualaikum, saya ingin bertanya tentang prosedur pendaftaran untuk kategori Half Marathon...', status: 'unread', priority: 'high', category: 'Pendaftaran', createdAt: '2026-07-10 14:30:00' },
      { id: '2', name: 'Siti Rahma', email: 'siti.rahma@email.com', subject: 'Informasi Sponsor', message: 'Selamat siang. Perusahaan kami tertarik untuk menjadi sponsor...', status: 'read', priority: 'medium', category: 'Sponsor', createdAt: '2026-07-09 10:15:00' },
    ];

    // ============================================================
    // VIEW CONTACT
    // ============================================================
    function viewContact(id) {
      const contact = contactsData.find(c => c.id === id);
      if (!contact) return;

      const content = document.getElementById('viewContent');
      content.innerHTML = `
        <div class="space-y-4">
          <!-- Header -->
          <div class="flex items-start justify-between">
            <div>
              <h4 class="text-lg font-bold text-gray-900 dark:text-white">${contact.subject}</h4>
              <p class="text-sm text-gray-500 dark:text-gray-400">Dari: ${contact.name} (${contact.email})</p>
            </div>
            <div class="flex gap-2">
              <span class="px-2.5 py-1 text-xs font-medium rounded-full ${getStatusColor(contact.status)}">
                ${getStatusLabel(contact.status)}
              </span>
              <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
                ${contact.category}
              </span>
            </div>
          </div>

          <!-- Priority & Date -->
          <div class="flex items-center gap-4 text-sm">
            <span class="flex items-center gap-1">
              <i class="bi bi-flag-fill ${getPriorityColor(contact.priority)}"></i>
              Prioritas: ${getPriorityLabel(contact.priority)}
            </span>
            <span class="text-gray-500 dark:text-gray-400">
              <i class="bi bi-clock mr-1"></i>
              ${formatDate(contact.createdAt)}
            </span>
          </div>

          <!-- Message -->
          <div class="p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
            <p class="text-gray-700 dark:text-gray-300 whitespace-pre-wrap">${contact.message}</p>
          </div>

          <!-- Response -->
          ${contact.response ? `
            <div>
              <h5 class="text-sm font-semibold text-green-600 dark:text-green-400 mb-2">
                <i class="bi bi-reply mr-1"></i>
                Balasan:
              </h5>
              <div class="p-4 bg-green-50 dark:bg-green-900/10 rounded-lg border border-green-200 dark:border-green-800">
                <p class="text-gray-700 dark:text-gray-300">${contact.response}</p>
              </div>
            </div>
          ` : `
            <div class="flex justify-end">
              <button onclick="replyContact('${contact.id}')" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition flex items-center gap-2">
                <i class="bi bi-reply"></i>
                Balas Pesan
              </button>
            </div>
          `}
        </div>
      `;

      viewModal.classList.remove('opacity-0', 'invisible');
      viewModal.querySelector('.relative').classList.remove('scale-95');
      viewModal.querySelector('.relative').classList.add('scale-100');
      document.body.style.overflow = 'hidden';
    }
    window.viewContact = viewContact;

    function closeViewModal() {
      viewModal.classList.add('opacity-0', 'invisible');
      viewModal.querySelector('.relative').classList.remove('scale-100');
      viewModal.querySelector('.relative').classList.add('scale-95');
      document.body.style.overflow = '';
    }
    window.closeViewModal = closeViewModal;

    // ============================================================
    // REPLY CONTACT
    // ============================================================
    let replyContactId = null;

    function replyContact(id) {
      const contact = contactsData.find(c => c.id === id);
      if (!contact) return;

      replyContactId = id;
      document.getElementById('replyTo').value = `${contact.name} <${contact.email}>`;
      document.getElementById('replySubject').value = `Re: ${contact.subject}`;
      document.getElementById('replyMessage').value = '';
      document.getElementById('markAsRead').checked = true;

      replyModal.classList.remove('opacity-0', 'invisible');
      replyModal.querySelector('.relative').classList.remove('scale-95');
      replyModal.querySelector('.relative').classList.add('scale-100');
      document.body.style.overflow = 'hidden';
    }
    window.replyContact = replyContact;

    function closeReplyModal() {
      replyModal.classList.add('opacity-0', 'invisible');
      replyModal.querySelector('.relative').classList.remove('scale-100');
      replyModal.querySelector('.relative').classList.add('scale-95');
      document.body.style.overflow = '';
      replyContactId = null;
    }
    window.closeReplyModal = closeReplyModal;

    // Reply Form Submit
    document.getElementById('replyForm')?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const message = document.getElementById('replyMessage').value.trim();
      if (!message) {
        showToast('⚠️ Mohon tulis balasan Anda');
        return;
      }

      showToast('✅ Balasan berhasil dikirim!');
      
      setTimeout(() => {
        closeReplyModal();
        // Update status in table
        if (replyContactId) {
          const row = document.querySelector(`tr[data-id="${replyContactId}"]`);
          if (row) {
            const statusCell = row.querySelectorAll('td')[4];
            if (statusCell) {
              statusCell.innerHTML = `
                <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400">
                  Sudah Dibalas
                </span>
              `;
            }
          }
        }
      }, 1000);
    });

    // ============================================================
    // DELETE CONTACT
    // ============================================================
    function deleteContact(id) {
      if (!confirm('Yakin ingin menghapus pesan ini?')) return;
      
      const row = document.querySelector(`tr[data-id="${id}"]`);
      if (row) {
        row.style.transform = 'scale(0.9)';
        row.style.opacity = '0';
        setTimeout(() => {
          row.remove();
          showToast('Pesan berhasil dihapus!');
          updateStats();
        }, 300);
      }
    }
    window.deleteContact = deleteContact;

    // ============================================================
    // UPDATE STATISTICS
    // ============================================================
    function updateStats() {
      const rows = document.querySelectorAll('tbody tr');
      const total = rows.length;
      const unread = document.querySelectorAll('tbody tr .bg-red-100').length;
      const replied = document.querySelectorAll('tbody tr .bg-blue-100').length;
      const high = document.querySelectorAll('tbody tr .text-red-600').length;
      
      const statCards = document.querySelectorAll('.grid-cols-1.sm\\:grid-cols-2 .bg-white');
      if (statCards.length >= 4) {
        const totalCount = statCards[0].querySelector('.text-2xl');
        if (totalCount) totalCount.textContent = total;
        
        const unreadCount = statCards[1].querySelector('.text-2xl');
        if (unreadCount) unreadCount.textContent = unread;
        
        const repliedCount = statCards[2].querySelector('.text-2xl');
        if (repliedCount) repliedCount.textContent = replied;
        
        const highCount = statCards[3].querySelector('.text-2xl');
        if (highCount) highCount.textContent = high;
      }
    }

    // ============================================================
    // SEARCH
    // ============================================================
    const searchInput = document.getElementById('searchInput');
    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      const rows = document.querySelectorAll('tbody tr');
      
      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(query) ? '' : 'none';
      });
    });

    // ============================================================
    // TOAST
    // ============================================================
    function showToast(message) {
      const toast = document.getElementById('toast');
      const toastMessage = document.getElementById('toast-message');
      
      if (toast && toastMessage) {
        toastMessage.textContent = message;
        toast.classList.remove('translate-y-full', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
        
        setTimeout(hideToast, 3000);
      }
    }
    window.showToast = showToast;

    function hideToast() {
      const toast = document.getElementById('toast');
      if (toast) {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('translate-y-full', 'opacity-0');
      }
    }
    window.hideToast = hideToast;

    // ============================================================
    // KEYBOARD SHORTCUTS
    // ============================================================
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeViewModal();
        closeReplyModal();
      }
    });

    // ============================================================
    // GET COLOR FUNCTIONS
    // ============================================================
    function getStatusColor(status) {
      const colors = {
        read: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
        unread: 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400',
        replied: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400',
      };
      return colors[status] || 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400';
    }

    function getStatusLabel(status) {
      const labels = {
        read: 'Sudah Dibaca',
        unread: 'Belum Dibaca',
        replied: 'Sudah Dibalas',
      };
      return labels[status] || status;
    }

    function getPriorityColor(priority) {
      const colors = {
        high: 'text-red-600 dark:text-red-400',
        medium: 'text-yellow-600 dark:text-yellow-400',
        low: 'text-green-600 dark:text-green-400',
      };
      return colors[priority] || 'text-gray-600 dark:text-gray-400';
    }

    function getPriorityLabel(priority) {
      const labels = {
        high: 'Tinggi',
        medium: 'Sedang',
        low: 'Rendah',
      };
      return labels[priority] || priority;
    }

    function formatDate(date) {
      return new Date(date).toLocaleDateString('id-ID', {
        day: '2-digit',
        month: 'long',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
      });
    }

    console.log('✅ Kontak Admin Panel loaded');
  </script>
</AdminLayout>