---
// src/pages/admin/contacts/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, contactMessages } from '../../../db/index.js';
import { desc } from 'drizzle-orm';

let list: any[] = [];
let loadError = false;

try {
  list = await db.select().from(contactMessages).orderBy(desc(contactMessages.createdAt));
} catch (err) {
  console.error('Gagal memuat contact_messages:', err);
  loadError = true;
}

const counts = {
  semua: list.length,
  unread: list.filter((m) => m.status === 'unread').length,
  read: list.filter((m) => m.status === 'read').length,
  replied: list.filter((m) => m.status === 'replied').length,
};

const statusLabel: Record<string, string> = {
  unread: 'Masuk',
  read: 'Dibaca',
  replied: 'Selesai',
};

function formatDate(d: Date | string | null) {
  if (!d) return '-';
  return new Date(d).toLocaleString('id-ID', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}
---

<AdminLayout title="Kontak - Admin Waru Turi Run">
  <div class="wt-page">
    <div class="wt-page-head">
      <div>
        <span class="wt-eyebrow">Kotak Masuk</span>
        <h1 class="wt-title">Pesan Kontak</h1>
        <p class="wt-subtitle">Setiap pesan dari halaman /kontak melewati tiga tahap: Masuk, Dibaca, lalu Selesai.</p>
      </div>
    </div>

    {loadError && (
      <div class="wt-alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>Gagal memuat pesan dari database. Cek koneksi <code>DATABASE_URL</code> dan tabel <code>contact_messages</code>.</span>
      </div>
    )}

    <div class="wt-tabs" role="tablist">
      <button class="wt-tab active" data-filter="semua">
        <span>Semua</span><b>{counts.semua}</b>
      </button>
      <button class="wt-tab" data-filter="unread">
        <span class="dot dot-unread"></span><span>Masuk</span><b>{counts.unread}</b>
      </button>
      <button class="wt-tab" data-filter="read">
        <span class="dot dot-read"></span><span>Dibaca</span><b>{counts.read}</b>
      </button>
      <button class="wt-tab" data-filter="replied">
        <span class="dot dot-replied"></span><span>Selesai</span><b>{counts.replied}</b>
      </button>
    </div>

    <div class="wt-inbox" id="inbox">
      <div class="wt-list" id="messageList">
        {list.length === 0 && (
          <div class="wt-empty">
            <i class="bi bi-inbox"></i>
            <p>Belum ada pesan masuk.</p>
          </div>
        )}
        {list.map((m) => (
          <button
            class="wt-item"
            data-id={m.id}
            data-status={m.status}
            data-name={m.name}
            data-email={m.email}
            data-phone={m.phone ?? ''}
            data-subject={m.subject}
            data-message={m.message}
            data-reply={m.adminReply ?? ''}
            data-replied-by={m.repliedBy ?? ''}
            data-date={formatDate(m.createdAt)}
          >
            <span class={`wt-item-bar bar-${m.status}`}></span>
            <span class="wt-item-body">
              <span class="wt-item-top">
                <span class="wt-item-name">{m.name}</span>
                <span class={`wt-badge badge-${m.status}`}>
                  {m.status === 'replied' && <i class="bi bi-flag-fill"></i>}
                  {statusLabel[m.status ?? 'unread']}
                </span>
              </span>
              <span class="wt-item-subject">{m.subject}</span>
              <span class="wt-item-date">{formatDate(m.createdAt)}</span>
            </span>
          </button>
        ))}
      </div>

      <div class="wt-detail" id="messageDetail">
        <div class="wt-detail-empty">
          <i class="bi bi-envelope-open"></i>
          <p>Pilih pesan di sebelah kiri untuk melihat detail.</p>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<style is:global>
  :root {
    --wt-navy: #0b1f3a;
    --wt-blue: #2679ec;
    --wt-blue-deep: #144fba;
    --wt-gold: #f5b300;
    --wt-gold-deep: #c98e00;
    --wt-rose: #e23f5d;
    --wt-amber: #d97706;
    --wt-mist: #f3f6fb;
    --wt-line: #e4e9f2;
    --wt-ink: #0b1f3a;
    --wt-ink-soft: #5b6577;
  }
  .dark {
    --wt-mist: #16202f;
    --wt-line: #2a3648;
    --wt-ink: #eef2fa;
    --wt-ink-soft: #93a0b4;
  }

  .wt-page { color: var(--wt-ink); }

  .wt-page-head { margin-bottom: 20px; }
  .wt-eyebrow {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--wt-blue);
    margin-bottom: 6px;
  }
  .wt-title {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin: 0 0 4px 0;
  }
  .wt-subtitle {
    font-size: 0.85rem;
    color: var(--wt-ink-soft);
    margin: 0;
    max-width: 480px;
  }

  .wt-alert {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: rgba(226, 63, 93, 0.08);
    border: 1px solid rgba(226, 63, 93, 0.25);
    color: var(--wt-rose);
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 0.85rem;
    margin-bottom: 18px;
  }
  .wt-alert i { margin-top: 2px; }

  .wt-tabs {
    display: flex;
    gap: 6px;
    background: var(--wt-mist);
    border: 1px solid var(--wt-line);
    border-radius: 14px;
    padding: 5px;
    margin-bottom: 18px;
    overflow-x: auto;
  }
  .wt-tab {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 14px;
    border-radius: 10px;
    border: none;
    background: transparent;
    color: var(--wt-ink-soft);
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .wt-tab:hover { color: var(--wt-ink); }
  .wt-tab.active {
    background: #fff;
    color: var(--wt-navy);
    box-shadow: 0 2px 8px rgba(11, 31, 58, 0.1);
  }
  .dark .wt-tab.active { background: #0b1f3a; color: #eef2fa; }
  .wt-tab b {
    font-variant-numeric: tabular-nums;
    font-size: 0.72rem;
    background: rgba(11, 31, 58, 0.06);
    padding: 1px 7px;
    border-radius: 20px;
  }
  .dark .wt-tab b { background: rgba(255, 255, 255, 0.08); }
  .wt-tab.active b { background: rgba(38, 121, 236, 0.12); color: var(--wt-blue); }

  .dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .dot-unread { background: var(--wt-rose); }
  .dot-read { background: var(--wt-amber); }
  .dot-replied { background: var(--wt-gold); }

  .wt-inbox {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 18px;
    align-items: start;
  }

  .wt-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 72vh;
    overflow-y: auto;
    padding-right: 4px;
  }

  .wt-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 48px 20px;
    text-align: center;
    color: var(--wt-ink-soft);
    background: var(--wt-mist);
    border-radius: 16px;
    font-size: 0.85rem;
  }
  .wt-empty i { font-size: 1.6rem; opacity: 0.5; }

  .wt-item {
    position: relative;
    display: flex;
    align-items: stretch;
    text-align: left;
    background: #fff;
    border: 1px solid var(--wt-line);
    border-radius: 14px;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    font-family: inherit;
    width: 100%;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .dark .wt-item { background: #101a29; }
  .wt-item:hover { border-color: rgba(38, 121, 236, 0.35); box-shadow: 0 4px 14px rgba(11, 31, 58, 0.06); }
  .wt-item.selected { border-color: var(--wt-blue); background: rgba(38, 121, 236, 0.05); }

  .wt-item-bar { width: 4px; flex-shrink: 0; }
  .bar-unread { background: var(--wt-rose); }
  .bar-read { background: var(--wt-amber); }
  .bar-replied { background: var(--wt-gold); }

  .wt-item-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 13px 15px;
  }

  .wt-item-top { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
  .wt-item-name {
    font-weight: 700;
    font-size: 0.88rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .wt-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 8px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .badge-unread { background: rgba(226, 63, 93, 0.12); color: var(--wt-rose); }
  .badge-read { background: rgba(217, 119, 6, 0.12); color: var(--wt-amber); }
  .badge-replied {
    color: #7a5400;
    background-color: rgba(245, 179, 0, 0.18);
    background-image: repeating-conic-gradient(rgba(11,31,58,0.35) 0% 25%, transparent 0% 50%);
    background-size: 6px 6px;
  }
  .dark .badge-replied { color: #ffdf8a; }

  .wt-item-subject {
    font-size: 0.82rem;
    color: var(--wt-ink-soft);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .wt-item-date {
    font-size: 0.72rem;
    color: var(--wt-ink-soft);
    opacity: 0.75;
    font-variant-numeric: tabular-nums;
  }

  .wt-detail {
    background: #fff;
    border: 1px solid var(--wt-line);
    border-radius: 18px;
    padding: 26px;
    min-height: 420px;
  }
  .dark .wt-detail { background: #101a29; }

  .wt-detail-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-height: 360px;
    color: var(--wt-ink-soft);
    text-align: center;
    gap: 10px;
  }
  .wt-detail-empty i { font-size: 1.8rem; opacity: 0.4; }

  .wt-back {
    display: none;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    color: var(--wt-blue);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0 0 16px 0;
    cursor: pointer;
  }

  .wt-d-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 18px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--wt-line);
  }
  .wt-d-header h2 {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin: 0 0 10px 0;
    word-break: break-word;
  }

  .wt-meta-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .wt-meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    color: var(--wt-ink-soft);
    background: var(--wt-mist);
    border-radius: 20px;
    padding: 5px 11px;
    text-decoration: none;
    max-width: 100%;
  }
  .wt-meta-chip span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .wt-meta-chip i { color: var(--wt-blue); flex-shrink: 0; }
  .wt-meta-chip.is-link:hover { background: rgba(38, 121, 236, 0.1); }

  .wt-d-body {
    background: var(--wt-mist);
    border-left: 3px solid var(--wt-blue);
    border-radius: 4px 14px 14px 4px;
    padding: 16px 18px;
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 20px;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .wt-prev-reply {
    background: rgba(245, 179, 0, 0.08);
    border-left: 3px solid var(--wt-gold);
    border-radius: 4px 14px 14px 4px;
    padding: 12px 18px;
    font-size: 0.85rem;
    margin-bottom: 18px;
    word-break: break-word;
  }
  .wt-prev-reply strong {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--wt-gold-deep);
    margin-bottom: 5px;
  }

  .wt-reply-box { margin-top: 4px; }
  .wt-reply-box label {
    display: block;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--wt-ink-soft);
    margin-bottom: 8px;
  }
  .wt-reply-box textarea {
    display: block;
    width: 100%;
    min-height: 120px;
    padding: 13px 16px;
    border: 2px solid var(--wt-line);
    border-radius: 12px;
    font-size: 0.9rem;
    font-family: inherit;
    line-height: 1.6;
    resize: vertical;
    background: var(--wt-mist);
    color: var(--wt-ink);
    box-sizing: border-box;
    transition: border-color 0.15s ease;
  }
  .wt-reply-box textarea:focus {
    border-color: var(--wt-blue);
    background: #fff;
    outline: none;
  }
  .dark .wt-reply-box textarea:focus { background: #0b1420; }
  .wt-reply-box textarea.invalid { border-color: var(--wt-rose); }

  .wt-actions { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }

  .wt-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 11px 20px;
    border-radius: 11px;
    border: none;
    font-size: 0.85rem;
    font-weight: 800;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.12s ease, background 0.15s ease;
  }
  .wt-btn:active { transform: translateY(1px); }

  .wt-btn-finish {
    background: var(--wt-gold);
    color: #402c00;
    box-shadow: 0 4px 14px rgba(245, 179, 0, 0.3);
  }
  .wt-btn-finish:hover { background: var(--wt-gold-deep); }
  .wt-btn-finish:disabled { opacity: 0.5; cursor: not-allowed; box-shadow: none; }

  .wt-btn-ghost {
    background: var(--wt-mist);
    color: var(--wt-ink);
    border: 1px solid var(--wt-line);
  }
  .wt-btn-ghost:hover { background: var(--wt-line); }

  .wt-hint { font-size: 0.75rem; color: var(--wt-ink-soft); margin-top: 8px; }

  .wt-feedback {
    font-size: 0.8rem;
    margin-top: 12px;
    display: none;
    align-items: center;
    gap: 6px;
    font-weight: 700;
  }
  .wt-feedback.show { display: flex; }
  .wt-feedback.ok { color: #16a34a; }
  .wt-feedback.fail { color: var(--wt-rose); }

  @media (prefers-reduced-motion: reduce) {
    .wt-item, .wt-btn, .wt-detail { transition: none !important; }
  }

  @media (max-width: 768px) {
    .wt-inbox { display: block; }
    .wt-list { max-height: none; padding-right: 0; }
    .wt-back { display: inline-flex; }

    .wt-detail {
      position: fixed;
      inset: 0;
      z-index: 60;
      border-radius: 0;
      border: none;
      padding: 18px 16px 24px 16px;
      overflow-y: auto;
      transform: translateX(100%);
      transition: transform 0.28s ease;
      -webkit-overflow-scrolling: touch;
    }
    .wt-inbox.mobile-detail-active .wt-detail { transform: translateX(0); }
    .wt-detail-empty { display: none; }

    .wt-actions {
      position: sticky;
      bottom: -24px;
      background: #fff;
      margin: 16px -16px -24px -16px;
      padding: 14px 16px 22px 16px;
      border-top: 1px solid var(--wt-line);
    }
    .dark .wt-actions { background: #101a29; }
    .wt-actions .wt-btn { flex: 1; }
  }

  @media (max-width: 480px) {
    .wt-title { font-size: 1.3rem; }
    .wt-item-body { padding: 11px 13px; }
    .wt-d-header h2 { font-size: 1.02rem; }
  }
</style>

<script>
  const inboxEl = document.getElementById('inbox');
  const detailEl = document.getElementById('messageDetail');
  const tabs = document.querySelectorAll('.wt-tab');
  let currentFilter = 'semua';

  const statusLabel: Record<string, string> = {
    unread: 'Masuk',
    read: 'Dibaca',
    replied: 'Selesai',
  };

  const isMobile = () => window.innerWidth <= 768;

  function applyFilter() {
    document.querySelectorAll('.wt-item').forEach((el) => {
      const status = el.getAttribute('data-status');
      const show = currentFilter === 'semua' || status === currentFilter;
      (el as HTMLElement).style.display = show ? '' : 'none';
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      currentFilter = tab.getAttribute('data-filter') || 'semua';
      applyFilter();
    });
  });

  function escapeHtml(str: string) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderDetail(item: HTMLElement) {
    const id = item.getAttribute('data-id')!;
    const name = item.getAttribute('data-name')!;
    const email = item.getAttribute('data-email')!;
    const phone = item.getAttribute('data-phone') || '';
    const subject = item.getAttribute('data-subject')!;
    const message = item.getAttribute('data-message')!;
    const reply = item.getAttribute('data-reply') || '';
    const repliedBy = item.getAttribute('data-replied-by') || '';
    const date = item.getAttribute('data-date')!;
    const status = item.getAttribute('data-status')!;

    const waHref = phone ? `https://wa.me/${phone.replace(/[^0-9]/g, '')}` : '';

    const prevReplyHtml = reply
      ? `<div class="wt-prev-reply">
          <strong><i class="bi bi-flag-fill"></i> Balasan tersimpan${repliedBy ? ' &middot; ' + escapeHtml(repliedBy) : ''}</strong>
          ${escapeHtml(reply)}
        </div>`
      : '';

    detailEl!.innerHTML = `
      <button class="wt-back" id="detailBackBtn" type="button">
        <i class="bi bi-arrow-left"></i> Kembali ke daftar
      </button>

      <div class="wt-d-header">
        <div>
          <h2>${escapeHtml(subject)}</h2>
          <div class="wt-meta-row">
            <span class="wt-meta-chip"><i class="bi bi-person-fill"></i><span>${escapeHtml(name)}</span></span>
            <a class="wt-meta-chip is-link" href="mailto:${escapeHtml(email)}"><i class="bi bi-envelope-fill"></i><span>${escapeHtml(email)}</span></a>
            ${phone ? `<a class="wt-meta-chip is-link" href="${waHref}" target="_blank"><i class="bi bi-whatsapp"></i><span>${escapeHtml(phone)}</span></a>` : ''}
            <span class="wt-meta-chip"><i class="bi bi-clock-fill"></i><span>${date}</span></span>
          </div>
        </div>
        <span class="wt-badge badge-${status}" id="currentStatusBadge">${status === 'replied' ? '<i class="bi bi-flag-fill"></i>' : ''}${statusLabel[status] ?? status}</span>
      </div>

      <div class="wt-d-body">${escapeHtml(message)}</div>

      ${prevReplyHtml}

      <div class="wt-reply-box">
        <label for="replyText">Balasan Admin</label>
        <textarea id="replyText" placeholder="Tulis balasan untuk peserta ini...">${escapeHtml(reply)}</textarea>
        <p class="wt-hint" id="replyHint">1) Tekan "Tandai Selesai" buat nyimpen &amp; nutup tiket. 2) Tekan "Kirim via WhatsApp" / "Kirim via Email" buat benar-benar ngirim ke penanya.</p>
      </div>

      <div class="wt-actions">
        <button class="wt-btn wt-btn-finish" id="finishBtn">
          <i class="bi bi-flag-fill"></i> Tandai Selesai
        </button>
        ${status === 'unread' ? `<button class="wt-btn wt-btn-ghost" id="markReadBtn">Tandai Dibaca</button>` : ''}
        ${phone ? `<button class="wt-btn wt-btn-ghost" id="openWaBtn" type="button"><i class="bi bi-whatsapp"></i> Kirim via WhatsApp</button>` : ''}
        <button class="wt-btn wt-btn-ghost" id="openEmailBtn" type="button">
          <i class="bi bi-envelope"></i> Kirim via Email
        </button>
      </div>

      <div class="wt-feedback" id="saveFeedback"></div>
    `;

    document.getElementById('finishBtn')!.addEventListener('click', async () => {
      const textarea = document.getElementById('replyText') as HTMLTextAreaElement;
      const hint = document.getElementById('replyHint')!;
      const value = textarea.value.trim();

      if (!value) {
        textarea.classList.add('invalid');
        hint.textContent = 'Tulis dulu balasannya sebelum menandai selesai.';
        hint.style.color = 'var(--wt-rose)';
        textarea.focus();
        return;
      }
      textarea.classList.remove('invalid');

      await updateMessage(id, { adminReply: value }, item, 'replied');

      if (isMobile()) {
        setTimeout(() => {
          inboxEl!.classList.remove('mobile-detail-active');
        }, 650);
      }
    });

    const markReadBtn = document.getElementById('markReadBtn');
    if (markReadBtn) {
      markReadBtn.addEventListener('click', async () => {
        await updateMessage(id, { status: 'read' }, item, 'read');
      });
    }

    document.getElementById('openWaBtn')?.addEventListener('click', () => {
      const textarea = document.getElementById('replyText') as HTMLTextAreaElement;
      const text = textarea.value.trim();
      if (!text) {
        textarea.classList.add('invalid');
        textarea.focus();
        return;
      }
      const waMessage =
        `Halo ${name}, ini balasan dari panitia Waru Turi Fun Run 2026 untuk pertanyaan kamu ("${subject}"):\n\n${text}\n\n` +
        `Ada pertanyaan lain? Hubungi kami di sini atau kunjungi http://localhost:4321/kontak`;
      const target = phone.replace(/[^0-9]/g, '').replace(/^0/, '62');
      window.open(`https://wa.me/${target}?text=${encodeURIComponent(waMessage)}`, '_blank');
    });

    document.getElementById('openEmailBtn')?.addEventListener('click', () => {
      const textarea = document.getElementById('replyText') as HTMLTextAreaElement;
      const text = textarea.value.trim();
      if (!text) {
        textarea.classList.add('invalid');
        textarea.focus();
        return;
      }
      const emailBody =
        `Halo ${name},\n\nTerima kasih sudah menghubungi Waru Turi Fun Run 2026. Berikut balasan dari tim kami:\n\n${text}\n\n` +
        `Salam,\nPanitia Waru Turi Fun Run 2026`;
      window.location.href = `mailto:${email}?subject=${encodeURIComponent('Re: ' + subject)}&body=${encodeURIComponent(emailBody)}`;
    });

    document.getElementById('detailBackBtn')!.addEventListener('click', () => {
      inboxEl!.classList.remove('mobile-detail-active');
    });

    if (isMobile()) {
      inboxEl!.classList.add('mobile-detail-active');
    }
  }

  async function updateMessage(id: string, payload: Record<string, unknown>, item: HTMLElement, newStatus: string) {
    const feedback = document.getElementById('saveFeedback');
    try {
      const res = await fetch(`/api/admin/contacts/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Gagal');

      item.setAttribute('data-status', newStatus);
      if (typeof payload.adminReply === 'string') {
        item.setAttribute('data-reply', payload.adminReply);
      }

      const bar = item.querySelector('.wt-item-bar');
      if (bar) bar.className = `wt-item-bar bar-${newStatus}`;

      const badge = item.querySelector('.wt-badge');
      if (badge) {
        badge.className = `wt-badge badge-${newStatus}`;
        badge.innerHTML = `${newStatus === 'replied' ? '<i class="bi bi-flag-fill"></i>' : ''}${statusLabel[newStatus] ?? newStatus}`;
      }

      const currentBadge = document.getElementById('currentStatusBadge');
      if (currentBadge) {
        currentBadge.className = `wt-badge badge-${newStatus}`;
        currentBadge.innerHTML = `${newStatus === 'replied' ? '<i class="bi bi-flag-fill"></i>' : ''}${statusLabel[newStatus] ?? newStatus}`;
      }

      if (feedback) {
        feedback.innerHTML = newStatus === 'replied'
          ? '<i class="bi bi-check-circle-fill"></i> Tiket ditandai selesai.'
          : '<i class="bi bi-check-circle-fill"></i> Tersimpan.';
        feedback.className = 'wt-feedback show ok';
      }
    } catch (err) {
      if (feedback) {
        feedback.innerHTML = '<i class="bi bi-x-circle-fill"></i> Gagal menyimpan, coba lagi.';
        feedback.className = 'wt-feedback show fail';
      }
    }
  }

  document.querySelectorAll('.wt-item').forEach((item) => {
    item.addEventListener('click', () => {
      document.querySelectorAll('.wt-item').forEach((el) => el.classList.remove('selected'));
      item.classList.add('selected');
      renderDetail(item as HTMLElement);

      if (item.getAttribute('data-status') === 'unread') {
        updateMessage(item.getAttribute('data-id')!, { status: 'read' }, item as HTMLElement, 'read');
      }
    });
  });
</script>