      height: 44px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .stat-icon.blue {
      background: #dbeafe;
    }
    .stat-icon.yellow {
      background: #fef9c3;
    }
    .stat-icon.green {
      background: #dcfce7;
    }
    .stat-icon.purple {
      background: #f3e8ff;
    }

    .stat-icon-svg {
      width: 20px;
      height: 20px;
    }
    .stat-icon.blue .stat-icon-svg { color: #2563eb; }
    .stat-icon.yellow .stat-icon-svg { color: #ca8a04; }
    .stat-icon.green .stat-icon-svg { color: #16a34a; }
    .stat-icon.purple .stat-icon-svg { color: #9333ea; }

    /* ===== CATEGORY ===== */
    .category-grid {
