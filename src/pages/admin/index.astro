// src/pages/admin/index.astro
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db/index.js';
import { users, participants } from '../../db/schema.js';
import { eq, count } from 'drizzle-orm';
import { verifyToken } from '../../lib/auth';

// ===== CEK AUTH =====
const token = Astro.cookies.get('token')?.value;
let isAdmin = false;
let userData = null;

if (token) {
  const decoded = verifyToken(token);
  if (decoded && typeof decoded !== 'string') {
    const user = await db.select().from(users).where(eq(users.id, decoded.id));
    if (user && user.length > 0 && (user[0].role === 'admin' || user[0].role === 'super_admin')) {
      isAdmin = true;
      userData = user[0];
    }
  }
}

// ===== REDIRECT JIKA BUKAN ADMIN =====
if (!isAdmin) {
  return Astro.redirect('/auth/login');
}

// ===== AMBIL STATISTIK =====
let stats = {
  total: 0,
  registered: 0,
  confirmed: 0,
  paid: 0,
  unpaid: 0,
  categories: {
    '5K': 0,
    '10K': 0,
    'Pelajar': 0
  }
};

if (isAdmin) {
  try {
    // Total peserta
    const totalResult = await db.select({ count: count() }).from(participants);
    stats.total = Number(totalResult[0]?.count) || 0;
    
    // Status registered
    const registeredResult = await db.select({ count: count() }).from(participants).where(eq(participants.status, 'registered'));
    stats.registered = Number(registeredResult[0]?.count) || 0;
    
    // Status confirmed
    const confirmedResult = await db.select({ count: count() }).from(participants).where(eq(participants.status, 'confirmed'));
    stats.confirmed = Number(confirmedResult[0]?.count) || 0;
    
    // Payment status paid
    const paidResult = await db.select({ count: count() }).from(participants).where(eq(participants.paymentStatus, 'paid'));
    stats.paid = Number(paidResult[0]?.count) || 0;
    
    // Payment status unpaid (pending)
    const unpaidResult = await db.select({ count: count() }).from(participants).where(eq(participants.paymentStatus, 'pending'));
    stats.unpaid = Number(unpaidResult[0]?.count) || 0;
    
    // Per kategori
    const category5K = await db.select({ count: count() }).from(participants).where(eq(participants.category, '5K'));
    stats.categories['5K'] = Number(category5K[0]?.count) || 0;
    
    const category10K = await db.select({ count: count() }).from(participants).where(eq(participants.category, '10K'));
    stats.categories['10K'] = Number(category10K[0]?.count) || 0;
    
    const categoryPelajar = await db.select({ count: count() }).from(participants).where(eq(participants.category, 'Pelajar'));
    stats.categories['Pelajar'] = Number(categoryPelajar[0]?.count) || 0;
    
  } catch (error) {
    console.error('Error fetching stats:', error);
  }
}
