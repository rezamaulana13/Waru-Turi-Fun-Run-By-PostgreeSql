        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-100 dark:border-gray-700 p-5 hover:shadow-md transition">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Dikonfirmasi</p>
            <p class="text-2xl font-semibold text-gray-900 dark:text-white mt-1">{stats.confirmed}</p>
