        height: 32px;
      }

      .actions-grid {
        grid-template-columns: 1fr;
        gap: 10px;
      }

      .action-card {
        padding: 14px 16px;
      }

      .action-icon {
        width: 38px;
        height: 38px;
      }

      .action-icon-svg {
        width: 17px;
        height: 17px;
      }

      .action-title {
        font-size: 0.8rem;
      }

      .action-desc {
        font-size: 0.7rem;
      }
    }

    @media (max-width: 480px) {
      .stats-grid {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .category-grid {
        grid-template-columns: 1fr;
