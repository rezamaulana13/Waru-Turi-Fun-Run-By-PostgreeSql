      .stat-icon.yellow .stat-icon-svg { color: #fbbf24; }
      .stat-icon.green .stat-icon-svg { color: #34d399; }
      .stat-icon.purple .stat-icon-svg { color: #a78bfa; }

      .category-icon.red { background: #3a1a1a; }
      .category-icon.blue { background: #1a2a3a; }
      .category-icon.green { background: #1a3a2a; }

