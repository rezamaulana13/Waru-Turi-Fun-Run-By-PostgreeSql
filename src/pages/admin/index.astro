      }
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 1024px) {
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }
    }

    @media (max-width: 768px) {
      .admin-dashboard {
        padding: 0 12px;
      }

      .dashboard-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
      }

      .dashboard-title {
        font-size: 1.2rem;
      }

