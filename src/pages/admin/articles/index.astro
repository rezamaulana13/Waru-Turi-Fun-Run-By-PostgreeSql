---
// src/pages/admin/articles/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, articles } from '../../../db';
import { eq, desc, ne, and } from 'drizzle-orm';

// ===== HELPER FUNCTIONS =====
function generateSlug(title: string): string {
  return title
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, '')
    .replace(/[\s_-]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

function formatDate(date: string | Date): string {
  if (!date) return '-';
  const d = new Date(date);
  return d.toLocaleDateString('id-ID', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });
}

function getStatusColor(status: string): string {
  const colors: Record<string, string> = {
    published: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
    draft: 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400',
    archived: 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400',
  };
  return colors[status] || 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400';
}

function getStatusLabel(status: string): string {
  const labels: Record<string, string> = {
    published: 'Dipublikasikan',
    draft: 'Draft',
    archived: 'Diarsipkan',
  };
  return labels[status] || status;
}

function getCategoryColor(category: string): string {
  const colors: Record<string, string> = {
    'Tips & Trik': 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400',
    'Peralatan': 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400',
    'Nutrisi': 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
    'Latihan': 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-400',
    'Kesehatan': 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400',
    'Event': 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400',
  };
  return colors[category] || 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400';
}

// ===== DEKLARASI VARIABLE =====
let articleList: any[] = [];
let fetchError = ''; // FIX: rename dari 'error' agar tidak bentrok dengan catch(error) di bawah

// ===== GET ALL ARTICLES =====
try {
  const result = await db.select()
    .from(articles)
    .orderBy(desc(articles.createdAt));

  articleList = result || [];
  console.log('✅ Articles loaded:', articleList.length);
} catch (e: any) {
  fetchError = e.message;
  console.error('Error fetching articles:', e);
}

// ===== HANDLE FORM ACTIONS =====
let errorMessage = '';
let editArticleData = null;
let isEditMode = false;

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const action = form.get('action')?.toString() || '';
    const id = form.get('id')?.toString() || '';

    // ===== DELETE =====
    if (action === 'delete' && id) {
      await db.delete(articles).where(eq(articles.id, parseInt(id)));
      return Astro.redirect('/admin/articles?success=deleted');
    }

    // ===== CREATE / UPDATE =====
    if (action === 'save') {
      const title = form.get('title')?.toString() || '';
      const subtitle = form.get('subtitle')?.toString() || '';
      const category = form.get('category')?.toString() || '';
      const excerpt = form.get('excerpt')?.toString() || '';
      const content = form.get('content')?.toString() || '';
      const status = form.get('status')?.toString() || 'draft';
      // FIX #2: baris ini WAJIB tidak di-comment, karena dipakai di bawah (tagsArray).
      // Kalau di-comment tapi tetap dipakai, akan muncul "ReferenceError: tags is not defined"
      // dan proses simpan artikel baru selalu gagal/crash.
      const tags = form.get('tags')?.toString() || '';
      const image = form.get('image')?.toString() || '';
      const author = form.get('author')?.toString() || 'Admin Waru Turi';
      const metaDescription = form.get('metaDescription')?.toString() || '';
      const metaKeywords = form.get('metaKeywords')?.toString() || '';
      const editId = form.get('editId')?.toString() || '';

      const tagsArray = tags ? tags.split(',').map(t => t.trim()).filter(t => t) : [];

      // Validate
      if (!title || !category || !content) {
        errorMessage = 'Judul, kategori, dan konten wajib diisi!';
      } else {
        const slug = generateSlug(title);

        if (editId) {
          // ===== UPDATE =====
          // FIX #3: cek slug bentrok saat update, tapi kecualikan artikel yang sedang diedit.
          const editIdNum = parseInt(editId);
          const slugConflict = await db.select()
            .from(articles)
            .where(and(eq(articles.slug, slug), ne(articles.id, editIdNum)));

          if (slugConflict.length > 0) {
            errorMessage = `Slug "${slug}" sudah dipakai artikel lain. Silakan ubah judul agar berbeda.`;
          } else {
            const updateData: any = {
              title: title.trim(),
              subtitle: subtitle.trim() || null,
              slug,
              category: category.trim(),
              excerpt: excerpt.trim() || null,
              content: content.trim(),
              status,
              // NOTE: aktifkan baris ini hanya jika kolom `tags` sudah ada di schema Drizzle kamu.
              // tags: tagsArray,
              featuredImage: image.trim() || null,
              authorName: author.trim(),
              metaDescription: metaDescription.trim() || null,
              metaKeywords: metaKeywords.trim() || null,
              updatedAt: new Date(),
            };

            // Handle published_at
            if (status === 'published') {
              updateData.publishedAt = new Date();
            } else {
              updateData.publishedAt = null;
            }

            await db.update(articles)
              .set(updateData)
              .where(eq(articles.id, editIdNum));

            return Astro.redirect('/admin/articles?success=updated');
          }
        } else {
          // ===== CREATE =====
          // Check if slug already exists
          const existing = await db.select()
            .from(articles)
            .where(eq(articles.slug, slug));

          if (existing.length > 0) {
            errorMessage = `Slug "${slug}" sudah digunakan. Silakan gunakan judul yang berbeda.`;
          } else {
            const newArticle: any = {
              title: title.trim(),
              subtitle: subtitle.trim() || null,
              slug,
              category: category.trim(),
              excerpt: excerpt.trim() || null,
              content: content.trim(),
              status,
              // NOTE: aktifkan baris ini hanya jika kolom `tags` sudah ada di schema Drizzle kamu.
              // tags: tagsArray,
              featuredImage: image.trim() || null,
              authorName: author.trim(),
              metaDescription: metaDescription.trim() || null,
              metaKeywords: metaKeywords.trim() || null,
              viewCount: 0,
              likes: 0,
              createdAt: new Date(),
              updatedAt: new Date(),
            };

            if (status === 'published') {
              newArticle.publishedAt = new Date();
            }

            await db.insert(articles).values(newArticle);
            return Astro.redirect('/admin/articles?success=created');
          }
        }
      }
    }
  } catch (error: any) {
    errorMessage = `Terjadi kesalahan: ${error.message}`;
    console.error('Error:', error);
  }
}

// ===== GET URL PARAMS =====
const urlParams = new URLSearchParams(Astro.url.search);
const successParam = urlParams.get('success');
const editIdParam = urlParams.get('edit');

// ===== GET EDIT DATA =====
if (editIdParam) {
  try {
    const result = await db.select()
      .from(articles)
      .where(eq(articles.id, parseInt(editIdParam)));

    if (result.length > 0) {
      editArticleData = result[0];
      isEditMode = true;
    }
  } catch (e) {
    console.error('Error fetching article for edit:', e);
  }
}

// ===== STATISTICS =====
const totalArticles = articleList.length;
const publishedArticles = articleList.filter((a: any) => a.status === 'published').length;
const totalViews = articleList.reduce((acc: number, a: any) => acc + (a.viewCount || 0), 0);
const totalLikes = articleList.reduce((acc: number, a: any) => acc + (a.likes || 0), 0);

// Convert article list to JSON for JavaScript
const articlesJson = JSON.stringify(articleList);
---

<AdminLayout title="Manajemen Artikel - Admin Panel">
  <div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between flex-wrap gap-4">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">
          <i class="bi bi-newspaper text-blue-600 dark:text-blue-400 mr-2"></i>
          Manajemen Artikel
        </h1>
        <p class="text-gray-500 dark:text-gray-400 mt-1 text-sm">
          Kelola semua artikel di Waru Turi Run
        </p>
      </div>
      <button
        id="btnCreateArticle"
        class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center gap-2 text-sm shadow-sm shadow-blue-500/20"
      >
        <i class="bi bi-plus-lg"></i>
        Tambah Artikel
      </button>
    </div>

    <!-- Alert Messages -->
    {successParam === 'created' && (
      <div class="p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl flex items-center gap-3">
        <i class="bi bi-check-circle-fill text-green-600 dark:text-green-400 text-xl"></i>
        <p class="text-green-700 dark:text-green-300 text-sm">Artikel berhasil dibuat!</p>
        <button onclick="this.parentElement.remove()" class="ml-auto text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-200">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    )}

    {successParam === 'updated' && (
      <div class="p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl flex items-center gap-3">
        <i class="bi bi-check-circle-fill text-green-600 dark:text-green-400 text-xl"></i>
        <p class="text-green-700 dark:text-green-300 text-sm">Artikel berhasil diperbarui!</p>
        <button onclick="this.parentElement.remove()" class="ml-auto text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-200">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    )}

    {successParam === 'deleted' && (
      <div class="p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl flex items-center gap-3">
        <i class="bi bi-check-circle-fill text-green-600 dark:text-green-400 text-xl"></i>
        <p class="text-green-700 dark:text-green-300 text-sm">Artikel berhasil dihapus!</p>
        <button onclick="this.parentElement.remove()" class="ml-auto text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-200">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    )}

    {errorMessage && (
      <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl flex items-center gap-3">
        <i class="bi bi-exclamation-circle-fill text-red-600 dark:text-red-400 text-xl"></i>
        <p class="text-red-700 dark:text-red-300 text-sm">{errorMessage}</p>
        <button onclick="this.parentElement.remove()" class="ml-auto text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-200">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
    )}

    {fetchError && (
      <div class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl flex items-center gap-3">
        <i class="bi bi-exclamation-circle-fill text-red-600 dark:text-red-400 text-xl"></i>
        <p class="text-red-700 dark:text-red-300 text-sm">Gagal memuat data: {fetchError}</p>
      </div>
    )}

    <!-- Statistics Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Total Artikel</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">{totalArticles}</p>
          </div>
          <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-newspaper text-xl text-blue-600 dark:text-blue-400"></i>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Dipublikasikan</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">{publishedArticles}</p>
          </div>
          <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-check-circle text-xl text-green-600 dark:text-green-400"></i>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Total Views</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">{totalViews.toLocaleString()}</p>
          </div>
          <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-eye text-xl text-purple-600 dark:text-purple-400"></i>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Total Likes</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">{totalLikes.toLocaleString()}</p>
          </div>
          <div class="w-10 h-10 bg-red-100 dark:bg-red-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-heart-fill text-xl text-red-600 dark:text-red-400"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Search & Filter -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
      <div class="flex flex-col md:flex-row gap-4">
        <div class="flex-1 relative">
          <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500"></i>
          <input
            type="text"
            id="searchInput"
            placeholder="Cari artikel..."
            class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm"
            oninput="filterArticles()"
          />
        </div>
        <div class="flex gap-3 flex-wrap">
          <select id="categoryFilter" class="px-4 py-2.5 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm" onchange="filterArticles()">
            <option value="">Semua Kategori</option>
            <option value="Tips & Trik">Tips & Trik</option>
            <option value="Peralatan">Peralatan</option>
            <option value="Nutrisi">Nutrisi</option>
            <option value="Latihan">Latihan</option>
            <option value="Kesehatan">Kesehatan</option>
            <option value="Event">Event</option>
          </select>
          <select id="statusFilter" class="px-4 py-2.5 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm" onchange="filterArticles()">
            <option value="">Semua Status</option>
            <option value="published">Dipublikasikan</option>
            <option value="draft">Draft</option>
            <option value="archived">Diarsipkan</option>
          </select>
          <button onclick="resetFilters()" class="px-4 py-2.5 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition text-sm">
            <i class="bi bi-arrow-counterclockwise"></i>
            Reset
          </button>
        </div>
      </div>
    </div>

    <!-- Articles Table -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 overflow-hidden">
      {articleList.length > 0 ? (
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 dark:bg-gray-700/50 border-b border-gray-200 dark:border-gray-700">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Artikel</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider hidden md:table-cell">Kategori</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider hidden sm:table-cell">Status</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider hidden lg:table-cell">Views</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider hidden xl:table-cell">Tanggal</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
              {articleList.map((article: any) => (
                <tr
                  key={article.id}
                  class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition article-row"
                  data-id={article.id}
                  data-title={article.title?.toLowerCase() || ''}
                  data-category={article.category || ''}
                  data-status={article.status || ''}
                >
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      {article.featuredImage && (
                        <img
                          src={article.featuredImage}
                          alt={article.title}
                          class="w-10 h-10 rounded-lg object-cover flex-shrink-0"
                          loading="lazy"
                        />
                      )}
                      <div>
                        <div class="font-medium text-gray-900 dark:text-white text-sm line-clamp-1">
                          {article.title || 'Untitled'}
                        </div>
                        {article.subtitle && (
                          <div class="text-xs text-gray-500 dark:text-gray-400 line-clamp-1">{article.subtitle}</div>
                        )}
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 hidden md:table-cell">
                    <span class={`
                      px-2 py-1 text-xs font-medium rounded-full
                      ${getCategoryColor(article.category)}
                    `}>
                      {article.category || 'Uncategorized'}
                    </span>
                  </td>
                  <td class="px-6 py-4 hidden sm:table-cell">
                    <span class={`
                      px-2 py-1 text-xs font-medium rounded-full
                      ${getStatusColor(article.status)}
                    `}>
                      {getStatusLabel(article.status)}
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400 hidden lg:table-cell">
                    {article.viewCount || 0}
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400 hidden xl:table-cell">
                    {formatDate(article.createdAt)}
                  </td>
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-1">
                      <button
                        class="btn-edit p-2 text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition"
                        title="Edit"
                        data-action="edit"
                        data-id={article.id}
                      >
                        <i class="bi bi-pencil"></i>
                      </button>
                      <a
                        href={`/articles/${article.slug}`}
                        target="_blank"
                        class="p-2 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition"
                        title="Lihat"
                      >
                        <i class="bi bi-eye"></i>
                      </a>
                      <button
                        class="p-2 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition"
                        title="Hapus"
                        data-action="delete"
                        data-id={article.id}
                        data-title={article.title}
                      >
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="text-center py-16">
          <i class="bi bi-inbox text-6xl text-gray-300 dark:text-gray-600 mb-4 block"></i>
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Belum Ada Artikel</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm mb-4">Mulai buat artikel pertama Anda</p>
          <button id="btnCreateArticleEmpty" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm">
            <i class="bi bi-plus-lg"></i>
            Buat Artikel
          </button>
        </div>
      )}
    </div>

    <!-- Footer Info -->
    {articleList.length > 0 && (
      <div class="flex items-center justify-between text-sm text-gray-500 dark:text-gray-400">
        <p>
          Menampilkan <span class="font-medium">{articleList.length}</span> artikel
        </p>
        <p>
          <i class="bi bi-info-circle mr-1"></i>
          {publishedArticles} dipublikasikan, {articleList.filter((a: any) => a.status === 'draft').length} draft, {articleList.filter((a: any) => a.status === 'archived').length} diarsipkan
        </p>
      </div>
    )}
  </div>

  <!-- ============================================================ -->
  <!-- MODAL FORM (Create/Edit) -->
  <!-- ============================================================ -->
  <div id="articleModal" class="fixed inset-0 z-50 flex items-center justify-center px-4 hidden">
    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal()"></div>

    <!-- Modal Content -->
    <div class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto">
      <div class="sticky top-0 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-4 flex items-center justify-between z-10">
        <!-- FIX #1: id header diganti jadi "modalTitleHeader" (sebelumnya "modalTitle", -->
        <!-- bentrok dengan id input judul di bawah sehingga input judul tidak pernah terisi). -->
        <h2 id="modalTitleHeader" class="text-xl font-bold text-gray-900 dark:text-white">
          <i class="bi bi-plus-circle text-blue-600 dark:text-blue-400 mr-2"></i>
          Tambah Artikel Baru
        </h2>
        <button onclick="closeModal()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition">
          <i class="bi bi-x-lg text-xl"></i>
        </button>
      </div>

      <form method="POST" class="p-6 space-y-6" id="articleForm">
        <input type="hidden" name="action" value="save">
        <input type="hidden" name="editId" id="editId" value="">

        <!-- Title -->
        <div>
          <label for="modalTitle" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Judul Artikel <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="modalTitle"
            name="title"
            class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm"
            placeholder="Masukkan judul artikel..."
            required
            oninput="generateSlugFromTitle(this.value)"
          />
        </div>

        <!-- Slug -->
        <div>
          <label for="modalSlug" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Slug (URL)
          </label>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500">
              <i class="bi bi-link-45deg"></i>
            </span>
            <input
              type="text"
              id="modalSlug"
              name="slug"
              class="w-full pl-10 pr-4 py-3 bg-gray-100 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg text-sm text-gray-600 dark:text-gray-400 cursor-not-allowed"
              placeholder="auto-generated-from-title"
              readonly
            />
          </div>
        </div>

        <!-- Subtitle -->
        <div>
          <label for="modalSubtitle" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Subtitle
          </label>
          <input
            type="text"
            id="modalSubtitle"
            name="subtitle"
            class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm"
            placeholder="Subtitle artikel..."
          />
        </div>

        <!-- Category & Author -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="modalCategory" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              Kategori <span class="text-red-500">*</span>
            </label>
            <select
              id="modalCategory"
              name="category"
              class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm"
              required
            >
              <option value="">Pilih Kategori</option>
              <option value="Tips & Trik">Tips & Trik</option>
              <option value="Peralatan">Peralatan</option>
              <option value="Nutrisi">Nutrisi</option>
              <option value="Latihan">Latihan</option>
              <option value="Kesehatan">Kesehatan</option>
              <option value="Event">Event</option>
            </select>
          </div>

          <div>
            <label for="modalAuthor" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              Penulis
            </label>
            <input
              type="text"
              id="modalAuthor"
              name="author"
              value="Admin Waru Turi"
              class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm"
              placeholder="Nama penulis..."
            />
          </div>
        </div>

        <!-- Image -->
        <div>
          <label for="modalImage" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Gambar (URL)
          </label>
          <div class="flex gap-3">
            <input
              type="url"
              id="modalImage"
              name="image"
              class="flex-1 px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm"
              placeholder="https://picsum.photos/seed/... atau URL gambar lainnya"
              oninput="previewModalImage(this.value)"
            />
            <button
              type="button"
              onclick="generateRandomModalImage()"
              class="px-4 py-3 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition text-sm flex items-center gap-2"
            >
              <i class="bi bi-shuffle"></i>
              <span class="hidden sm:inline">Random</span>
            </button>
          </div>
          <div id="modalImagePreview" class="mt-3 hidden">
            <img id="modalPreviewImg" src="" alt="Preview" class="max-h-40 rounded-lg border border-gray-200 dark:border-gray-600"/>
          </div>
        </div>

        <!-- Excerpt -->
        <div>
          <label for="modalExcerpt" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Ringkasan
          </label>
          <textarea
            id="modalExcerpt"
            name="excerpt"
            rows="2"
            class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm resize-y"
            placeholder="Ringkasan singkat artikel..."
          ></textarea>
        </div>

        <!-- Content -->
        <div>
          <label for="modalContent" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Konten <span class="text-red-500">*</span>
          </label>
          <textarea
            id="modalContent"
            name="content"
            rows="8"
            class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition font-mono text-sm resize-y"
            placeholder="Tulis konten artikel di sini... (Mendukung Markdown)"
            required
          ></textarea>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
            <i class="bi bi-markdown mr-1"></i>
            Mendukung format Markdown: **bold**, *italic*, # heading, - list
          </p>
        </div>

        <!-- Tags -->
        <div>
          <label for="modalTags" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Tags
          </label>
          <input
            type="text"
            id="modalTags"
            name="tags"
            class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm"
            placeholder="pisahkan dengan koma, contoh: Mental, Persiapan, Motivasi"
          />
        </div>

        <!-- Status -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Status Artikel
          </label>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <label class="flex items-center gap-3 p-3 border-2 border-gray-200 dark:border-gray-600 rounded-lg cursor-pointer hover:border-blue-400 dark:hover:border-blue-500 transition has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 dark:has-[:checked]:bg-blue-900/20">
              <input type="radio" name="status" value="draft" checked class="form-radio text-blue-600"/>
              <div>
                <div class="font-medium text-gray-900 dark:text-white text-sm">Draft</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Masih dalam pengerjaan</div>
              </div>
            </label>

            <label class="flex items-center gap-3 p-3 border-2 border-gray-200 dark:border-gray-600 rounded-lg cursor-pointer hover:border-blue-400 dark:hover:border-blue-500 transition has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 dark:has-[:checked]:bg-blue-900/20">
              <input type="radio" name="status" value="published" class="form-radio text-blue-600"/>
              <div>
                <div class="font-medium text-gray-900 dark:text-white text-sm">Published</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Publikasikan sekarang</div>
              </div>
            </label>

            <label class="flex items-center gap-3 p-3 border-2 border-gray-200 dark:border-gray-600 rounded-lg cursor-pointer hover:border-blue-400 dark:hover:border-blue-500 transition has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 dark:has-[:checked]:bg-blue-900/20">
              <input type="radio" name="status" value="archived" class="form-radio text-blue-600"/>
              <div>
                <div class="font-medium text-gray-900 dark:text-white text-sm">Archived</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Arsipkan artikel</div>
              </div>
            </label>
          </div>
        </div>

        <!-- SEO -->
        <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white flex items-center gap-2 mb-4">
            <i class="bi bi-graph-up text-blue-600 dark:text-blue-400"></i>
            SEO (Search Engine Optimization)
          </h3>

          <div class="space-y-4">
            <div>
              <label for="modalMetaDescription" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Meta Description
              </label>
              <textarea
                id="modalMetaDescription"
                name="metaDescription"
                rows="2"
                class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm resize-y"
                placeholder="Deskripsi untuk SEO (maksimal 160 karakter)..."
                maxlength="160"
              ></textarea>
            </div>

            <div>
              <label for="modalMetaKeywords" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                Meta Keywords
              </label>
              <input
                type="text"
                id="modalMetaKeywords"
                name="metaKeywords"
                class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-700/50 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition text-sm"
                placeholder="pisahkan dengan koma, contoh: lari, marathon, tips lari"
              />
            </div>
          </div>
        </div>

        <!-- Submit -->
        <div class="sticky bottom-0 bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 -mx-6 px-6 py-4 flex justify-end gap-3">
          <button type="button" onclick="closeModal()" class="px-6 py-2.5 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition text-sm">
            Batal
          </button>
          <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm flex items-center gap-2">
            <i class="bi bi-check-lg"></i>
            <span id="modalSubmitText">Simpan</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ============================================================ -->
  <!-- DELETE CONFIRMATION MODAL -->
  <!-- ============================================================ -->
  <div id="deleteModal" class="fixed inset-0 z-50 flex items-center justify-center px-4 hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeDeleteModal()"></div>

    <div class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-md w-full p-6">
      <div class="text-center">
        <div class="w-16 h-16 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
          <i class="bi bi-exclamation-triangle text-3xl text-red-600 dark:text-red-400"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Konfirmasi Hapus</h3>
        <p class="text-gray-500 dark:text-gray-400 text-sm mb-6">
          Apakah Anda yakin ingin menghapus artikel "<span id="deleteTitle" class="font-medium text-gray-700 dark:text-gray-300"></span>"?
          <br>
          <span class="text-red-500 text-xs">Tindakan ini tidak dapat dibatalkan!</span>
        </p>

        <form method="POST" id="deleteForm">
          <input type="hidden" name="action" value="delete">
          <input type="hidden" name="id" id="deleteId">
          <div class="flex gap-3 justify-center">
            <button type="button" onclick="closeDeleteModal()" class="px-6 py-2.5 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition text-sm">
              Batal
            </button>
            <button type="submit" class="px-6 py-2.5 bg-red-600 text-white rounded-lg hover:bg-red-700 transition text-sm flex items-center gap-2">
              <i class="bi bi-trash"></i>
              Hapus
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script define:vars={{ articlesJson }}>
    // ============================================================
    // DATA
    // ============================================================
    const articlesData = JSON.parse(articlesJson);

    // ============================================================
    // MODAL CONTROLS
    // ============================================================
    function openCreateModal() {
      // FIX #1: header sekarang diambil lewat id "modalTitleHeader" (bukan "modalTitle" lagi)
      const titleHeader = document.getElementById('modalTitleHeader');
      const submitText = document.getElementById('modalSubmitText');
      const editId = document.getElementById('editId');

      titleHeader.innerHTML = '<i class="bi bi-plus-circle text-blue-600 dark:text-blue-400 mr-2"></i> Tambah Artikel Baru';
      submitText.textContent = 'Buat Artikel';
      editId.value = '';

      // Reset form
      document.getElementById('articleForm').reset();
      document.getElementById('modalSlug').value = '';
      document.getElementById('modalImagePreview').classList.add('hidden');
      document.querySelector('input[name="status"][value="draft"]').checked = true;
      document.getElementById('modalAuthor').value = 'Admin Waru Turi';
      // Sekarang ini benar-benar menembak <input id="modalTitle">, bukan <h2> lagi
      document.getElementById('modalTitle').value = '';
      document.getElementById('modalSubtitle').value = '';
      document.getElementById('modalExcerpt').value = '';
      document.getElementById('modalContent').value = '';
      document.getElementById('modalTags').value = '';
      document.getElementById('modalImage').value = '';
      document.getElementById('modalMetaDescription').value = '';
      document.getElementById('modalMetaKeywords').value = '';

      modal_show();
    }

    function openEditModal(data) {
      const titleHeader = document.getElementById('modalTitleHeader');
      const submitText = document.getElementById('modalSubmitText');
      const editId = document.getElementById('editId');

      titleHeader.innerHTML = '<i class="bi bi-pencil text-blue-600 dark:text-blue-400 mr-2"></i> Edit Artikel';
      submitText.textContent = 'Update Artikel';
      editId.value = data.id;

      // Fill form with data — sekarang benar-benar mengisi <input id="modalTitle">
      document.getElementById('modalTitle').value = data.title || '';
      document.getElementById('modalSubtitle').value = data.subtitle || '';
      document.getElementById('modalCategory').value = data.category || '';
      document.getElementById('modalAuthor').value = data.authorName || 'Admin Waru Turi';
      document.getElementById('modalExcerpt').value = data.excerpt || '';
      document.getElementById('modalContent').value = data.content || '';
      document.getElementById('modalTags').value = (data.tags || []).join(', ');
      document.getElementById('modalMetaDescription').value = data.metaDescription || '';
      document.getElementById('modalMetaKeywords').value = data.metaKeywords || '';

      // Image - use featured_image
      if (data.featuredImage) {
        document.getElementById('modalImage').value = data.featuredImage;
        previewModalImage(data.featuredImage);
      } else {
        document.getElementById('modalImage').value = '';
        document.getElementById('modalImagePreview').classList.add('hidden');
      }

      // Slug
      document.getElementById('modalSlug').value = data.slug || '';

      // Status
      const statusRadios = document.querySelectorAll('input[name="status"]');
      statusRadios.forEach(radio => {
        radio.checked = radio.value === data.status;
      });

      modal_show();
    }

    function modal_show() {
      const modal = document.getElementById('articleModal');
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      document.getElementById('articleModal').classList.add('hidden');
      document.body.style.overflow = '';
    }

    // ============================================================
    // EDIT ARTICLE
    // ============================================================
    function editArticle(id) {
      const article = articlesData.find(a => a.id === id);

      if (article) {
        openEditModal(article);
      } else {
        fetch(`/api/articles/${id}`)
          .then(res => res.json())
          .then(data => {
            if (data) {
              openEditModal(data);
            } else {
              alert('Artikel tidak ditemukan!');
            }
          })
          .catch(() => {
            alert('Gagal mengambil data artikel!');
          });
      }
    }

    // ============================================================
    // DELETE CONFIRMATION
    // ============================================================
    function confirmDelete(id, title) {
      document.getElementById('deleteId').value = id;
      document.getElementById('deleteTitle').textContent = title;
      document.getElementById('deleteModal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeDeleteModal() {
      document.getElementById('deleteModal').classList.add('hidden');
      document.body.style.overflow = '';
    }

    // ============================================================
    // GENERATE SLUG
    // ============================================================
    function generateSlugFromTitle(title) {
      const slug = title
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_-]+/g, '-')
        .replace(/^-+|-+$/g, '');

      document.getElementById('modalSlug').value = slug;
    }

    // ============================================================
    // IMAGE HANDLING
    // ============================================================
    function generateRandomModalImage() {
      const seed = Math.random().toString(36).substring(7);
      const url = `https://picsum.photos/seed/${seed}/800/500`;
      document.getElementById('modalImage').value = url;
      previewModalImage(url);
    }

    function previewModalImage(url) {
      const preview = document.getElementById('modalImagePreview');
      const img = document.getElementById('modalPreviewImg');
      if (url && url.length > 0) {
        img.src = url;
        preview.classList.remove('hidden');
      } else {
        preview.classList.add('hidden');
      }
    }

    // ============================================================
    // SEARCH AND FILTER
    // ============================================================
    function filterArticles() {
      const search = document.getElementById('searchInput').value.toLowerCase();
      const category = document.getElementById('categoryFilter').value;
      const status = document.getElementById('statusFilter').value;
      const rows = document.querySelectorAll('.article-row');

      rows.forEach(row => {
        const title = row.dataset.title || '';
        const rowCategory = row.dataset.category || '';
        const rowStatus = row.dataset.status || '';

        let show = true;
        if (search && !title.includes(search)) show = false;
        if (category && rowCategory !== category) show = false;
        if (status && rowStatus !== status) show = false;

        row.style.display = show ? '' : 'none';
      });
    }

    function resetFilters() {
      document.getElementById('searchInput').value = '';
      document.getElementById('categoryFilter').value = '';
      document.getElementById('statusFilter').value = '';
      filterArticles();
    }

    // ============================================================
    // KEYBOARD SHORTCUTS
    // ============================================================
    document.addEventListener('keydown', function(e) {
      if (e.ctrlKey && e.key === 'n') {
        e.preventDefault();
        openCreateModal();
      }
      if (e.key === 'Escape') {
        closeModal();
        closeDeleteModal();
      }
    });

    // ============================================================
    // EVENT LISTENERS
    // ============================================================
    document.addEventListener('DOMContentLoaded', function() {
      // Button Create
      const btnCreate = document.getElementById('btnCreateArticle');
      const btnCreateEmpty = document.getElementById('btnCreateArticleEmpty');

      if (btnCreate) {
        btnCreate.addEventListener('click', openCreateModal);
      }
      if (btnCreateEmpty) {
        btnCreateEmpty.addEventListener('click', openCreateModal);
      }

      // ============================================================
      // EVENT DELEGATION - Edit & Delete buttons
      // ============================================================
      document.querySelectorAll('.article-row').forEach(row => {
        row.addEventListener('click', function(e) {
          const editBtn = e.target.closest('[data-action="edit"]');
          const deleteBtn = e.target.closest('[data-action="delete"]');

          if (editBtn) {
            const id = parseInt(editBtn.dataset.id);
            editArticle(id);
          }

          if (deleteBtn) {
            const id = deleteBtn.dataset.id;
            const title = deleteBtn.dataset.title;
            confirmDelete(id, title);
          }
        });
      });

      // Check if edit mode from URL
      const urlParams = new URLSearchParams(window.location.search);
      const editId = urlParams.get('edit');

      if (editId) {
        const article = articlesData.find(a => a.id === parseInt(editId));
        if (article) {
          openEditModal(article);
          const newUrl = window.location.pathname;
          window.history.replaceState({}, '', newUrl);
        }
      }
    });

    // ============================================================
    // MAKE FUNCTIONS GLOBALLY AVAILABLE
    // ============================================================
    window.openCreateModal = openCreateModal;
    window.openEditModal = openEditModal;
    window.closeModal = closeModal;
    window.editArticle = editArticle;
    window.confirmDelete = confirmDelete;
    window.closeDeleteModal = closeDeleteModal;
    window.generateSlugFromTitle = generateSlugFromTitle;
    window.generateRandomModalImage = generateRandomModalImage;
    window.previewModalImage = previewModalImage;
    window.filterArticles = filterArticles;
    window.resetFilters = resetFilters;

    console.log('✅ Admin Articles - All-in-One CRUD loaded');
    console.log('📌 Shortcuts: Ctrl+N = New Article, ESC = Close Modal');
  </script>
</AdminLayout>