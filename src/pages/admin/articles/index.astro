        href="/admin/articles/create"
        class="group bg-white dark:bg-gray-800 rounded-2xl shadow-sm border-2 border-dashed border-gray-300 dark:border-gray-600 overflow-hidden hover:border-blue-500 dark:hover:border-blue-400 transition-all duration-300 flex items-center justify-center min-h-[420px]"
      >
        <div class="text-center p-6">
          <div class="w-20 h-20 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-50 dark:group-hover:bg-blue-900/20 transition">
            <i class="bi bi-plus-lg text-4xl text-gray-400 dark:text-gray-500 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition"></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-600 dark:text-gray-400 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition">
            Tambah Artikel Baru
          </h3>
          <p class="text-sm text-gray-400 dark:text-gray-500 mt-1">Klik untuk menambahkan artikel</p>
        </div>
      </a>
    </div>

    <!-- Pagination -->
    <div class="mt-8 flex items-center justify-between flex-wrap gap-3">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Menampilkan <span class="font-medium">1</span> - <span class="font-medium">{Math.min(10, articles.length)}</span> dari <span class="font-medium">{articles.length}</span> data
      </p>
      <div class="flex items-center gap-2">
        <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition disabled:opacity-50" disabled>
          <i class="bi bi-chevron-left"></i>
        </button>
        <button class="px-3 py-1.5 rounded-lg bg-blue-600 text-white">1</button>
        <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">2</button>
        <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">3</button>
        <span class="text-gray-500 dark:text-gray-400">...</span>
        <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">10</button>
        <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="fixed bottom-6 right-6 bg-gray-900 dark:bg-gray-800 text-white px-6 py-4 rounded-xl shadow-lg transform translate-y-full opacity-0 transition-all duration-300 flex items-center gap-3 z-50">
    <i class="bi bi-check-circle-fill text-green-400"></i>
    <span id="toast-message">Artikel berhasil dihapus!</span>
    <button onclick="hideToast()" class="text-gray-400 hover:text-white transition">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>

  <script>
    // ============================================================
    // DELETE ARTICLE
    // ============================================================
    function deleteArticle(id) {
      if (!confirm('Yakin ingin menghapus artikel ini?')) return;
      
      const card = document.querySelector(`#articlesGrid .group[data-id="${id}"]`);
      if (card) {
        card.style.transform = 'scale(0.9)';
        card.style.opacity = '0';
        setTimeout(() => {
          card.remove();
          showToast('Artikel berhasil dihapus!');
          updateStats();
        }, 300);
      }
    }
    window.deleteArticle = deleteArticle;

    // ============================================================
    // UPDATE STATISTICS
    // ============================================================
    function updateStats() {
      const cards = document.querySelectorAll('#articlesGrid .group:not(:last-child)');
      const total = cards.length;
      const published = document.querySelectorAll('#articlesGrid .group .bg-green-500').length;
      const views = Array.from(document.querySelectorAll('#articlesGrid .group .bi-eye'))
        .reduce((acc, el) => acc + parseInt(el.parentElement?.textContent?.trim() || '0'), 0);
      const likes = Array.from(document.querySelectorAll('#articlesGrid .group .bi-heart'))
        .reduce((acc, el) => acc + parseInt(el.parentElement?.textContent?.trim() || '0'), 0);
      
      const statCards = document.querySelectorAll('.grid-cols-1.sm\\:grid-cols-2 .bg-white');
      if (statCards.length >= 4) {
        const totalCount = statCards[0].querySelector('.text-2xl');
        if (totalCount) totalCount.textContent = total;
        
        const publishedCount = statCards[1].querySelector('.text-2xl');
        if (publishedCount) publishedCount.textContent = published;
        
        const viewsCount = statCards[2].querySelector('.text-2xl');
        if (viewsCount) viewsCount.textContent = views.toLocaleString();
        
        const likesCount = statCards[3].querySelector('.text-2xl');
        if (likesCount) likesCount.textContent = likes.toLocaleString();
      }
    }

    // ============================================================
    // SEARCH
    // ============================================================
    const searchInput = document.getElementById('searchInput');
    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      const cards = document.querySelectorAll('#articlesGrid .group:not(:last-child)');
      
      cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(query) ? '' : 'none';
      });
    });

    // ============================================================
    // TOAST
    // ============================================================
    function showToast(message) {
      const toast = document.getElementById('toast');
      const toastMessage = document.getElementById('toast-message');
      
      if (toast && toastMessage) {
        toastMessage.textContent = message;
        toast.classList.remove('translate-y-full', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
        
        setTimeout(hideToast, 3000);
      }
    }
    window.showToast = showToast;

    function hideToast() {
      const toast = document.getElementById('toast');
      if (toast) {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('translate-y-full', 'opacity-0');
      }
    }
    window.hideToast = hideToast;

    console.log('✅ Artikel Admin Panel loaded');
  </script>
</AdminLayout>