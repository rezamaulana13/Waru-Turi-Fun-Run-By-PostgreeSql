// Cari route berdasarkan ID
const route = dummyRoutes.find(r => r.id === id);

// Jika tidak ditemukan, redirect
if (!route) {
  return Astro.redirect('/admin/routes');
}

// Helper function untuk format tanggal
function formatDate(date: string): string {
  return new Date(date).toLocaleDateString('id-ID', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });
}

// Helper function untuk get color difficulty
function getDifficultyColor(difficulty: string): string {
  const colors: Record<string, string> = {
    'Mudah': 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 border-green-200 dark:border-green-800',
    'Sedang': 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400 border-yellow-200 dark:border-yellow-800',
    'Sulit': 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-400 border-orange-200 dark:border-orange-800',
    'Sangat Sulit': 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 border-red-200 dark:border-red-800',
  };
  return colors[difficulty] || 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 border-gray-200 dark:border-gray-600';
}

// Helper function untuk get status color
function getStatusColor(status: string): string {
  return status === 'active' 
    ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 border-green-200 dark:border-green-800'
    : 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 border-red-200 dark:border-red-800';
}
---

<AdminLayout title={`${route.name} - Detail Rute`}>
  <div class="max-w-7xl mx-auto">
    <!-- Breadcrumb & Header -->
    <div class="mb-6">
      <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-4">
        <a href="/admin" class="hover:text-blue-600 dark:hover:text-blue-400 transition">Dashboard</a>
        <i class="bi bi-chevron-right text-xs"></i>
        <a href="/admin/routes" class="hover:text-blue-600 dark:hover:text-blue-400 transition">Rute</a>
        <i class="bi bi-chevron-right text-xs"></i>
        <span class="text-gray-700 dark:text-gray-300 font-medium">{route.name}</span>
      </nav>

      <div class="flex items-center justify-between flex-wrap gap-4">
        <div>
          <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">
            <i class="bi bi-map text-blue-600 dark:text-blue-400 mr-2"></i>
            {route.name}
          </h1>
          <p class="text-gray-500 dark:text-gray-400 mt-1">
            Detail lengkap rute {route.category} • {route.distance}
          </p>
        </div>
        <div class="flex gap-3">
          <a 
            href="/admin/routes" 
            class="px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition flex items-center gap-2"
          >
            <i class="bi bi-arrow-left"></i>
            Kembali
          </a>
          <button 
            onclick="window.location.href=`/admin/routes/edit/${route.id}`"
            class="px-4 py-2 bg-yellow-600 text-white rounded-lg hover:bg-yellow-700 transition flex items-center gap-2"
          >
            <i class="bi bi-pencil"></i>
            Edit Rute
          </button>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Left Column - Image & Info -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Image -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 overflow-hidden">
          <div class="relative h-64 md:h-80 lg:h-96 overflow-hidden bg-gray-100 dark:bg-gray-700">
            {route.image ? (
              <img 
                src={route.image} 
                alt={route.name}
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-gray-400 dark:text-gray-500">
                <i class="bi bi-map text-6xl"></i>
              </div>
            )}
            <div class="absolute top-4 left-4 flex gap-2">
              <span class={`
                px-3 py-1 text-white text-xs font-medium rounded-full
                ${route.status === 'active' ? 'bg-green-500' : 'bg-red-500'}
              `}>
                {route.status === 'active' ? 'Aktif' : 'Tidak Aktif'}
              </span>
              <span class="px-3 py-1 bg-blue-600 text-white text-xs font-medium rounded-full">
                {route.category}
              </span>
            </div>
          </div>
        </div>

        <!-- Deskripsi -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">
            <i class="bi bi-file-text text-blue-600 dark:text-blue-400 mr-2"></i>
            Deskripsi Rute
          </h3>
          <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
            {route.description}
          </p>
        </div>

        <!-- Waypoints / Checkpoint -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
              <i class="bi bi-pin-map text-blue-600 dark:text-blue-400 mr-2"></i>
              Checkpoint & Waypoints
            </h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">
              {route.waypoints.length} titik
            </span>
          </div>
          
          <div class="relative">
            <!-- Timeline Line -->
            <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-blue-200 dark:bg-blue-900/50"></div>
            
            <div class="space-y-4">
              {route.waypoints.map((wp, index) => (
                <div key={wp.id} class="relative pl-10">
                  <!-- Timeline Dot -->
                  <div class={`
                    absolute left-2 top-2 w-5 h-5 rounded-full border-2 flex items-center justify-center
                    ${index === 0 ? 'bg-green-500 border-green-500' : ''}
                    ${index === route.waypoints.length - 1 ? 'bg-blue-600 border-blue-600' : ''}
                    ${index !== 0 && index !== route.waypoints.length - 1 ? 'bg-gray-200 dark:bg-gray-600 border-gray-300 dark:border-gray-500' : ''}
                  `}>
                    {index === 0 && <i class="bi bi-flag text-white text-[10px]"></i>}
                    {index === route.waypoints.length - 1 && <i class="bi bi-check-lg text-white text-[10px]"></i>}
                    {index !== 0 && index !== route.waypoints.length - 1 && (
                      <span class="text-[10px] font-bold text-gray-600 dark:text-gray-300">{index + 1}</span>
                    )}
                  </div>
                  
                  <!-- Content -->
                  <div class={`
                    p-4 rounded-lg border
                    ${index === 0 ? 'bg-green-50 dark:bg-green-900/10 border-green-200 dark:border-green-800' : ''}
                    ${index === route.waypoints.length - 1 ? 'bg-blue-50 dark:bg-blue-900/10 border-blue-200 dark:border-blue-800' : ''}
                    ${index !== 0 && index !== route.waypoints.length - 1 ? 'bg-gray-50 dark:bg-gray-700/50 border-gray-200 dark:border-gray-600' : ''}
                  `}>
                    <div class="flex items-center justify-between flex-wrap gap-2">
                      <h4 class="font-medium text-gray-900 dark:text-white">
                        {wp.name}
                      </h4>
                      <span class="text-sm font-semibold text-blue-600 dark:text-blue-400">
                        {wp.distance}
                      </span>
                    </div>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                      {wp.description}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column - Details -->
      <div class="space-y-6">
        <!-- Quick Info -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
            <i class="bi bi-info-circle text-blue-600 dark:text-blue-400 mr-2"></i>
            Informasi Rute
          </h3>
          
          <div class="space-y-3">
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">Kategori</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white">{route.category}</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">Jarak</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white">{route.distance}</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">Elevasi</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white">{route.elevation}</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">Durasi</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white">{route.duration}</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">Tingkat Kesulitan</span>
              <span class={`
                px-2.5 py-1 text-xs font-medium rounded-full
                ${getDifficultyColor(route.difficulty)}
              `}>
                {route.difficulty}
              </span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">Status</span>
              <span class={`
                px-2.5 py-1 text-xs font-medium rounded-full
                ${getStatusColor(route.status)}
              `}>
                {route.status === 'active' ? 'Aktif' : 'Tidak Aktif'}
              </span>
            </div>
            <div class="flex items-center justify-between py-2">
              <span class="text-sm text-gray-500 dark:text-gray-400">Checkpoint</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white">{route.waypoints.length} titik</span>
            </div>
          </div>
        </div>

        <!-- Statistik -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
            <i class="bi bi-graph-up text-blue-600 dark:text-blue-400 mr-2"></i>
            Statistik
          </h3>
          
          <div class="space-y-3">
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">Total Peserta</span>
              <span class="text-lg font-bold text-gray-900 dark:text-white">{route.participants}</span>
            </div>
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">Rata-rata Waktu</span>
              <span class="text-lg font-bold text-blue-600 dark:text-blue-400">{route.averageTime}</span>
            </div>
            <div class="flex items-center justify-between py-2">
              <span class="text-sm text-gray-500 dark:text-gray-400">Tingkat Penyelesaian</span>
              <div class="flex items-center gap-2">
                <div class="w-24 h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                  <div class="h-full bg-green-500 rounded-full" style="width: 85%"></div>
                </div>
                <span class="text-sm font-medium text-gray-900 dark:text-white">85%</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Timeline Info -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
            <i class="bi bi-clock text-blue-600 dark:text-blue-400 mr-2"></i>
            Timeline
          </h3>
          
          <div class="space-y-2">
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700">
              <span class="text-sm text-gray-500 dark:text-gray-400">Dibuat</span>
              <span class="text-sm text-gray-900 dark:text-white">{formatDate(route.createdAt)}</span>
            </div>
            <div class="flex items-center justify-between py-2">
              <span class="text-sm text-gray-500 dark:text-gray-400">Terakhir Update</span>
              <span class="text-sm text-gray-900 dark:text-white">{formatDate(route.updatedAt)}</span>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
            <i class="bi bi-lightning text-yellow-500 mr-2"></i>
            Aksi Cepat
          </h3>
          
          <div class="space-y-2">
            <button onclick="window.location.href=`/admin/participants?route=${route.id}`" class="w-full px-4 py-2.5 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/30 transition flex items-center justify-center gap-2">
              <i class="bi bi-people"></i>
              Lihat Peserta Rute Ini
            </button>
            <button onclick="window.location.href=`/admin/certificates?route=${route.id}`" class="w-full px-4 py-2.5 bg-green-50 dark:bg-green-900/20 text-green-600 dark:text-green-400 rounded-lg hover:bg-green-100 dark:hover:bg-green-900/30 transition flex items-center justify-center gap-2">
              <i class="bi bi-file-earmark-text"></i>
              Sertifikat Rute Ini
            </button>
            <button onclick="window.location.href=`/admin/reports/route/${route.id}`" class="w-full px-4 py-2.5 bg-purple-50 dark:bg-purple-900/20 text-purple-600 dark:text-purple-400 rounded-lg hover:bg-purple-100 dark:hover:bg-purple-900/30 transition flex items-center justify-center gap-2">
              <i class="bi bi-bar-chart"></i>
              Laporan Rute
            </button>
            <button onclick="deleteRoute('{route.id}')" class="w-full px-4 py-2.5 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/30 transition flex items-center justify-center gap-2">
              <i class="bi bi-trash"></i>
              Hapus Rute
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="fixed bottom-6 right-6 bg-gray-900 dark:bg-gray-800 text-white px-6 py-4 rounded-xl shadow-lg transform translate-y-full opacity-0 transition-all duration-300 flex items-center gap-3 z-50">
    <i class="bi bi-check-circle-fill text-green-400"></i>
    <span id="toast-message">Rute berhasil dihapus!</span>
    <button onclick="hideToast()" class="text-gray-400 hover:text-white transition">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>

  <script>
    // ============================================================
    // DELETE ROUTE
    // ============================================================
    function deleteRoute(id) {
      if (!confirm('Yakin ingin menghapus rute ini? Tindakan ini tidak dapat dibatalkan.')) return;
      
      try {
        // Simulate delete
        showToast('Rute berhasil dihapus!');
        
        setTimeout(() => {
          window.location.href = '/admin/routes';
        }, 1500);
      } catch (error) {
        console.error('Error deleting route:', error);
        showToast('❌ Gagal menghapus rute');
      }
    }
    window.deleteRoute = deleteRoute;

    // ============================================================
    // TOAST
    // ============================================================
    function showToast(message) {
      const toast = document.getElementById('toast');
      const toastMessage = document.getElementById('toast-message');
      
      if (toast && toastMessage) {
        toastMessage.textContent = message;
        toast.classList.remove('translate-y-full', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
        
        setTimeout(hideToast, 3000);
      }
    }
    window.showToast = showToast;

    function hideToast() {
      const toast = document.getElementById('toast');
      if (toast) {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('translate-y-full', 'opacity-0');
      }
    }
    window.hideToast = hideToast;

    console.log('✅ Rute Detail Admin Panel loaded');
  </script>
</AdminLayout>