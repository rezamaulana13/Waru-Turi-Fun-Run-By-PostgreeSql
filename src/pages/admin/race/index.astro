  <script>
    // Modal functions
    const modal = document.getElementById('modal');
    const editModal = document.getElementById('editModal');
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toast-message');

    // Open Add Modal
    function openModal() {
      modal.classList.remove('opacity-0', 'invisible');
      modal.querySelector('.relative').classList.remove('scale-95');
      modal.querySelector('.relative').classList.add('scale-100');
      document.body.style.overflow = 'hidden';
    }
    window.openModal = openModal;

    // Close Add Modal
    function closeModal() {
      modal.classList.add('opacity-0', 'invisible');
      modal.querySelector('.relative').classList.remove('scale-100');
      modal.querySelector('.relative').classList.add('scale-95');
      document.body.style.overflow = '';
    }
    window.closeModal = closeModal;

    // Open Edit Modal
    function openEditModal() {
      editModal.classList.remove('opacity-0', 'invisible');
      editModal.querySelector('.relative').classList.remove('scale-95');
      editModal.querySelector('.relative').classList.add('scale-100');
      document.body.style.overflow = 'hidden';
    }
    window.openEditModal = openEditModal;

    // Close Edit Modal
    function closeEditModal() {
      editModal.classList.add('opacity-0', 'invisible');
      editModal.querySelector('.relative').classList.remove('scale-100');
      editModal.querySelector('.relative').classList.add('scale-95');
      document.body.style.overflow = '';
    }
    window.closeEditModal = closeEditModal;

    // Close modals with Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeModal();
        closeEditModal();
      }
    });

    // Save race
    function saveRace() {
      closeModal();
      showToast('Race berhasil ditambahkan!');
    }
    window.saveRace = saveRace;

    // Update race
    function updateRace() {
      closeEditModal();
      showToast('Race berhasil diupdate!');
    }
    window.updateRace = updateRace;

    // Delete race
    function deleteRace(btn) {
      if (confirm('Yakin ingin menghapus race ini?')) {
        const card = btn.closest('.group');
        if (card) {
          card.style.transform = 'scale(0.9)';
          card.style.opacity = '0';
          setTimeout(() => {
            card.remove();
            showToast('Race berhasil dihapus!');
          }, 300);
        }
      }
    }
    window.deleteRace = deleteRace;

    // Upload area
    const uploadArea = document.getElementById('uploadArea');
    const raceImageInput = document.getElementById('raceImageInput');

    uploadArea?.addEventListener('click', () => {
      raceImageInput?.click();
    });

    uploadArea?.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadArea.classList.add('border-blue-500', 'dark:border-blue-400', 'bg-blue-50', 'dark:bg-blue-900/10');
    });

    uploadArea?.addEventListener('dragleave', () => {
      uploadArea.classList.remove('border-blue-500', 'dark:border-blue-400', 'bg-blue-50', 'dark:bg-blue-900/10');
    });

    uploadArea?.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadArea.classList.remove('border-blue-500', 'dark:border-blue-400', 'bg-blue-50', 'dark:bg-blue-900/10');
      showToast('Gambar berhasil diupload!');
    });

    raceImageInput?.addEventListener('change', () => {
      showToast('Gambar berhasil diupload!');
    });

    // Toast notification
    function showToast(message) {
      toastMessage.textContent = message;
      toast.classList.remove('translate-y-full', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
      
      setTimeout(hideToast, 3000);
    }
    window.showToast = showToast;

    function hideToast() {
      toast.classList.remove('translate-y-0', 'opacity-100');
      toast.classList.add('translate-y-full', 'opacity-0');
    }
    window.hideToast = hideToast;

    // Search functionality
    const searchInput = document.getElementById('searchInput');
    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      const cards = document.querySelectorAll('#raceGrid .group:not(:last-child)');
      
      cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(query) ? '' : 'none';
      });
    });

    console.log('✅ Race Admin Panel loaded');
  </script>
