---
// src/pages/admin/medals/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';

// Data dummy untuk sementara
const medals = [
  {
    id: '1',
    name: 'The Golden Champion',
    category: 'Gold',
    description: 'Medali Emas eksklusif ini dipesan khusus untuk para pelari tercepat yang mampu menaklukkan lintasan dengan determinasi tinggi. Ini bukan sekadar penghargaan, tapi simbol kekuatan dan kecepatanmu di Waru Turi.',
    image: 'https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgloYUwmS7ixUvYGyzMhLUxHXZfZRzSPEM1zyApcANwWsuCiH8u_ExyN1k50m4Xl72D4MpFMMYB2GqQ417d8AP5YCKpod4azna3HszS_ptESW8mf0D8IXvQV32PcNC6fLObOECb75SkiOhWt_CfVaJn4ryL02_9o8QvERXvitZgkjAPPN85gZxu7kEwQ12P/s960-rw/gabung10k.jpeg',
    status: 'active',
    stock: 500,
    createdAt: '2026-07-10',
  },
  {
    id: '2',
    name: 'The Silver Finisher',
    category: 'Silver',
    description: 'Medali Perak ini menunggumu yang gigih berjuang di barisan depan. Tunjukkan sportivitas tinggi dan lampaui batas kemampuanmu. Setiap lengkungan desainnya adalah saksi bisu atas keringat dan semangat pantang menyerahmu dalam mengejar garis finish.',
    image: 'https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEiu-flZMiecextDDty-H5UZ97102VdMcFB42OmRCi178AmcD1jkE0gXzsnkaAfiN3catA02CU4496DoCx-A7c1AmgJtRYZ0DAro3jtl-XBY5y4gpt-McAilDp5cMToj-R2jipsTLix6ZfukEasNNYhXga9ITjWcItkxv0EIJKZ9klq-cY24eCHl_qCXqliS/s960-rw/gabung5k.jpeg',
    status: 'active',
    stock: 750,
    createdAt: '2026-07-10',
  },
  {
    id: '3',
    name: 'Bronze Warrior',
    category: 'Bronze',
    description: 'Medali Perunggu sebagai penghargaan bagi para pejuang yang telah menyelesaikan tantangan dengan semangat juang tinggi. Setiap tetes keringat dan langkah yang diambil adalah bukti ketangguhan dan dedikasi.',
    image: 'https://picsum.photos/seed/bronze/400/400',
    status: 'inactive',
    stock: 300,
    createdAt: '2026-07-09',
  },
];

// Helper function untuk format tanggal
function formatDate(date: string): string {
  return new Date(date).toLocaleDateString('id-ID', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });
}
---

<AdminLayout title="Medali - Admin Panel">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <div>
          <h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">
            <i class="bi bi-trophy text-blue-600 dark:text-blue-400 mr-2"></i>
            Manajemen Medali
          </h1>
          <p class="text-gray-500 dark:text-gray-400 mt-1">
            Kelola medali finisher Waru Turi Run
          </p>
        </div>
        <div class="flex gap-3">
          <button class="px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition flex items-center gap-2">
            <i class="bi bi-download"></i>
            Export
          </button>
          <button class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center gap-2" onclick="openModal()">
            <i class="bi bi-plus-lg"></i>
            Tambah Medali
          </button>
        </div>
      </div>
    </div>

    <!-- Filter & Search -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4 mb-6">
      <div class="flex flex-col md:flex-row gap-4">
        <div class="flex-1 relative">
          <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500"></i>
          <input 
            type="text" 
            placeholder="Cari medali..." 
            class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            id="searchInput"
          />
        </div>
        <div class="flex gap-3">
          <select class="px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            <option value="">Semua Kategori</option>
            <option value="gold">Gold</option>
            <option value="silver">Silver</option>
            <option value="bronze">Bronze</option>
          </select>
          <select class="px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            <option value="">Semua Status</option>
            <option value="active">Aktif</option>
            <option value="inactive">Tidak Aktif</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Total Medali</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">{medals.length}</p>
          </div>
          <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-trophy text-2xl text-blue-600 dark:text-blue-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-green-600 dark:text-green-400">↑ 2 medali aktif</span>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Gold</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">
              {medals.filter(m => m.category === 'Gold').length}
            </p>
          </div>
          <div class="w-12 h-12 bg-yellow-100 dark:bg-yellow-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-star-fill text-2xl text-yellow-600 dark:text-yellow-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-gray-500 dark:text-gray-400">Premium</span>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Silver</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">
              {medals.filter(m => m.category === 'Silver').length}
            </p>
          </div>
          <div class="w-12 h-12 bg-gray-300 dark:bg-gray-700 rounded-xl flex items-center justify-center">
            <i class="bi bi-star text-2xl text-gray-600 dark:text-gray-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-gray-500 dark:text-gray-400">Standar</span>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 p-4">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-400">Total Stok</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">
              {medals.reduce((acc, m) => acc + m.stock, 0)}
            </p>
          </div>
          <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center">
            <i class="bi bi-box text-2xl text-green-600 dark:text-green-400"></i>
          </div>
        </div>
        <div class="mt-2">
          <span class="text-xs text-gray-500 dark:text-gray-400">Total unit</span>
        </div>
      </div>
    </div>

    <!-- Medals Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="medalsGrid">
      {medals.map((medal) => (
        <div class="group bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200/50 dark:border-gray-700/50 overflow-hidden hover:shadow-xl transition-all duration-300" data-id={medal.id}>
          <!-- Image -->
          <div class="relative h-64 overflow-hidden bg-gray-100 dark:bg-gray-700">
            {medal.image ? (
              <img 
                src={medal.image} 
                alt={medal.name}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-gray-400 dark:text-gray-500">
                <i class="bi bi-image text-5xl"></i>
              </div>
            )}
            
            <!-- Status Badge -->
            <div class="absolute top-3 left-3">
              <span class={`
                px-3 py-1 text-white text-xs font-medium rounded-full
                ${medal.status === 'active' ? 'bg-green-500' : 'bg-red-500'}
              `}>
                {medal.status === 'active' ? 'Aktif' : 'Tidak Aktif'}
              </span>
            </div>

            <!-- Category Badge -->
            <div class="absolute top-3 right-3">
              <span class={`
                px-3 py-1 text-white text-xs font-medium rounded-full
                ${medal.category === 'Gold' ? 'bg-yellow-500' : ''}
                ${medal.category === 'Silver' ? 'bg-gray-400' : ''}
                ${medal.category === 'Bronze' ? 'bg-orange-600' : ''}
              `}>
                {medal.category}
              </span>
            </div>

            <!-- Action Buttons -->
            <div class="absolute bottom-4 right-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
              <button 
                onclick="editMedal('{medal.id}')" 
                class="p-2.5 bg-white/90 dark:bg-gray-800/90 rounded-lg hover:bg-white dark:hover:bg-gray-700 transition shadow-md"
                title="Edit"
              >
                <i class="bi bi-pencil text-sm text-gray-700 dark:text-gray-300"></i>
              </button>
              <button 
                onclick="deleteMedal('{medal.id}')" 
                class="p-2.5 bg-white/90 dark:bg-gray-800/90 rounded-lg hover:bg-white dark:hover:bg-gray-700 transition shadow-md"
                title="Hapus"
              >
                <i class="bi bi-trash text-sm text-red-500"></i>
              </button>
            </div>

            <!-- Stock Info -->
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-4">
              <div class="flex items-center justify-between text-white">
                <div class="flex items-center gap-2">
                  <i class="bi bi-box"></i>
                  <span class="text-sm font-medium">Stok: {medal.stock}</span>
                </div>
                <div class="flex items-center gap-2">
                  <i class="bi bi-calendar3"></i>
                  <span class="text-sm">{formatDate(medal.createdAt)}</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class="p-5">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">
              {medal.name}
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3">
              {medal.description}
            </p>
          </div>
        </div>
      ))}

      <!-- Add New Medal Card -->
      <div 
        onclick="openModal()"
        class="group bg-white dark:bg-gray-800 rounded-2xl shadow-sm border-2 border-dashed border-gray-300 dark:border-gray-600 overflow-hidden hover:border-blue-500 dark:hover:border-blue-400 transition-all duration-300 flex items-center justify-center min-h-[400px] cursor-pointer"
      >
        <div class="text-center p-6">
          <div class="w-20 h-20 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-50 dark:group-hover:bg-blue-900/20 transition">
            <i class="bi bi-plus-lg text-4xl text-gray-400 dark:text-gray-500 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition"></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-600 dark:text-gray-400 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition">
            Tambah Medali Baru
          </h3>
          <p class="text-sm text-gray-400 dark:text-gray-500 mt-1">Klik untuk menambahkan medali</p>
        </div>
      </div>
    </div>

    <!-- Pagination -->
    <div class="mt-8 flex items-center justify-between flex-wrap gap-3">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Menampilkan <span class="font-medium">1</span> - <span class="font-medium">{Math.min(10, medals.length)}</span> dari <span class="font-medium">{medals.length}</span> data
      </p>
      <div class="flex items-center gap-2">
        <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition disabled:opacity-50" disabled>
          <i class="bi bi-chevron-left"></i>
        </button>
        <button class="px-3 py-1.5 rounded-lg bg-blue-600 text-white">1</button>
        <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">2</button>
        <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">3</button>
        <span class="text-gray-500 dark:text-gray-400">...</span>
        <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">10</button>
        <button class="px-3 py-1.5 rounded-lg border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Modal Tambah/Edit Medali -->
  <div id="modal" class="fixed inset-0 z-50 flex items-center justify-center px-4 opacity-0 invisible transition-all duration-300">
    <div class="absolute inset-0 bg-black/50" onclick="closeModal()"></div>
    <div class="relative bg-white dark:bg-gray-800 rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl transform scale-95 transition-all duration-300">
      <div class="sticky top-0 bg-white dark:bg-gray-800 z-10 px-6 py-4 border-b border-gray-200/50 dark:border-gray-700/50 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
          <i class="bi bi-plus-circle text-blue-600 dark:text-blue-400 mr-2"></i>
          <span id="modalTitle">Tambah Medali Baru</span>
        </h3>
        <button onclick="closeModal()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition">
          <i class="bi bi-x-lg"></i>
        </button>
      </div>
      
      <form id="medalForm" class="p-6 space-y-4">
        <!-- Nama Medali -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Nama Medali <span class="text-red-500">*</span>
          </label>
          <input 
            type="text" 
            id="medalName"
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            placeholder="Masukkan nama medali"
            required
          />
        </div>

        <!-- Kategori -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Kategori <span class="text-red-500">*</span>
          </label>
          <select 
            id="medalCategory"
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            required
          >
            <option value="">Pilih Kategori</option>
            <option value="Gold">Gold</option>
            <option value="Silver">Silver</option>
            <option value="Bronze">Bronze</option>
          </select>
        </div>

        <!-- Status -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Status <span class="text-red-500">*</span>
          </label>
          <select 
            id="medalStatus"
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            required
          >
            <option value="active">Aktif</option>
            <option value="inactive">Tidak Aktif</option>
          </select>
        </div>

        <!-- Stok -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Stok <span class="text-red-500">*</span>
          </label>
          <input 
            type="number" 
            id="medalStock"
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            placeholder="Masukkan jumlah stok"
            min="0"
            required
          />
        </div>

        <!-- Deskripsi -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Deskripsi <span class="text-red-500">*</span>
          </label>
          <textarea 
            id="medalDescription"
            rows="4" 
            class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"
            placeholder="Masukkan deskripsi medali..."
            required
          ></textarea>
        </div>

        <!-- Upload Gambar -->
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Gambar Medali <span class="text-red-500">*</span>
          </label>
          <div class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-xl p-6 text-center hover:border-blue-500 dark:hover:border-blue-400 transition cursor-pointer" id="uploadArea">
            <input type="file" accept="image/*" class="hidden" id="imageInput" />
            <div id="imagePreview" class="hidden mb-4">
              <img src="" alt="Preview" class="max-h-48 mx-auto rounded-lg" />
            </div>
            <i class="bi bi-cloud-upload text-4xl text-gray-400 dark:text-gray-500 mb-3 block" id="uploadIcon"></i>
            <p class="text-gray-600 dark:text-gray-300 font-medium" id="uploadText">Klik atau drag & drop untuk upload</p>
            <p class="text-sm text-gray-400 dark:text-gray-500 mt-1">JPG, PNG, GIF (Max 2MB)</p>
          </div>
        </div>

        <!-- Submit Buttons -->
        <div class="sticky bottom-0 bg-white dark:bg-gray-800 pt-4 border-t border-gray-200/50 dark:border-gray-700/50 flex justify-end gap-3">
          <button type="button" onclick="closeModal()" class="px-6 py-2 border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">
            Batal
          </button>
          <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition flex items-center gap-2">
            <i class="bi bi-check-lg"></i>
            <span id="submitText">Simpan</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="fixed bottom-6 right-6 bg-gray-900 dark:bg-gray-800 text-white px-6 py-4 rounded-xl shadow-lg transform translate-y-full opacity-0 transition-all duration-300 flex items-center gap-3 z-50">
    <i class="bi bi-check-circle-fill text-green-400"></i>
    <span id="toast-message">Medali berhasil disimpan!</span>
    <button onclick="hideToast()" class="text-gray-400 hover:text-white transition">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>

  <script>
    // ============================================================
    // MODAL FUNCTIONS
    // ============================================================
    const modal = document.getElementById('modal');
    const modalTitle = document.getElementById('modalTitle');
    const submitText = document.getElementById('submitText');
    const medalForm = document.getElementById('medalForm');
    let editingId = null;

    function openModal() {
      modal.classList.remove('opacity-0', 'invisible');
      modal.querySelector('.relative').classList.remove('scale-95');
      modal.querySelector('.relative').classList.add('scale-100');
      document.body.style.overflow = 'hidden';
      resetForm();
    }
    window.openModal = openModal;

    function closeModal() {
      modal.classList.add('opacity-0', 'invisible');
      modal.querySelector('.relative').classList.remove('scale-100');
      modal.querySelector('.relative').classList.add('scale-95');
      document.body.style.overflow = '';
      resetForm();
    }
    window.closeModal = closeModal;

    function resetForm() {
      medalForm.reset();
      editingId = null;
      modalTitle.textContent = 'Tambah Medali Baru';
      submitText.textContent = 'Simpan';
      document.getElementById('imagePreview').classList.add('hidden');
      document.getElementById('uploadIcon').classList.remove('hidden');
      document.getElementById('uploadText').textContent = 'Klik atau drag & drop untuk upload';
      document.getElementById('uploadText').classList.remove('text-blue-600', 'dark:text-blue-400');
    }

    function editMedal(id) {
      // Find medal data
      const medals = document.querySelectorAll('#medalsGrid .group:not(:last-child)');
      let medalData = null;
      
      medals.forEach(card => {
        if (card.dataset.id === id) {
          const name = card.querySelector('h3')?.textContent || '';
          const description = card.querySelector('p')?.textContent || '';
          const image = card.querySelector('img')?.src || '';
          const category = card.querySelector('.absolute.top-3.right-3 span')?.textContent || '';
          const status = card.querySelector('.absolute.top-3.left-3 span')?.textContent || '';
          const stock = card.querySelector('.absolute.bottom-0 .text-sm.font-medium')?.textContent?.replace('Stok: ', '') || '0';
          
          medalData = { id, name, description, image, category, status, stock };
        }
      });

      if (medalData) {
        editingId = id;
        modalTitle.textContent = 'Edit Medali';
        submitText.textContent = 'Update';
        
        document.getElementById('medalName').value = medalData.name;
        document.getElementById('medalCategory').value = medalData.category;
        document.getElementById('medalStatus').value = medalData.status === 'Aktif' ? 'active' : 'inactive';
        document.getElementById('medalStock').value = medalData.stock;
        document.getElementById('medalDescription').value = medalData.description;
        
        if (medalData.image) {
          const preview = document.getElementById('imagePreview');
          const img = preview.querySelector('img');
          if (img) {
            img.src = medalData.image;
            preview.classList.remove('hidden');
            document.getElementById('uploadIcon').classList.add('hidden');
            document.getElementById('uploadText').textContent = 'Gambar saat ini';
          }
        }
        
        openModal();
      }
    }
    window.editMedal = editMedal;

    // ============================================================
    // IMAGE UPLOAD
    // ============================================================
    const uploadArea = document.getElementById('uploadArea');
    const imageInput = document.getElementById('imageInput');

    uploadArea?.addEventListener('click', () => {
      imageInput?.click();
    });

    uploadArea?.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadArea.classList.add('border-blue-500', 'dark:border-blue-400', 'bg-blue-50', 'dark:bg-blue-900/10');
    });

    uploadArea?.addEventListener('dragleave', () => {
      uploadArea.classList.remove('border-blue-500', 'dark:border-blue-400', 'bg-blue-50', 'dark:bg-blue-900/10');
    });

    uploadArea?.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadArea.classList.remove('border-blue-500', 'dark:border-blue-400', 'bg-blue-50', 'dark:bg-blue-900/10');
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        handleImageFile(files[0]);
      }
    });

    imageInput?.addEventListener('change', (e) => {
      const files = e.target.files;
      if (files.length > 0) {
        handleImageFile(files[0]);
      }
    });

    function handleImageFile(file) {
      const validTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
      if (!validTypes.includes(file.type)) {
        showToast('Format file tidak didukung. Gunakan JPG, PNG, atau GIF.');
        return;
      }

      if (file.size > 2 * 1024 * 1024) {
        showToast('Ukuran file terlalu besar. Maksimal 2MB.');
        return;
      }

      const reader = new FileReader();
      reader.onload = (e) => {
        const preview = document.getElementById('imagePreview');
        const img = preview.querySelector('img');
        if (img) {
          img.src = e.target.result;
          preview.classList.remove('hidden');
          document.getElementById('uploadIcon').classList.add('hidden');
          document.getElementById('uploadText').textContent = file.name;
          document.getElementById('uploadText').classList.add('text-blue-600', 'dark:text-blue-400');
        }
      };
      reader.readAsDataURL(file);
    }

    // ============================================================
    // FORM SUBMISSION
    // ============================================================
    medalForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const name = document.getElementById('medalName').value;
      const category = document.getElementById('medalCategory').value;
      const status = document.getElementById('medalStatus').value;
      const stock = document.getElementById('medalStock').value;
      const description = document.getElementById('medalDescription').value;
      const imagePreview = document.getElementById('imagePreview');
      const img = imagePreview.querySelector('img');
      
      if (!name || !category || !status || !stock || !description) {
        showToast('⚠️ Mohon lengkapi semua field yang wajib diisi');
        return;
      }

      // Simulate save
      showToast(editingId ? '✅ Medali berhasil diupdate!' : '✅ Medali berhasil ditambahkan!');
      
      setTimeout(() => {
        closeModal();
        // Reload page to show new data (in production, this would update the UI dynamically)
        setTimeout(() => location.reload(), 500);
      }, 1000);
    });

    // ============================================================
    // DELETE MEDAL
    // ============================================================
    function deleteMedal(id) {
      if (!confirm('Yakin ingin menghapus medali ini?')) return;
      
      const card = document.querySelector(`#medalsGrid .group[data-id="${id}"]`);
      if (card) {
        card.style.transform = 'scale(0.9)';
        card.style.opacity = '0';
        setTimeout(() => {
          card.remove();
          showToast('Medali berhasil dihapus!');
          updateStats();
        }, 300);
      }
    }
    window.deleteMedal = deleteMedal;

    // ============================================================
    // UPDATE STATISTICS
    // ============================================================
    function updateStats() {
      const cards = document.querySelectorAll('#medalsGrid .group:not(:last-child)');
      const total = cards.length;
      const gold = document.querySelectorAll('#medalsGrid .group .bg-yellow-500').length;
      const silver = document.querySelectorAll('#medalsGrid .group .bg-gray-400').length;
      const stock = Array.from(document.querySelectorAll('#medalsGrid .group .absolute.bottom-0 .text-sm.font-medium'))
        .reduce((acc, el) => acc + parseInt(el.textContent?.replace('Stok: ', '') || '0'), 0);
      
      const statCards = document.querySelectorAll('.grid-cols-1.sm\\:grid-cols-2 .bg-white');
      if (statCards.length >= 4) {
        const totalCount = statCards[0].querySelector('.text-2xl');
        if (totalCount) totalCount.textContent = total;
        
        const goldCount = statCards[1].querySelector('.text-2xl');
        if (goldCount) goldCount.textContent = gold;
        
        const silverCount = statCards[2].querySelector('.text-2xl');
        if (silverCount) silverCount.textContent = silver;
        
        const stockCount = statCards[3].querySelector('.text-2xl');
        if (stockCount) stockCount.textContent = stock;
      }
    }

    // ============================================================
    // SEARCH
    // ============================================================
    const searchInput = document.getElementById('searchInput');
    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      const cards = document.querySelectorAll('#medalsGrid .group:not(:last-child)');
      
      cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(query) ? '' : 'none';
      });
    });

    // ============================================================
    // TOAST
    // ============================================================
    function showToast(message) {
      const toast = document.getElementById('toast');
      const toastMessage = document.getElementById('toast-message');
      
      if (toast && toastMessage) {
        toastMessage.textContent = message;
        toast.classList.remove('translate-y-full', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
        
        setTimeout(hideToast, 3000);
      }
    }
    window.showToast = showToast;

    function hideToast() {
      const toast = document.getElementById('toast');
      if (toast) {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('translate-y-full', 'opacity-0');
      }
    }
    window.hideToast = hideToast;

    // ============================================================
    // KEYBOARD SHORTCUTS
    // ============================================================
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    console.log('✅ Medali Admin Panel loaded');
  </script>
</AdminLayout>