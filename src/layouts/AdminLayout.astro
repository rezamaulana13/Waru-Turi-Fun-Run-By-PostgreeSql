---
// src/layouts/AdminLayout.astro
import { db, users, participants } from '../db/index.js';
import { eq, count } from 'drizzle-orm';
import { verifyToken } from '../lib/auth';

type Props = {
  title: string;
};

const { title } = Astro.props;

// ===== CEK AUTH & AMBIL DATA =====
let isAdmin = false;
let userData = null;
let totalParticipants = 0;

try {
  const token = Astro.cookies.get('token')?.value;
  if (token) {
    const decoded = verifyToken(token);
    if (decoded && typeof decoded !== 'string') {
      const user = await db.select().from(users).where(eq(users.id, decoded.id));
      if (user && user.length > 0 && (user[0].role === 'admin' || user[0].role === 'super_admin')) {
        isAdmin = true;
        userData = user[0];
      }
    }
  }
} catch (error) {
  console.error('Error checking auth:', error);
}

// ===== AMBIL JUMLAH PESERTA =====
try {
  const result = await db.select({ count: count() }).from(participants);
  totalParticipants = Number(result[0]?.count) || 0;
} catch (error) {
  console.error('Error fetching participant count:', error);
}

// ===== CEK PATH =====
const pathname = Astro.url.pathname;
const isLoginPage = pathname === '/auth/login';

// ===== UNAUTHORIZED =====
if (!isAdmin && !isLoginPage) {
  return Astro.redirect('/auth/login');
}

if (isAdmin && isLoginPage) {
  return Astro.redirect('/admin');
}
