        </a>

        <a href="/admin/contacts" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition group" data-path="/admin/contacts">
          <i class="bi bi-envelope text-lg text-gray-400 dark:text-gray-500 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition"></i>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition">Kontak</span>
        </a>

        <div class="my-3 border-t border-gray-200/50 dark:border-gray-700/50"></div>

        <button onclick="handleLogout()" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition group w-full">
          <i class="bi bi-box-arrow-right text-lg text-red-400 dark:text-red-500 group-hover:text-red-600 dark:group-hover:text-red-400 transition"></i>
          <span class="text-sm font-medium text-red-600 dark:text-red-400 group-hover:text-red-700 dark:group-hover:text-red-300 transition">Logout</span>
        </button>

        <a href="/admin/settings" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition group" data-path="/admin/settings">
          <i class="bi bi-gear text-lg text-gray-400 dark:text-gray-500 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition"></i>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition">Pengaturan</span>
        </a>
      </nav>
      
      <div class="mt-6 pt-4 border-t border-gray-200/50 dark:border-gray-700/50">
        <div class="px-3 py-2">
          <p class="text-[10px] text-gray-400 dark:text-gray-500">
            <i class="bi bi-shield-check mr-1"></i>
            Admin Access
          </p>
          <p class="text-[10px] text-gray-400 dark:text-gray-500 mt-0.5">
            v2.0 • Waru Turi 2027
          </p>
        </div>
      </div>
    </aside>

    <main class="flex-1 p-4 md:p-6 min-h-[calc(100vh-4rem)]">
      <slot />
    </main>
  </div>

  <script>
    window.handleLogout = async function() {
      if (confirm('Yakin ingin logout dari akun ini?')) {
        try {
          const btns = document.querySelectorAll('[onclick*="handleLogout"]');
          btns.forEach(btn => {
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Logout...';
            btn.disabled = true;
          });
          
          await fetch('/api/auth/logout', { 
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          
        } catch (e) {
          console.error('Logout error:', e);
        }
        
        localStorage.removeItem('token');
        localStorage.removeItem('user');
        sessionStorage.clear();
        window.location.href = '/';
      }
    };

    window.toggleSubmenu = function(id) {
      const submenu = document.getElementById(id + '-submenu');
      const arrow = document.getElementById(id + '-arrow');
      const submenuMobile = document.getElementById(id + '-submenu-mobile');
      const arrowMobile = document.getElementById(id + '-arrow-mobile');
      
      if (submenu) {
        submenu.classList.toggle('open');
        if (arrow) {
          arrow.classList.toggle('rotate-180');
        }
      }
      
      if (submenuMobile) {
        submenuMobile.classList.toggle('open');
        if (arrowMobile) {
          arrowMobile.classList.toggle('rotate-180');
        }
      }
      
      const isOpen = submenu ? submenu.classList.contains('open') : false;
      localStorage.setItem('submenu-' + id, isOpen ? 'open' : 'closed');
    };

    function restoreSubmenuState() {
      const submenus = ['informasi'];
      submenus.forEach(id => {
        const state = localStorage.getItem('submenu-' + id);
        
        const submenu = document.getElementById(id + '-submenu');
        const arrow = document.getElementById(id + '-arrow');
        const submenuMobile = document.getElementById(id + '-submenu-mobile');
        const arrowMobile = document.getElementById(id + '-arrow-mobile');
        
        if (state === 'open') {
          if (submenu) {
            submenu.classList.add('open');
            if (arrow) arrow.classList.add('rotate-180');
          }
          if (submenuMobile) {
            submenuMobile.classList.add('open');
            if (arrowMobile) arrowMobile.classList.add('rotate-180');
          }
        }
      });
    }

    const hamburgerBtn = document.getElementById('hamburger-btn');
    const closeSidebarBtn = document.getElementById('close-sidebar');
    const sidebarMobile = document.getElementById('sidebar-mobile');
    const sidebarOverlay = document.getElementById('sidebar-overlay');

    function openMobileSidebar() {
      sidebarMobile?.classList.add('open');
      sidebarOverlay?.classList.add('show');
      document.body.style.overflow = 'hidden';
    }

    function closeMobileSidebar() {
      sidebarMobile?.classList.remove('open');
      sidebarOverlay?.classList.remove('show');
      document.body.style.overflow = '';
    }

    hamburgerBtn?.addEventListener('click', openMobileSidebar);
    closeSidebarBtn?.addEventListener('click', closeMobileSidebar);
    sidebarOverlay?.addEventListener('click', closeMobileSidebar);

    document.querySelectorAll('#sidebar-mobile .sidebar-link, #sidebar-mobile .submenu-link').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
          setTimeout(closeMobileSidebar, 300);
        }
      });
    });

    const dropdownToggle = document.getElementById('user-dropdown-toggle');
    const dropdown = document.getElementById('user-dropdown');
    const arrow = document.getElementById('dropdown-arrow');

    dropdownToggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown?.classList.toggle('show');
      arrow?.classList.toggle('rotate-180');
    });

    document.addEventListener('click', (e) => {
      if (!dropdownToggle?.contains(e.target) && !dropdown?.contains(e.target)) {
        dropdown?.classList.remove('show');
        arrow?.classList.remove('rotate-180');
      }
    });

    const token = localStorage.getItem('token');
    if (!token) {
      window.location.href = '/auth/login';
    }

    try {
      const userStr = localStorage.getItem('user');
      if (userStr) {
        const user = JSON.parse(userStr);
        
        const elements = {
          name: document.getElementById('user-name'),
          avatar: document.getElementById('user-avatar'),
          role: document.getElementById('user-role'),
          dropdownName: document.getElementById('dropdown-name'),
          dropdownEmail: document.getElementById('dropdown-email')
        };
        
        const roleMap = {
          'admin': 'Administrator',
          'super_admin': 'Super Admin',
          'user': 'User'
        };
        
        if (elements.name && user.name) elements.name.textContent = user.name;
        if (elements.avatar && user.name) elements.avatar.textContent = user.name.charAt(0).toUpperCase();
        if (elements.role) elements.role.textContent = roleMap[user.role] || user.role || 'User';
        if (elements.dropdownName && user.name) elements.dropdownName.textContent = user.name;
        if (elements.dropdownEmail && user.email) elements.dropdownEmail.textContent = user.email;
      }
    } catch (e) {
      console.error('Error loading user:', e);
    }

    function setActiveMenu() {
      const currentPath = window.location.pathname;
      const links = document.querySelectorAll('.sidebar-link, .submenu-link');
      
      links.forEach(link => {
        link.classList.remove('active');
        const path = link.getAttribute('data-path');
        if (path && currentPath.includes(path)) {
          link.classList.add('active');
          
          if (link.classList.contains('submenu-link')) {
            const parentSubmenu = link.closest('.submenu');
            if (parentSubmenu) {
              parentSubmenu.classList.add('open');
              const parentId = parentSubmenu.id.replace('-submenu', '');
              const parentIdMobile = parentSubmenu.id.replace('-submenu', '-submenu-mobile');
              const submenuMobile = document.getElementById(parentIdMobile);
              if (submenuMobile) {
                submenuMobile.classList.add('open');
              }
              
              const arrow = document.getElementById(parentId + '-arrow');
              if (arrow) {
                arrow.classList.add('rotate-180');
              }
              const arrowMobile = document.getElementById(parentId + '-arrow-mobile');
              if (arrowMobile) {
                arrowMobile.classList.add('rotate-180');
              }
              
              localStorage.setItem('submenu-' + parentId, 'open');
            }
          }
        }
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      restoreSubmenuState();
      setActiveMenu();
    });

    document.addEventListener('keydown', (e) => {
      if (e.ctrlKey && e.shiftKey && e.key === 'L') {
        e.preventDefault();
        window.handleLogout();
      }
    });

    console.log('✅ Admin Panel loaded');
    console.log('📌 Keyboard shortcut: Ctrl+Shift+L for logout');
  </script>
</body>
</html>