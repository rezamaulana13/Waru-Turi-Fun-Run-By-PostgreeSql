---
// src/components/common/Navbar.astro
import { verifyToken, getUserByToken } from '../../lib/auth';

// Cek apakah user sudah login
let user = null;
let isLoggedIn = false;
let isAdmin = false;

try {
  const tokenCookie = Astro.cookies.get('token');
  const tokenValue = tokenCookie?.value || null;
  
  if (tokenValue) {
    const decoded = verifyToken(tokenValue);
    if (decoded) {
      user = await getUserByToken(tokenValue);
      isLoggedIn = !!user;
      isAdmin = user?.role === 'admin' || user?.role === 'super_admin';
    }
  }
} catch (error) {
  console.error('Error checking auth:', error);
}
---

