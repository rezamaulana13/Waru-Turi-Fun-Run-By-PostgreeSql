---
// src/components/sections/Intro.astro
import { db, aboutContent } from '../../db/index.js';
import { eq, asc } from 'drizzle-orm';

// ===== AMBIL DATA INTRO DARI DATABASE =====
let introData: Record<string, string> = {};

try {
  const result = await db.select().from(aboutContent)
    .where(eq(aboutContent.section, 'intro'))
    .orderBy(asc(aboutContent.order));
  
  if (result.length > 0) {
    result.forEach((item: any) => {
      introData[item.key] = item.value || '';
    });
  }
} catch (error) {
  console.error('Error fetching intro data:', error);
}

// Fallback data
const title = introData.title || 'A Celebration of Movement in Green Scenery';
const subtitle = introData.subtitle || 'Event lomba lari rekreasi yang menghadirkan semangat kebersamaan, gaya hidup sehat, dan sportivitas bagi seluruh peserta.';
const description = introData.description || 'Waru Turi Fun Run memadukan gaya hidup sehat dengan kepedulian terhadap lingkungan melalui aksi nyata penanaman pohon.';
const image = introData.image || 'https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgfZOME1jxvXjrMmS0NZZnJsTWtEX0Oe5mTBk4JUSvu91HJa8ae0x97XxDdg-Idlgxi1dY1yAh93CYZIl_Dc7q-pvO3VJiFtJjXskMGOouAg1Iy5lzd0KNb8yFDsT9g_RA9rVNenf4inQfTQ91PuDt5KKtqjXpabN5ecOlugbvRA-CmvbfCECre2Ql8z3ZU/s1536/Harga%20Reguler%20Waru%20Turi%20Fun%20Run%202026%20Landscape.jpeg.jpg';
const stat1 = introData.stat_1 || '1';
const stat1Label = introData.stat_1_label || 'DAY EVENT';
const stat2 = introData.stat_2 || '5K';
const stat2Label = introData.stat_2_label || 'RUN';
const stat3 = introData.stat_3 || '10K';
const stat3Label = introData.stat_3_label || 'RUN';

// Card data
const card1Title = introData.card_1_title || 'Healthy Lifestyle';
const card1Desc = introData.card_1_desc || 'Rekreasi lari untuk semua level peserta.';
const card2Title = introData.card_2_title || 'Eco Action';
const card2Desc = introData.card_2_desc || 'Aksi nyata penghijauan & penanaman pohon.';
---

<section id="intro" class="py-16 sm:py-20 lg:py-24 bg-[#F4F7FC]">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Left Content -->
      <div>
        <span class="inline-block text-[#0033A0] font-semibold text-sm uppercase tracking-wider mb-3 bg-blue-50 px-4 py-1.5 rounded-full">
          <i class="bi bi-info-circle mr-1"></i> Tentang Event
        </span>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-gray-900 mb-4 leading-tight">
          {title}
        </h2>
        <p class="text-base sm:text-lg text-gray-600 mb-3 leading-relaxed">
          {subtitle}
        </p>
        <p class="text-gray-600 mb-6 leading-relaxed">
          <strong>Waru Turi Fun Run</strong> {description}
        </p>
        
        <!-- Stats -->
        <div class="flex gap-6 sm:gap-10">
          <div class="text-center">
            <h3 class="text-3xl sm:text-4xl font-extrabold text-[#0033A0]">{stat1}</h3>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">{stat1Label}</p>
            <div class="w-8 h-1 bg-[#00A3E0] rounded-full mx-auto mt-2"></div>
          </div>
          <div class="text-center">
            <h3 class="text-3xl sm:text-4xl font-extrabold text-[#0033A0]">{stat2}</h3>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">{stat2Label}</p>
            <div class="w-8 h-1 bg-[#00A3E0] rounded-full mx-auto mt-2"></div>
          </div>
          <div class="text-center">
            <h3 class="text-3xl sm:text-4xl font-extrabold text-[#0033A0]">{stat3}</h3>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">{stat3Label}</p>
            <div class="w-8 h-1 bg-[#00A3E0] rounded-full mx-auto mt-2"></div>
          </div>
        </div>
      </div>

      <!-- Right Content -->
      <div>
        <img 
          src={image}
          alt="Waru Turi Fun Run" 
          class="w-full rounded-2xl shadow-xl mb-6"
          width="800"
          height="450"
          loading="lazy"
          decoding="async"
        />
        
        <!-- Highlight Cards -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-md hover:shadow-xl transition-all hover:-translate-y-1 border border-gray-100">
            <i class="bi bi-heart-pulse text-3xl text-[#0033A0]"></i>
            <h4 class="font-bold text-gray-900 mt-2 text-sm sm:text-base">{card1Title}</h4>
            <p class="text-xs sm:text-sm text-gray-500">{card1Desc}</p>
          </div>
          <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-md hover:shadow-xl transition-all hover:-translate-y-1 border border-gray-100">
            <i class="bi bi-tree text-3xl text-[#0033A0]"></i>
            <h4 class="font-bold text-gray-900 mt-2 text-sm sm:text-base">{card2Title}</h4>
            <p class="text-xs sm:text-sm text-gray-500">{card2Desc}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #intro {
    contain: layout paint;
  }
  
  #intro img {
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    #intro .hover\:-translate-y-1 {
      transform: none !important;
      transition: none !important;
    }
  }
</style>