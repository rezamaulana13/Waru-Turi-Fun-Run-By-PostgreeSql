---
// src/components/sections/Tabs.astro
import { db, aboutContent } from '../../db/index.js';
import { eq, asc } from 'drizzle-orm';

// ===== AMBIL DATA TABS DARI DATABASE =====
let tabsData: Record<string, any> = {};
let tabItems: { id: string; icon: string; title: string; content: string; image: string; features: string[] }[] = [];

try {
  const result = await db.select().from(aboutContent)
    .where(eq(aboutContent.section, 'tabs'))
    .orderBy(asc(aboutContent.order));
  
  if (result.length > 0) {
    result.forEach((item: any) => {
      tabsData[item.key] = item.value || '';
    });
  }
} catch (error) {
  console.error('Error fetching tabs data:', error);
}

// ===== DATA DEFAULT =====
const title = tabsData.title || 'Informasi Race';

// Default tabs
const defaultTabs = [
  {
    id: 'tab1',
    icon: 'bi-flag',
    title: 'Race Info',
    content: 'Event Fun Run ini dirancang untuk semua kalangan, mulai dari pelari pemula hingga profesional. Peserta akan menikmati suasana lari santai, hiburan musik, serta berbagai fasilitas menarik.',
    image: 'https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgdH3wyXVm55V4ybo7Vzkhx20WX5osQDwvKtDVAjCVN7GL-xcIDGsh9s3XjMLGZbjXLeeVM9Bswk9zk8-UgiAs8NcByj2ed5_VEboE7PYmES_VPsGt2sEc9-EKag3eAbRoMPRAKPEr9ldJn94bBGhQZ4EBp3vpBpyaP1pk1YqjdkL802EiL0KVl5PYmyhq_/s710/Isi%20web%20600x600.webp',
    features: ['Jarak 5K & 10K', 'Start & finish nyaman', 'Water station tersedia', 'Keindahan Waru Turi']
  },
  {
    id: 'tab2',
    icon: 'bi-shield-check',
    title: 'Keamanan',
    content: 'Keamanan peserta adalah prioritas utama. Tim marshal, medis, dan keamanan akan berjaga di sepanjang rute untuk memastikan kenyamanan dan keselamatan pelari.',
    image: 'https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEiGLXPwjDGAoiJwD8mFMlBULp1ozljorJz-9puxEBQ-XHHlwX71p_vLIWwwfje6u1ilKokDPaWWkWx1XxhKnoNnNXW8NxU7zqNzyKqGyrW9bVzCaSbouHxSZLPTogr_GmanfH_43Z6LEuLtFuXYYgbOx3_ksIlKEj4Klw6UCLCdmsEFo4GdnAuXE-UDNqnr/s1224/keaman.jpg',
    features: ['Marshal sepanjang rute', 'Tim medis & ambulans standby', 'Pengamanan area event']
  },
  {
    id: 'tab3',
    icon: 'bi-lightning',
    title: 'Performa & Rute',
    content: 'Rute dirancang dengan jalur yang aman dan nyaman, memberikan pengalaman berlari terbaik bagi seluruh peserta.',
    image: 'https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgZ1qlMwJiSFMgXkXsn6di4rRX5BHvxuqDvhQu6HmSIyIBw5ynFo1NJTX3zyc8ETepMQBi2aeJNnHmCBRXjuC3A6ge6wdNjTG-L9d2OUQc7pqm36SXRLwvw-v9l36Jv9NihJoPw3azugAIh168vLhMSSZTmwJdQWtuJUAoBMBfATY2RGoNZ4D5INlUifSTY/s1280/waruturi3.jpeg',
    features: ['Rute aman & jelas', 'Penanda jarak setiap 1 km', 'Jalur datar & nyaman']
  },
  {
    id: 'tab4',
    icon: 'bi-people-fill',
    title: 'Layanan',
    content: 'Peserta mendapatkan berbagai fasilitas pendukung mulai dari starter kit, hiburan, hingga area istirahat.',
    image: 'https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhAEFZtsBJ9rw2tZsX85BI7yCuAelNeuGbR9igbVfnLx6abBjz3Bjcc2mgySj2QV7M97ySLCsGwxsI4QdFmIgOyCzImiMLGIjambeTovsixarg5JokoURMojJhZUGzTe24nQ3P-nSi6ZHXJfw2q6LTvvm0ci_zhfRQL2G1H5O1aE_jumxcsqjvB2hyphenhyphenw_ehn/s960/Waru%20Turi%20Fun%20Run%202026%20(4).webp',
    features: ['Jersey Official', 'BIB peserta', 'Doorprize & hadiah', 'Hiburan musik & MC']
  }
];

// Parse tabs dari database atau pakai default
if (tabsData.tabs) {
  try {
    const parsed = JSON.parse(tabsData.tabs);
    if (Array.isArray(parsed) && parsed.length > 0) {
      tabItems = parsed;
    } else {
      tabItems = defaultTabs;
    }
  } catch {
    tabItems = defaultTabs;
  }
} else {
  tabItems = defaultTabs;
}

// ===== AMBIL DATA TITLE =====
let pageTitle = title;
try {
  const titleResult = await db.select().from(aboutContent)
    .where(eq(aboutContent.section, 'tabs'))
    .where(eq(aboutContent.key, 'title'));
  if (titleResult.length > 0) {
    pageTitle = titleResult[0].value || title;
  }
} catch {
  // fallback
}
---

<section id="info" class="py-16 sm:py-20 lg:py-24 bg-[#F4F7FC]">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-center text-gray-900 mb-8 sm:mb-12">
      {pageTitle}
    </h2>

    <!-- Tabs Navigation -->
    <div class="flex flex-wrap justify-center gap-2 sm:gap-3 mb-6 sm:mb-8">
      {tabItems.slice(0, 4).map((tab, index) => (
        <button 
          key={tab.id}
          class={`tab-btn ${index === 0 ? 'active' : ''} px-4 sm:px-6 py-2.5 sm:py-3 rounded-full bg-white border border-gray-200 font-semibold text-sm sm:text-base transition-all hover:border-[#0033A0] hover:text-[#0033A0] flex items-center gap-2`}
          data-tab={tab.id}
        >
          <i class={`bi ${tab.icon}`}></i> {tab.title}
        </button>
      ))}
    </div>

    <!-- Tab Content -->
    {tabItems.slice(0, 4).map((tab, index) => (
      <div 
        key={tab.id}
        id={tab.id}
        class={`tab-content ${index === 0 ? 'active' : 'hidden'} bg-white rounded-2xl p-6 sm:p-8 lg:p-10 shadow-md animate-fade`}
      >
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10 items-center">
          <div>
            <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900 mb-4">{tab.title}</h3>
            <p class="text-gray-600 leading-relaxed mb-6">{tab.content}</p>
            <div class="grid grid-cols-2 gap-3">
              {tab.features && tab.features.map((feature, i) => (
                <div key={i} class="flex items-center gap-2 text-sm font-medium text-gray-700">
                  <i class="bi bi-check-circle-fill text-[#00A3E0]"></i> {feature}
                </div>
              ))}
            </div>
          </div>
          <div>
            <img 
              src={tab.image}
              alt={tab.title}
              class="w-full rounded-xl"
              loading="lazy"
              decoding="async"
              onerror="this.style.display='none'"
            />
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  #info {
    contain: layout paint;
  }

  #info img {
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  .tab-btn {
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
  }
  
  .tab-btn.active {
    background: #0033A0;
    color: white;
    border-color: #0033A0;
  }

  .tab-content {
    transition: opacity 0.3s ease;
  }

  .tab-content.active {
    display: block;
    animation: fadeIn 0.4s ease;
  }

  .tab-content.hidden {
    display: none;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tab-content.active {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    #info .tab-btn {
      padding: 0.5rem 0.75rem;
      font-size: 0.7rem;
    }
    #info .tab-btn i {
      font-size: 0.7rem;
    }
    #info .grid-cols-2 {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // ===== TABS FUNCTIONALITY =====
  document.addEventListener('DOMContentLoaded', function() {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        // Remove active class from all tabs
        tabs.forEach(function(t) {
          t.classList.remove('active');
        });
        tab.classList.add('active');
        
        // Hide all tab contents
        contents.forEach(function(c) {
          c.classList.remove('active');
          c.classList.add('hidden');
        });
        
        // Show target content
        const target = document.getElementById(tab.dataset.tab);
        if (target) {
          target.classList.remove('hidden');
          target.classList.add('active');
        }
      });
    });

    // ===== KEYBOARD NAVIGATION =====
    const tabKeys = ['ArrowLeft', 'ArrowRight', 'Home', 'End'];
    document.addEventListener('keydown', function(e) {
      if (!tabKeys.includes(e.key)) return;
      
      const activeTab = document.querySelector('.tab-btn.active');
      if (!activeTab) return;
      
      const tabsList = Array.from(document.querySelectorAll('.tab-btn'));
      const currentIndex = tabsList.indexOf(activeTab);
      let newIndex = currentIndex;
      
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        newIndex = Math.max(0, currentIndex - 1);
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        newIndex = Math.min(tabsList.length - 1, currentIndex + 1);
      } else if (e.key === 'Home') {
        e.preventDefault();
        newIndex = 0;
      } else if (e.key === 'End') {
        e.preventDefault();
        newIndex = tabsList.length - 1;
      }
      
      if (newIndex !== currentIndex) {
        tabsList[newIndex].click();
        tabsList[newIndex].focus();
      }
    });
  });
</script>