---
// src/components/sections/CTA.astro
import { db, aboutContent } from '../../db/index.js';
import { eq } from 'drizzle-orm';

// ===== AMBIL DATA CTA DARI DATABASE =====
let ctaData: Record<string, string> = {};

try {
  const result = await db.select().from(aboutContent).where(eq(aboutContent.section, 'cta'));
  
  if (result.length > 0) {
    result.forEach((item: any) => {
      ctaData[item.key] = item.value || '';
    });
  }
} catch (error) {
  console.error('Error fetching CTA data:', error);
}

// Fallback data
const title = ctaData.title || 'Siap Mengikuti Waru Turi Fun Run 2026?';
const description = ctaData.description || 'Tunjukkan Race terbaik kalian dan dapatkan medali eksklusif!';
const ctaText = ctaData.cta_text || 'Daftar Sekarang';
const ctaLink = ctaData.cta_link || '/daftar';
const ctaSecondaryText = ctaData.cta_secondary_text || 'Pelajari Rute';
const ctaSecondaryLink = ctaData.cta_secondary_link || '/rute';
---

<section id="cta" class="py-16 sm:py-20 lg:py-24 bg-gradient-to-br from-[#002266] to-[#0033A0] text-white overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto bg-white/5 backdrop-blur-sm rounded-2xl p-8 sm:p-10 lg:p-12 border border-white/10 text-center">
      <h3 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold mb-3">
        {title}
      </h3>
      <p class="text-white/80 text-base sm:text-lg mb-6 sm:mb-8 max-w-2xl mx-auto">
        {description}
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
        <a 
          href={ctaLink}
          class="inline-flex items-center justify-center gap-2 bg-[#FF6B00] hover:bg-[#E86000] text-white font-bold px-8 sm:px-10 py-3.5 sm:py-4 rounded-full transition-all hover:shadow-xl hover:-translate-y-1 active:scale-95"
        >
          <i class="bi bi-ticket-perforated"></i>
          {ctaText}
        </a>
        <a 
          href={ctaSecondaryLink}
          class="inline-flex items-center justify-center gap-2 bg-transparent hover:bg-white/10 text-white font-bold px-8 sm:px-10 py-3.5 sm:py-4 rounded-full border-2 border-white/30 hover:border-white transition-all hover:-translate-y-1 active:scale-95"
        >
          <i class="bi bi-map"></i>
          {ctaSecondaryText}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* ===== OPTIMASI ===== */
  #cta {
    contain: layout paint;
  }
  
  #cta .backdrop-blur-sm {
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }

  /* ===== REDUCE MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    #cta a {
      transition: none !important;
      transform: none !important;
    }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 640px) {
    #cta .rounded-2xl {
      padding: 1.5rem;
    }
  }
</style>