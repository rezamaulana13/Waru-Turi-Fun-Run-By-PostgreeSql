<style>
  /* ===== OPTIMASI: Hanya CSS yang diperlukan ===== */
  .sponsor-slider {
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .sponsor-track {
    display: flex;
    width: fit-content;
    animation: scrollSponsors 25s linear infinite;
    will-change: transform;
  }

  .sponsor-group {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    padding-right: 50px;
  }

  @keyframes scrollSponsors {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  /* ===== ANIMASI LOADING CEPAT ===== */
  @keyframes fadeDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-down {
    opacity: 0;
    animation: fadeDown 0.6s ease forwards;
  }
  
  .animation-delay-200 { animation-delay: 0.1s; }
  .animation-delay-400 { animation-delay: 0.2s; }
  .animation-delay-600 { animation-delay: 0.3s; }
  .animation-delay-700 { animation-delay: 0.35s; }
  .animation-delay-800 { animation-delay: 0.4s; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 640px) {
    .sponsor-group {
      padding-right: 30px;
    }
    .sponsor-group img {
      height: 20px;
      margin: 0 8px;
    }
    .animate-fade-down {
      animation-duration: 0.4s;
    }
  }

  @media (max-width: 480px) {
    .sponsor-group {
      padding-right: 20px;
    }
    .sponsor-group img {
      height: 16px;
      margin: 0 6px;
    }
  }

  /* ===== REDUCE MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    .sponsor-track {
      animation: none;
    }
    .animate-fade-down {
      opacity: 1;
      animation: none;
    }
  }
</style>