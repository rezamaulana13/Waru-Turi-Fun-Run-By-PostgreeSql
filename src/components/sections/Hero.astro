---
// src/components/sections/Hero.astro
import Countdown from '../ui/Countdown.astro';
import { db, aboutContent } from '../../db/index.js';
import { eq, asc } from 'drizzle-orm';

// ===== AMBIL DATA HERO DARI DATABASE =====
let heroData: Record<string, string> = {};
let hasHeroData = false;

try {
  const result = await db.select().from(aboutContent)
    .where(eq(aboutContent.section, 'hero'))
    .orderBy(asc(aboutContent.order));
  
  if (result.length > 0) {
    result.forEach((item: any) => {
      heroData[item.key] = item.value || '';
    });
    hasHeroData = true;
  }
} catch (error) {
  console.error('Error fetching hero data:', error);
}

// Fallback data
const fallbackData = {
  title: 'Waru Turi Fun Run 2026',
  subtitle: 'Lari Sehat, Hidup Berkah',
  description: 'Event lomba lari rekreasi di Bendung Waru Turi, Kediri.',
  cta_text: 'Daftar Sekarang',
  cta_link: '/daftar',
  image: '/images/hero-header.webp',
  event_date: '15 Februari 2026',
  event_location: 'Bendung Waru Turi, Kediri'
};

const title = heroData.title || fallbackData.title;
const ctaText = heroData.cta_text || fallbackData.cta_text;
const ctaLink = heroData.cta_link || fallbackData.cta_link;
const heroImage = heroData.image || fallbackData.image;
const eventDate = heroData.event_date || fallbackData.event_date;
const eventLocation = heroData.event_location || fallbackData.event_location;
---

<section id="hero" class="hero-section relative min-h-screen flex items-center overflow-hidden">
  <!-- Background dengan overlay gradien (tanpa gambar background berat) -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-br from-[#002266] via-[#0033A0] to-[#00A3E0]"></div>
    
    <!-- Decorative circle -->
    <div class="absolute top-[-50%] right-[-20%] w-[600px] h-[600px] lg:w-[800px] lg:h-[800px] bg-white/5 rounded-full pointer-events-none"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 py-16 sm:py-20 lg:py-28">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Logo -->
      <div class="hero-logo-wrapper mb-4 sm:mb-6 animate-fade-down">
        <img 
          src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEj_7yqZkol2_oh-DOsILVsPCd4wV11OjAalFSlWtVwgX-ryCIq6eL8swt_xsLkmxpEC4FQYEUFr38libsnOhSPimz7DcWGHpA09petmLf_YWdDVKDHSrZlHV2j3aoYNsmQwmLMJCd2-Qfk2IdjRUlk6beTlQbJVb362F3FjKjs2L2nqBke4V_NTeCDBc816/s704/logo%20fun%20run%202026.webp" 
          alt="Waru Turi Fun Run Logo" 
          class="max-w-[200px] sm:max-w-[280px] lg:max-w-[320px] w-full mx-auto drop-shadow-2xl"
          width="320"
          height="auto"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'; document.getElementById('alt-title').style.display='block';"
        />
        <h1 id="alt-title" class="hidden text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white">{title}</h1>
      </div>

      <!-- Event Details -->
      <div class="flex flex-wrap justify-center gap-2 sm:gap-4 mb-6 sm:mb-8 animate-fade-down animation-delay-200">
        <div class="flex items-center gap-2 bg-white/15 backdrop-blur-sm px-4 sm:px-6 py-2 rounded-full text-white text-sm sm:text-base border border-white/20">
          <i class="bi bi-calendar-event"></i>
          <span>{eventDate}</span>
        </div>
        <div class="flex items-center gap-2 bg-white/15 backdrop-blur-sm px-4 sm:px-6 py-2 rounded-full text-white text-sm sm:text-base border border-white/20">
          <i class="bi bi-geo-alt-fill"></i>
          <span>{eventLocation}</span>
        </div>
      </div>

      <!-- Countdown -->
      <div class="countdown-container animate-fade-down animation-delay-400">
        <h4 class="text-white/80 text-xs sm:text-sm font-semibold tracking-[0.2em] uppercase mb-4">
          EVENT DIMULAI DALAM
        </h4>
        <Countdown />
      </div>

      <!-- CTA Section -->
      <div class="cta-section mt-6 sm:mt-10 animate-fade-down animation-delay-600">
        <a 
          href={ctaLink}
          class="inline-flex items-center gap-2 bg-white hover:bg-gray-100 text-[#0033A0] font-bold text-base sm:text-lg px-8 sm:px-12 py-4 sm:py-5 rounded-full transition-all shadow-lg hover:shadow-xl hover:-translate-y-1"
        >
          <i class="bi bi-ticket-perforated"></i>
          {ctaText}
        </a>
        <p class="text-white/70 text-sm mt-3">Kuota terbatas! Harga Early Bird Hingga Kuota Terpenuhi.</p>
      </div>

      <!-- Sertifikat Button -->
      <div class="sertifikat-section mt-4 animate-fade-down animation-delay-700">
        <a 
          href="/sertifikat"
          class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white font-medium text-sm px-6 py-3 rounded-full transition-all border border-white/20 hover:border-white/40"
        >
          <i class="bi bi-award"></i>
          Lihat Sertifikat
        </a>
      </div>

      <!-- Sponsors Section (optimasi) -->
      <div class="sponsors-section mt-12 sm:mt-16 opacity-90 animate-fade-down animation-delay-800">
        <h4 class="text-white/60 text-[10px] sm:text-xs font-semibold tracking-[0.2em] uppercase mb-4">
          DIDUKUNG OLEH
        </h4>
