---
// src/components/shared/Countdown.astro
export interface Props {
  targetDate?: string;
}

const { targetDate = '2026-02-15T00:00:00.000+07:00' } = Astro.props;
---

<div id="countdown" class="flex justify-center gap-2 sm:gap-3 md:gap-4">
  <!-- Akan diisi JavaScript -->
</div>

<script>
  // ===== TARGET DATE =====
  const target = new Date('{targetDate}').getTime();
  const countdownEl = document.getElementById('countdown');
  
  // ===== FORMAT NUMBER =====
  function pad(num) {
    return String(num).padStart(2, '0');
  }

  // ===== UPDATE COUNTDOWN =====
  function updateCountdown() {
    if (!countdownEl) return;
    
    const now = Date.now();
    const diff = target - now;

    // Jika event sudah dimulai
    if (diff <= 0) {
      countdownEl.innerHTML = `
        <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl px-6 py-4 text-center">
          <div class="text-xl sm:text-2xl font-bold text-white animate-pulse">🎉 Event Telah Dimulai!</div>
        </div>
      `;
      return;
    }

    // Hitung waktu
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((diff % (1000 * 60)) / 1000);

    // Render dengan DOM manipulation (lebih cepat dari innerHTML)
    const units = [
      { value: pad(days), label: 'Hari' },
      { value: pad(hours), label: 'Jam' },
      { value: pad(minutes), label: 'Menit' },
      { value: pad(seconds), label: 'Detik' }
    ];

    let html = '';
    for (const unit of units) {
      html += `
        <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl sm:rounded-2xl px-2 sm:px-4 py-2 sm:py-3 md:py-4 min-w-[55px] sm:min-w-[70px] md:min-w-[90px] text-center">
          <div class="text-xl sm:text-2xl md:text-4xl lg:text-5xl font-bold text-white leading-none">${unit.value}</div>
          <div class="text-[10px] sm:text-xs md:text-sm text-white/70 mt-1">${unit.label}</div>
        </div>
      `;
    }
    countdownEl.innerHTML = html;
  }

  // ===== INIT =====
  updateCountdown();

  // ===== SET INTERVAL =====
  let intervalId = setInterval(updateCountdown, 1000);

  // ===== CLEANUP =====
  document.addEventListener('astro:before-swap', () => {
    if (intervalId) {
      clearInterval(intervalId);
      intervalId = null;
    }
  });

  // ===== VISIBILITY CHANGE (pause when tab hidden) =====
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      if (intervalId) {
        clearInterval(intervalId);
        intervalId = null;
      }
    } else {
      if (!intervalId) {
        updateCountdown();
        intervalId = setInterval(updateCountdown, 1000);
      }
    }
  });
</script>

<style>
  #countdown {
    contain: layout paint;
  }
  
  #countdown .bg-white\/10 {
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  @media (prefers-reduced-motion: reduce) {
    #countdown .animate-pulse {
      animation: none;
    }
  }
</style>