---
// src/components/shared/ParticipantList.astro
import type { Participant } from "../../types";

export interface Props {
  participants: Participant[];
}

const { participants } = Props;
---

<div class="card overflow-hidden" x-data="participantList()">
  <!-- Search & Filter -->
  <div class="p-4 border-b border-gray-200 dark:border-gray-700">
    <div class="flex flex-col md:flex-row gap-4">
      <div class="flex-1 relative">
        <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
        <input
          x-model="search"
          @input="filterParticipants()"
          type="text"
          placeholder="Cari nama peserta..."
          class="w-full pl-10 pr-4 py-3 rounded-xl bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition"
        />
      </div>
      <select
        x-model="category"
        @change="filterParticipants()"
        class="px-4 py-3 rounded-xl bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition"
      >
        <option value="all">Semua Kategori</option>
        <option value="5K">5K</option>
        <option value="10K">10K</option>
        <option value="Pelajar">Pelajar</option>
      </select>
    </div>
  </div>

  <!-- Table -->
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-gray-50 dark:bg-gray-700/50">
        <tr>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600 dark:text-gray-300">No</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600 dark:text-gray-300">Nama</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600 dark:text-gray-300">Kota</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600 dark:text-gray-300">Jersey</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600 dark:text-gray-300">Kategori</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600 dark:text-gray-300">No. Start</th>
          <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600 dark:text-gray-300">Status</th>
        </tr>
      </thead>
      <tbody id="participantTable" class="divide-y divide-gray-200 dark:divide-gray-700">
        {participants.map((p, index) => (
          <tr
            key={p.id}
            class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition participant-row"
            x-show="showParticipant(p.nama, p.kategori)"
          >
            <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">{index + 1}</td>
            <td class="px-4 py-3 text-sm font-medium">{p.nama}</td>
            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">{p.kota}</td>
            <td class="px-4 py-3 text-sm">
              <span class="inline-block px-3 py-1 bg-primary-500/10 text-primary-500 rounded-full text-xs font-semibold">
                {p.jersey}
              </span>
            </td>
            <td class="px-4 py-3 text-sm">
              <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold
                ${p.kategori === '10K' ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400' :
                  p.kategori === 'Pelajar' ? 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400' :
                  'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400'}`}
              >
                {p.kategori}
              </span>
            </td>
            <td class="px-4 py-3 text-sm font-mono font-bold text-primary-500">#{p.nomor}</td>
            <td class="px-4 py-3 text-sm">
              <span class={`inline-block px-2 py-1 rounded-full text-xs font-semibold
                ${p.status === 'confirmed' ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400' :
                  p.status === 'pending' ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400' :
                  'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400'}`}
              >
                {p.status === 'confirmed' ? '✔ Terkonfirmasi' :
                 p.status === 'pending' ? '⏳ Pending' : '✖ Batal'}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Empty State -->
  <div id="emptyState" class="hidden p-8 text-center text-gray-500 dark:text-gray-400">
    <i class="bi bi-search text-4xl block mb-3"></i>
    <p>Tidak ada peserta yang ditemukan</p>
  </div>
</div>

<script>
  function participantList() {
    return {
      search: '',
      category: 'all',
      filteredParticipants: [],
      
      filterParticipants() {
        const rows = document.querySelectorAll('.participant-row');
        const empty = document.getElementById('emptyState');
        let visible = 0;
        
        rows.forEach(row => {
          const name = row.querySelector('td:nth-child(2)')?.textContent?.toLowerCase() || '';
          const kategori = row.querySelector('td:nth-child(5) span')?.textContent || '';
          
          const matchSearch = name.includes(this.search.toLowerCase().trim());
          const matchCategory = this.category === 'all' || kategori === this.category;
          
          if (matchSearch && matchCategory) {
            row.style.display = '';
            visible++;
          } else {
            row.style.display = 'none';
          }
        });
        
        if (empty) {
          empty.classList.toggle('hidden', visible > 0);
        }
      },
      
      showParticipant(nama, kategori) {
        const matchSearch = nama.toLowerCase().includes(this.search.toLowerCase().trim());
        const matchCategory = this.category === 'all' || kategori === this.category;
        return matchSearch && matchCategory;
      }
    };
  }
</script>